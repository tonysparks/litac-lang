{
    "description": "Json",
    "disabled": false,
    "program": `
        @include("assert.h");
        @foreign func assert(e:bool):void;

        %definitions%

        func main(len:i32, args:**char):i32 {
            %code%
            return 0;
        }
    `,
    "tests": [

        {
            "name": "Json Parse",
           // disabled: true,
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/io";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()


                //var data: char*;
                //var status = readFile("C:/Users/antho/git/mini/assets/mini_city.json", &data)
                //if(status) {
                //    printf("Failed to open\n")
                //    return 1;
                //}
                //var n = ParseJson(data)

                //PrintJson(n, &buf)
                //printf("%s\n", buf.cStr())


                var node = parser.parseJson($"""
                    [
                         true, 4, false, "hi", 34343, null, [5],
                         {
                            "k" : "v"
                         }

                    ]
                """)


                buf.clear()
                PrintJson(node, &buf)

                //printf("'%s'\n", buf.cStr())
                assert( strcmp(buf.cStr(), "[true,4,false,\"hi\",34343,null,[5],{\"k\":\"v\"}]") == 0)
                node.free()

            `,
        },


        {
            "name": "Json Create",
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/io";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()

                var obj = CreateJsonObject()
                var a   = CreateJsonArray()
                obj.put("a", a)

                a = obj.get("a")
                if(a) {
                    a.add(CreateJsonNumber(4.5))
                    a.add(CreateJsonString("Hello World!"))
                    a.add(JSON_TRUE)
                    a.add(JSON_FALSE)
                    a.add(JSON_NULL)
                    var obj2 = CreateJsonObject()
                    obj2.put("b", CreateJsonString("Nirvana!"))
                    a.add(obj2)
                }

                PrintJson(obj, &buf)
                //printf("'%s'\n", buf.cStr())
                assert( strcmp(buf.cStr(), "{\"a\":[4.500000,\"Hello World!\",true,false,null,{\"b\":\"Nirvana!\"}]}") == 0)
                obj.free()
            `,
        },
        {
            "name": "Json Error",
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/io";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()

                var node = parser.parseJson($"""
                    [
                         true, 4, false, "hi", 34343, null, [5],

                            "k" : "v"
                         }

                    ]
                """)
                //printf("error: '%s'\n", parser.errorMsg)

                assert(node == null)
                assert(parser.hasError() == true)
                assert( strcmp(parser.errorMsg, "Expected token ], got :") == 0)
            `,
        },
        {
            "name": "Json Token Error",
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/io";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()

                var node = parser.parseJson($"""
                    fase
                """)
                //printf("error: '%s'\n", parser.errorMsg)

                assert(node == null)
                assert(parser.hasError() == true)
                assert( strcmp(parser.errorMsg, "invalid identifier, did you mean 'false'?") == 0)
            `,
        },
        {
            "name": "Json Token in complex Error",
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/io";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()

                var node = parser.parseJson($"""
                    [
                         tru, 4, false, "hi", 34343, null, [5],
                         {
                            "k" : "v"
                         }

                    ]
                """)
                //printf("error: '%s'\n", parser.errorMsg)

                assert(node == null)
                assert(parser.hasError() == true)
                assert( strcmp(parser.errorMsg, "invalid identifier, did you mean 'true'?") == 0)

            `,
        },
        {
            "name": "Json Token Stream Error",
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/io";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()

                var node = parser.parseJson($"""
                    [
                         true 4, false, "hi", 34343, null, [5],
                         {
                            "k" : "v"
                         }

                    ]
                """)
                //printf("error: '%s'\n", parser.errorMsg)

                assert(node == null)
                assert(parser.hasError() == true)
                assert( strcmp(parser.errorMsg, "Expected token ], got int") == 0)
            `,
        },
        {
            "name": "Json Negative Float",
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()

                var node = parser.parseJson($"""
                    {
                        "amount": -4.22,
                        "credit": -100.5,
                        "debit": 9.99,
                        "neg_int": -7,
                        "zero": 0.0
                    }
                """)

                assert(node != null)
                assert(!parser.hasError())
                assert(node.getFloat("amount", 0.0) == -4.22)
                assert(node.getFloat("credit", 0.0) == -100.5)
                assert(node.getFloat("debit", 0.0) == 9.99)
                assert(node.getInt("neg_int", 0) == -7)
                assert(node.getFloat("zero", 1.0) == 0.0)
                node.free()
            `,
        },
        {
            "name": "Json Negative Float In Array",
            "definitions": `
                import "std/json";
                import "std/string/builder";
                import "std/libc";

            `,
            "code": `
                var buf : StringBuilder;
                buf.init(16)

                var parser = JsonParser{}
                parser.init()
                defer parser.free()

                var node = parser.parseJson($"""
                    [-4.22, -100.5, 9.99, -7, 0.0]
                """)

                assert(node != null)
                assert(!parser.hasError())
                assert(node.size() == 5)
                assert(node.at(0).asFloat() == -4.22)
                assert(node.at(1).asFloat() == -100.5)
                assert(node.at(2).asFloat() == 9.99)
                assert(node.at(3).asInt() == -7)
                assert(node.at(4).asFloat() == 0.0)
                node.free()
            `,
        },
    ]
}