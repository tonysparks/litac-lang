import "std/json"
import "std/json/from_json"
import "std/json/to_json"
import "std/string"
import "std/string/builder"
import "std/string/buffer"
import "std/libc"
import "std/assert"
import "std/mem"

// -------------------------------------------------------------------------
// Helpers
// -------------------------------------------------------------------------

// Calls toJson on s and asserts the raw output (including surrounding quotes)
// equals expected.
func assertToJson(s: String, expected: *const char) {
    var sb = StringBuilderInit(64)
    defer sb.free()
    s.toJson(&sb)
    assert(strcmp(sb.cStr(), expected) == 0)
}

// Parses the JSON object {"k":<jsonText>}, calls String.fromJson, and returns
// the decoded string. The returned buffer is owned by the parser's allocator
// (lives as long as the parser, which leaks in tests — fine for assertions).
func decodeJsonToString(jsonObj: *const char) : String {
    var ctx = JsonContextInit()
    var parser = JsonParserInit()
    var node = parser.parseJson(StringInit(jsonObj))
    assert(!parser.hasError())
    assert(node != null)
    var s = String{}
    s.fromJson(&ctx, node.get("k"))
    return s
}

// Parses and calls StringBuffer.fromJson; caller supplies the backing array.
func decodeJsonToStringBuffer(jsonObj: *const char, buf: *char, cap: i32) : StringBuffer {
    var ctx = JsonContextInit()
    var parser = JsonParserInit()
    var node = parser.parseJson(StringInit(jsonObj))
    assert(!parser.hasError())
    assert(node != null)
    var sb = StringBufferInit(buf, cap)
    sb.fromJson(&ctx, node.get("k"))
    return sb
}

// Parses and calls StringBuilder.fromJson into a caller-supplied builder.
func decodeJsonToStringBuilder(jsonObj: *const char, sb: *StringBuilder) {
    var ctx = JsonContextInit()
    var parser = JsonParserInit()
    var node = parser.parseJson(StringInit(jsonObj))
    assert(!parser.hasError())
    assert(node != null)
    sb.fromJson(&ctx, node.get("k"))
}

// -------------------------------------------------------------------------
// to_json — baseline
// -------------------------------------------------------------------------

@test
func testToJsonStringEmpty() {
    assertToJson($"", "\"\"")
}

@test
func testToJsonStringPlain() {
    assertToJson($"hello", "\"hello\"")
}

@test
func testToJsonStringUtf8MultiByte() {
    // "café" — the 'é' is a 2-byte UTF-8 sequence (0xC3 0xA9), whose lead byte is >= 0x80.
    // Regression: JsonEscapeString indexed its 256-entry escape table with a sign-extended
    // char, turning bytes >= 0x80 into a huge index and crashing (OOB read) instead of
    // passing the raw UTF-8 bytes through unescaped, as JSON allows.
    var raw: [5]char
    raw[0] = 'c'
    raw[1] = 'a'
    raw[2] = 'f'
    raw[3] = 0xC3 as (char)
    raw[4] = 0xA9 as (char)

    var expected: [7]char
    expected[0] = '"'
    expected[1] = 'c'
    expected[2] = 'a'
    expected[3] = 'f'
    expected[4] = 0xC3 as (char)
    expected[5] = 0xA9 as (char)
    expected[6] = '"'

    var sb = StringBuilderInit(64)
    defer sb.free()
    StringInit(raw, 5).toJson(&sb)
    assert(sb.length == 7)
    assert(memcmp(sb.buffer as (*const void), (&expected[0]) as (*const void), 7) == 0)
}

@test
func testToJsonStringUtf8Emoji() {
    // 4-byte UTF-8 sequence (U+1F600 GRINNING FACE), also exercises bytes >= 0x80.
    var raw: [4]char
    raw[0] = 0xF0 as (char)
    raw[1] = 0x9F as (char)
    raw[2] = 0x98 as (char)
    raw[3] = 0x80 as (char)

    var expected: [6]char
    expected[0] = '"'
    expected[1] = 0xF0 as (char)
    expected[2] = 0x9F as (char)
    expected[3] = 0x98 as (char)
    expected[4] = 0x80 as (char)
    expected[5] = '"'

    var sb = StringBuilderInit(64)
    defer sb.free()
    StringInit(raw, 4).toJson(&sb)
    assert(sb.length == 6)
    assert(memcmp(sb.buffer as (*const void), (&expected[0]) as (*const void), 6) == 0)
}

