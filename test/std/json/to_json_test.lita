// -------------------------------------------------------------------------
// from_json — multi-char
// -------------------------------------------------------------------------

@test
func testFromJsonStringMixed() {
    // JSON: {"k":"a\tb\nc"}  → decoded: a <TAB> b <LF> c
    var s = decodeJsonToString("{\"k\":\"a\\tb\\nc\"}")
    assert(s.length == 5)
    assert(s.buffer[0] == 'a')
    assert(s.buffer[1] == '\t')
    assert(s.buffer[2] == 'b')
    assert(s.buffer[3] == '\n')
    assert(s.buffer[4] == 'c')
}

@test
func testFromJsonStringAllEscapesInSequence() {
    // JSON text (7 escape sequences): "\"\\\b\f\n\r\t"
    // C literal for that JSON object:  {"k":"\"\\\\\\b\\f\\n\\r\\t"}
    var s = decodeJsonToString("{\"k\":\"\\\"\\\\\\b\\f\\n\\r\\t\"}")
    assert(s.length == 7)
    assert(s.buffer[0] == '"')
    assert(s.buffer[1] == '\\')
    assert(s.buffer[2] == '\b')
    assert(s.buffer[3] == '\f')
    assert(s.buffer[4] == '\n')
    assert(s.buffer[5] == '\r')
    assert(s.buffer[6] == '\t')
}

// -------------------------------------------------------------------------
// Round-trip — each escape sequence
// -------------------------------------------------------------------------

// Encodes a single char to JSON, wraps it in {"k":...}, parses back, and
// asserts the decoded char matches the original.
func assertRoundTrip(c: char) {
    var input: [1]char
    input[0] = c
    var s = StringInit(input, 1)

    // to_json
    var encoded = StringBuilderInit(32)
    defer encoded.free()
    s.toJson(&encoded)

    // wrap for parser
    var wrapped = StringBuilderInit(64)
    defer wrapped.free()
    wrapped.append("{\"k\":%.*s}", encoded.length, encoded.buffer)

    // from_json
    var decoded = decodeJsonToString(wrapped.cStr())
    assert(decoded.length == 1)
    assert(decoded.buffer[0] == c)
}

@test
func testRoundTripDoubleQuote() {
    assertRoundTrip('"')
}

@test
func testRoundTripBackspace() {
    assertRoundTrip('\b')
}

@test
func testRoundTripFormFeed() {
    assertRoundTrip('\f')
}

@test
func testRoundTripNewline() {
    assertRoundTrip('\n')
}

@test
func testRoundTripCarriageReturn() {
    assertRoundTrip('\r')
}

@test
func testRoundTripTab() {
    assertRoundTrip('\t')
}

@test
func testRoundTripBackslash() {
    assertRoundTrip('\\')
}

@test
func testRoundTripEmailBody() {
    // Multi-char string with multiple escape types — the original regression.
    var original = $"hello\tworld\n\"quoted\"\r\n"

    var encoded = StringBuilderInit(64)
    defer encoded.free()
    original.toJson(&encoded)

    var wrapped = StringBuilderInit(128)
    defer wrapped.free()
    wrapped.append("{\"k\":%.*s}", encoded.length, encoded.buffer)

    var decoded = decodeJsonToString(wrapped.cStr())
    assert(decoded.length == original.length)
    assert(strncmp(decoded.buffer, original.buffer, original.length as (usize)) == 0)
}

