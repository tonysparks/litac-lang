func assertToJsonCStr(s: *const char, expected: *const char) {
    var sb = StringBuilderInit(64)
    defer sb.free()
    s.toJson(&sb)
    assert(strcmp(sb.cStr(), expected) == 0)
}

@test
func testToJsonCStrNull() {
    var p: *const char = null
    assertToJsonCStr(p, "null")
}

@test
func testToJsonCStrEmpty() {
    assertToJsonCStr("", "\"\"")
}

@test
func testToJsonCStrPlain() {
    assertToJsonCStr("hello", "\"hello\"")
}

@test
func testToJsonCStrDoubleQuote() {
    assertToJsonCStr("\"", "\"\\\"\"")
}

@test
func testToJsonCStrBackspace() {
    // Build via a char array — \b in C string literals is reliable here.
    var raw: [2]char
    raw[0] = '\b'
    raw[1] = '\0'
    assertToJsonCStr(raw, "\"\\b\"")
}

@test
func testToJsonCStrFormFeed() {
    var raw: [2]char
    raw[0] = '\f'
    raw[1] = '\0'
    assertToJsonCStr(raw, "\"\\f\"")
}

@test
func testToJsonCStrNewline() {
    assertToJsonCStr("a\nb", "\"a\\nb\"")
}

@test
func testToJsonCStrCarriageReturn() {
    assertToJsonCStr("\r", "\"\\r\"")
}

@test
func testToJsonCStrTab() {
    assertToJsonCStr("\t", "\"\\t\"")
}

@test
func testToJsonCStrBackslash() {
    assertToJsonCStr("\\", "\"\\\\\"")
}

@test
func testToJsonCStrMixed() {
    assertToJsonCStr("say \"hi\"\n", "\"say \\\"hi\\\"\\n\"")
}

// -------------------------------------------------------------------------
// *const char round-trip
// -------------------------------------------------------------------------

func assertCStrRoundTrip(s: *const char) {
    var encoded = StringBuilderInit(64)
    defer encoded.free()
    s.toJson(&encoded)

    var wrapped = StringBuilderInit(128)
    defer wrapped.free()
    wrapped.append("{\"k\":%.*s}", encoded.length, encoded.buffer)

    var parser = JsonParserInit()
    var node = parser.parseJson(wrapped.toString())
    assert(!parser.hasError())
    assert(node != null)
    assert(strcmp(node.getStr("k"), s) == 0)
}

@test
func testRoundTripCStrDoubleQuote() {
    assertCStrRoundTrip("\"")
}

@test
func testRoundTripCStrNewline() {
    assertCStrRoundTrip("line1\nline2")
}

@test
func testRoundTripCStrTab() {
    assertCStrRoundTrip("\t")
}

@test
func testRoundTripCStrCarriageReturn() {
    assertCStrRoundTrip("\r")
}

@test
func testRoundTripCStrBackslash() {
    assertCStrRoundTrip("\\")
}

@test
func testRoundTripCStrMixed() {
    assertCStrRoundTrip("a\tb\nc\\d\"e")
}

// -------------------------------------------------------------------------
// JsonContext.copyStrings
// -------------------------------------------------------------------------

@test
func testFromJsonStringCopyStringsClonesAndSurvivesNodeFree() {
    // copyStrings defaults to true.
    var ctx = JsonContextInit()
    var parser = JsonParserInit()
    var node = parser.parseJson(StringInit("{\"k\":\"hello\"}"))
    assert(!parser.hasError())
    assert(node != null)

    var jsonStr = node.get("k")
    var s = String{}
    s.fromJson(&ctx, jsonStr)

    assert(s.buffer != jsonStr.asString()) // cloned, not aliased

    node.free() // must not invalidate s: it owns its own copy
    assert(s.equals($"hello"))
}

@test
func testFromJsonStringNoCopyAliasesJsonBuffer() {
    var ctx = JsonContextInit(DefaultMakeFn, DefaultMakePtrFn, defaultAllocator, false)
    var parser = JsonParserInit()
    var node = parser.parseJson(StringInit("{\"k\":\"hello\"}"))
    assert(!parser.hasError())
    assert(node != null)
    defer node.free()

    var jsonStr = node.get("k")
    var s = String{}
    s.fromJson(&ctx, jsonStr)

    assert(s.buffer == jsonStr.asString()) // aliased, not cloned
    assert(s.equals($"hello"))
}

@test
func testFromJsonCStrCopyStringsClonesAndSurvivesNodeFree() {
    var ctx = JsonContextInit()
    var parser = JsonParserInit()
    var node = parser.parseJson(StringInit("{\"k\":\"hello\"}"))
    assert(!parser.hasError())
    assert(node != null)

    var jsonStr = node.get("k")
    var raw: *const char = null
    var rawPtr = &raw
    rawPtr.fromJson(&ctx, jsonStr)

    assert(raw != jsonStr.asString()) // cloned, not aliased

    node.free() // must not invalidate raw: it owns its own copy
    assert(strcmp(raw, "hello") == 0)
}

@test
func testFromJsonCStrNoCopyAliasesJsonBuffer() {
    var ctx = JsonContextInit(DefaultMakeFn, DefaultMakePtrFn, defaultAllocator, false)
    var parser = JsonParserInit()
    var node = parser.parseJson(StringInit("{\"k\":\"hello\"}"))
    assert(!parser.hasError())
    assert(node != null)
    defer node.free()

    var jsonStr = node.get("k")
    var raw: *const char = null
    var rawPtr = &raw
    rawPtr.fromJson(&ctx, jsonStr)

    assert(raw == jsonStr.asString()) // aliased, not cloned
}
