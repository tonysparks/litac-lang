@test
func testToJsonStringDoubleQuote() {
    assertToJson($"\"", "\"\\\"\"")
}

@test
func testToJsonStringBackspace() {
    assertToJson($"\b", "\"\\b\"")
}

@test
func testToJsonStringFormFeed() {
    assertToJson($"\f", "\"\\f\"")
}

@test
func testToJsonStringNewline() {
    assertToJson($"\n", "\"\\n\"")
}

@test
func testToJsonStringCarriageReturn() {
    assertToJson($"\r", "\"\\r\"")
}

@test
func testToJsonStringTab() {
    assertToJson($"\t", "\"\\t\"")
}

@test
func testToJsonStringBackslash() {
    // Build via raw array: $"\\" is ambiguous in LitaC string literals.
    var raw: [1]char
    raw[0] = '\\'
    assertToJson(StringInit(raw, 1), "\"\\\\\"")
}

@test
func testToJsonStringNullByte() {
    var raw: [1]char
    raw[0] = '\0'
    assertToJson(StringInit(raw, 1), "\"\\0\"")
}

// -------------------------------------------------------------------------
// to_json — multi-char / mixed
// -------------------------------------------------------------------------

@test
func testToJsonStringAllEscapesInSequence() {
    // "  \b  \f  \n  \r  \t  \\
    var raw: [7]char
    raw[0] = '"'
    raw[1] = '\b'
    raw[2] = '\f'
    raw[3] = '\n'
    raw[4] = '\r'
    raw[5] = '\t'
    raw[6] = '\\'
    assertToJson(StringInit(raw, 7), "\"\\\"\\b\\f\\n\\r\\t\\\\\"")
}

@test
func testToJsonStringEscapesInterleavedWithPlain() {
    assertToJson($"a\nb", "\"a\\nb\"")
}

@test
func testToJsonStringMultipleNewlines() {
    assertToJson($"\n\n", "\"\\n\\n\"")
}

@test
func testToJsonStringEmailBodyRegression() {
    // The original bug: literal newlines in email body produced invalid JSON.
    assertToJson($"line1\n\nline2\n", "\"line1\\n\\nline2\\n\"")
}

// -------------------------------------------------------------------------
// to_json — StringBuffer and StringBuilder
// -------------------------------------------------------------------------

@test
func testToJsonStringBufferEscapes() {
    var raw: [32]char
    var sb = StringBuilderInit(64)
    defer sb.free()
    var sbuf = StringBufferInit(raw, 32)
    sbuf.appendStr("a\tb\nc")
    sbuf.toJson(&sb)
    assert(strcmp(sb.cStr(), "\"a\\tb\\nc\"") == 0)
}

@test
func testToJsonStringBuilderEscapes() {
    var src = StringBuilderInit(32)
    defer src.free()
    src.appendStr("say \"hi\"\n")

    var out = StringBuilderInit(64)
    defer out.free()
    src.toJson(&out)
    assert(strcmp(out.cStr(), "\"say \\\"hi\\\"\\n\"") == 0)
}

// -------------------------------------------------------------------------
// from_json — each escape sequence (String)
// -------------------------------------------------------------------------

@test
func testFromJsonStringDoubleQuote() {
    // JSON: {"k":"\""}  → decoded: "
    var s = decodeJsonToString("{\"k\":\"\\\"\"}")
    assert(s.length == 1)
    assert(s.buffer[0] == '"')
}

@test
func testFromJsonStringBackspace() {
    // JSON: {"k":"\b"}  → decoded: 0x08
    var s = decodeJsonToString("{\"k\":\"\\b\"}")
    assert(s.length == 1)
    assert(s.buffer[0] == '\b')
}

@test
func testFromJsonStringFormFeed() {
    // JSON: {"k":"\f"}  → decoded: 0x0C
    var s = decodeJsonToString("{\"k\":\"\\f\"}")
    assert(s.length == 1)
    assert(s.buffer[0] == '\f')
}

@test
func testFromJsonStringNewline() {
    // JSON: {"k":"\n"}  → decoded: 0x0A
    var s = decodeJsonToString("{\"k\":\"\\n\"}")
    assert(s.length == 1)
    assert(s.buffer[0] == '\n')
}

@test
func testFromJsonStringCarriageReturn() {
    // JSON: {"k":"\r"}  → decoded: 0x0D
    var s = decodeJsonToString("{\"k\":\"\\r\"}")
    assert(s.length == 1)
    assert(s.buffer[0] == '\r')
}

@test
func testFromJsonStringTab() {
    // JSON: {"k":"\t"}  → decoded: 0x09
    var s = decodeJsonToString("{\"k\":\"\\t\"}")
    assert(s.length == 1)
    assert(s.buffer[0] == '\t')
}

@test
func testFromJsonStringBackslash() {
    // JSON: {"k":"\\"}  → decoded: single backslash
    var s = decodeJsonToString("{\"k\":\"\\\\\"}")
    assert(s.length == 1)
    assert(s.buffer[0] == '\\')
}

@test
func testFromJsonStringNullByte() {
    // \0 is a non-standard extension; the parser decodes it, but computing the
    // clone length via strlen (as String.fromJson's copyStrings path does)
    // stops at the first null byte, so the reported .length comes back as 0.
    // Regression check: a strlen-zero source must still clone into a non-null
    // one-byte buffer, not collapse to a null buffer (which previously
    // segfaulted on the buffer[0] read below).
    var s = decodeJsonToString("{\"k\":\"\\0\"}")
    assert(s.buffer != null)
    assert(s.buffer[0] == '\0')
}

