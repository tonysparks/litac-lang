import "std/metrics"
import "std/string/builder"
import "std/string"
import "std/assert"
import "std/libc"
import "std/mem"
import "std/thread"
import "std/atomic"

// ---------------------------------------------------------------
// Counter tests
// ---------------------------------------------------------------

@test("counter starts at zero")
func testCounterInit() {
    var c: Counter;
    c.init(defaultAllocator)
    defer c.free()
    assert(c.get() == 0)
}

@test("counter inc increments by one")
func testCounterInc() {
    var c: Counter;
    c.init(defaultAllocator)
    defer c.free()
    c.inc()
    c.inc()
    c.inc()
    assert(c.get() == 3)
}

@test("counter add increments by n")
func testCounterAdd() {
    var c: Counter;
    c.init(defaultAllocator)
    defer c.free()
    c.add(10)
    c.add(5)
    assert(c.get() == 15)
}

@test("counter inc with attrs creates separate series")
func testCounterIncWithAttrs() {
    var c: Counter;
    c.init(defaultAllocator)
    defer c.free()
    c.inc(MetricAttr { .name = "method", .value = "GET" })
    c.inc(MetricAttr { .name = "method", .value = "GET" })
    c.inc(MetricAttr { .name = "method", .value = "POST" })
    // get() sums all series
    assert(c.get() == 3)
}

// ---------------------------------------------------------------
// Gauge tests
// ---------------------------------------------------------------

@test("gauge starts at zero")
func testGaugeInit() {
    var g: Gauge;
    g.init(defaultAllocator)
    defer g.free()
    assert(g.get() == 0)
}

@test("gauge set replaces the value")
func testGaugeSet() {
    var g: Gauge;
    g.init(defaultAllocator)
    defer g.free()
    g.set(42)
    assert(g.get() == 42)
    g.set(7)
    assert(g.get() == 7)
}

@test("gauge add and sub")
func testGaugeAddSub() {
    var g: Gauge;
    g.init(defaultAllocator)
    defer g.free()
    g.add(10)
    g.add(5)
    assert(g.get() == 15)
    g.sub(3)
    assert(g.get() == 12)
}

@test("gauge can go negative")
func testGaugeNegative() {
    var g: Gauge;
    g.init(defaultAllocator)
    defer g.free()
    g.sub(5)
    assert(g.get() == -5)
}

// ---------------------------------------------------------------
// Histogram tests
// ---------------------------------------------------------------

@test("histogram starts empty")
func testHistogramInit() {
    var bounds = [3]f64 { 1.0, 5.0, 10.0 }
    var h: Histogram;
    h.init(bounds, 3, defaultAllocator)
    defer h.free()
    assert(h.totalCount() == 0)
}

@test("histogram observe routes to correct bucket")
func testHistogramObserveBuckets() {
    var bounds = [3]f64 { 1.0, 5.0, 10.0 }
    var h: Histogram;
    h.init(bounds, 3, defaultAllocator)
    defer h.free()

    h.observe(0.5)   // bucket 0: <= 1.0
    h.observe(3.0)   // bucket 1: <= 5.0
    h.observe(7.0)   // bucket 2: <= 10.0
    h.observe(99.0)  // bucket 3: +Inf

    assert(h.bucketCount(0) == 1)
    assert(h.bucketCount(1) == 1)
    assert(h.bucketCount(2) == 1)
    assert(h.bucketCount(3) == 1)
    assert(h.totalCount() == 4)
}

@test("histogram observe accumulates sum")
func testHistogramSum() {
    var bounds = [2]f64 { 5.0, 10.0 }
    var h: Histogram;
    h.init(bounds, 2, defaultAllocator)
    defer h.free()

    h.observe(1.0)
    h.observe(2.0)
    h.observe(3.0)

    assert(h.totalCount() == 3)
}

@test("histogram exact bucket boundary lands in that bucket")
func testHistogramBoundaryValue() {
    var bounds = [2]f64 { 5.0, 10.0 }
    var h: Histogram;
    h.init(bounds, 2, defaultAllocator)
    defer h.free()

    h.observe(5.0)  // exactly on boundary — should land in bucket 0 (val <= 5.0)
    assert(h.bucketCount(0) == 1)
    assert(h.bucketCount(1) == 0)
    assert(h.bucketCount(2) == 0)
}

@test("histogram value above all bounds goes to +Inf bucket")
func testHistogramInfBucket() {
    var bounds = [2]f64 { 1.0, 2.0 }
    var h: Histogram;
    h.init(bounds, 2, defaultAllocator)
    defer h.free()

    h.observe(100.0)
    assert(h.bucketCount(0) == 0)
    assert(h.bucketCount(1) == 0)
    assert(h.bucketCount(2) == 1)  // +Inf
    assert(h.totalCount() == 1)
}

// ---------------------------------------------------------------
// Registry tests
// ---------------------------------------------------------------

@test("registry counter get-or-create")
func testRegistryCounter() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var c1 = reg.counter("my_counter", "a test counter")
    assert(c1 != null)
    c1.inc()
    c1.inc()

    // same name returns same counter
    var c2 = reg.counter("my_counter")
    assert(c2 == c1)
    assert(c2.get() == 2)
}

@test("registry gauge get-or-create")
func testRegistryGauge() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var g = reg.gauge("connections", "active connections")
    assert(g != null)
    g.set(5)

    var g2 = reg.gauge("connections")
    assert(g2 == g)
    assert(g2.get() == 5)
}

@test("registry histogram get-or-create")
func testRegistryHistogram() {
    var bounds = [3]f64 { 1.0, 5.0, 10.0 }
    var reg: Registry;
    reg.init()
    defer reg.free()

    var h = reg.histogram("latency", bounds, 3, "request latency")
    assert(h != null)
    h.observe(2.0)

    var h2 = reg.histogram("latency", bounds, 3)
    assert(h2 == h)
    assert(h2.totalCount() == 1)
}

@test("registry distinct names are independent")
func testRegistryDistinctMetrics() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var a = reg.counter("alpha")
    var b = reg.counter("beta")
    assert(a != b)
    a.add(3)
    b.add(7)
    assert(a.get() == 3)
    assert(b.get() == 7)
}

// ---------------------------------------------------------------
// Prometheus scrape output tests
// ---------------------------------------------------------------

@test("scrape counter emits correct lines")
func testScrapeCounter() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var c = reg.counter("hits_total", "total hits")
    c.add(42)

    var sb = StringBuilderInit(256)
    defer sb.free()
    reg.scrapePrometheus(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"# HELP hits_total total hits"))
    assert(out.contains($"# TYPE hits_total counter"))
    assert(out.contains($"hits_total 42"))
}

@test("scrape gauge emits correct lines")
func testScrapeGauge() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var g = reg.gauge("queue_depth", "items in queue")
    g.set(7)

    var sb = StringBuilderInit(256)
    defer sb.free()
    reg.scrapePrometheus(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"# TYPE queue_depth gauge"))
    assert(out.contains($"queue_depth 7"))
}

@test("scrape histogram emits bucket, sum, count lines")
func testScrapeHistogram() {
    var bounds = [2]f64 { 5.0, 10.0 }
    var reg: Registry;
    reg.init()
    defer reg.free()

    var h = reg.histogram("dur_ms", bounds, 2, "duration ms")
    h.observe(3.0)   // bucket 0
    h.observe(7.0)   // bucket 1
    h.observe(50.0)  // +Inf

    var sb = StringBuilderInit(512)
    defer sb.free()
    reg.scrapePrometheus(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"# TYPE dur_ms histogram"))
    // cumulative counts: bucket0=1, bucket1=2, +Inf=3
    assert(out.contains($"dur_ms_bucket{le=\"5\"} 1"))
    assert(out.contains($"dur_ms_bucket{le=\"10\"} 2"))
    assert(out.contains($"dur_ms_bucket{le=\"+Inf\"} 3"))
    assert(out.contains($"dur_ms_count 3"))
}

// ---------------------------------------------------------------
// Prometheus scrape with per-update attributes
// ---------------------------------------------------------------

@test("scrape counter with attrs emits labels")
func testScrapeCounterWithAttrs() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var c = reg.counter("hits_total", "total hits")
    c.inc(MetricAttr { .name = "method", .value = "GET" })
    c.inc(MetricAttr { .name = "method", .value = "GET" })
    c.inc(MetricAttr { .name = "method", .value = "POST" })

    var sb = StringBuilderInit(256)
    defer sb.free()
    reg.scrapePrometheus(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"hits_total{method=\"GET\"} 2"))
    assert(out.contains($"hits_total{method=\"POST\"} 1"))
}

@test("scrape histogram with attrs emits labels on buckets, sum and count")
func testScrapeHistogramWithAttrs() {
    var bounds = [2]f64 { 5.0, 10.0 }
    var reg: Registry;
    reg.init()
    defer reg.free()

    var h = reg.histogram("dur_ms", bounds, 2, "duration ms")
    h.observe(3.0,  MetricAttr { .name = "region", .value = "us-east" })
    h.observe(7.0,  MetricAttr { .name = "region", .value = "us-east" })
    h.observe(50.0, MetricAttr { .name = "region", .value = "us-east" })

    var sb = StringBuilderInit(512)
    defer sb.free()
    reg.scrapePrometheus(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"dur_ms_bucket{le=\"5\",region=\"us-east\"} 1"))
    assert(out.contains($"dur_ms_bucket{le=\"10\",region=\"us-east\"} 2"))
    assert(out.contains($"dur_ms_bucket{le=\"+Inf\",region=\"us-east\"} 3"))
    assert(out.contains($"dur_ms_count{region=\"us-east\"} 3"))
}

// ---------------------------------------------------------------
// JSON scrape output tests
