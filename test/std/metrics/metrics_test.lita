@test("scrapeJSON counter emits correct fields")
func testScrapeJSONCounter() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var c = reg.counter("hits_total", "total hits")
    c.add(42)

    var sb = StringBuilderInit(256)
    defer sb.free()
    reg.scrapeJSON(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"\"name\":\"hits_total\""))
    assert(out.contains($"\"help\":\"total hits\""))
    assert(out.contains($"\"type\":\"counter\""))
    assert(out.contains($"\"value\":42"))
}

@test("scrapeJSON gauge emits correct fields")
func testScrapeJSONGauge() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var g = reg.gauge("queue_depth", "items in queue")
    g.set(7)

    var sb = StringBuilderInit(256)
    defer sb.free()
    reg.scrapeJSON(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"\"name\":\"queue_depth\""))
    assert(out.contains($"\"type\":\"gauge\""))
    assert(out.contains($"\"value\":7"))
}

@test("scrapeJSON histogram emits buckets, sum and count")
func testScrapeJSONHistogram() {
    var bounds = [2]f64 { 5.0, 10.0 }
    var reg: Registry;
    reg.init()
    defer reg.free()

    var h = reg.histogram("dur_ms", bounds, 2, "duration ms")
    h.observe(3.0)
    h.observe(7.0)
    h.observe(50.0)

    var sb = StringBuilderInit(512)
    defer sb.free()
    reg.scrapeJSON(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"\"name\":\"dur_ms\""))
    assert(out.contains($"\"type\":\"histogram\""))
    assert(out.contains($"\"count\":3"))
    assert(out.contains($"\"le\":5"))
    assert(out.contains($"\"le\":\"+Inf\""))
}

@test("scrapeJSON counter with attrs emits attributes object")
func testScrapeJSONCounterWithAttrs() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var c = reg.counter("hits_total", "total hits")
    c.inc(MetricAttr { .name = "service", .value = "web" })

    var sb = StringBuilderInit(256)
    defer sb.free()
    reg.scrapeJSON(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"\"attributes\":{\"service\":\"web\"}"))
}

@test("scrapeJSON escapes special chars in name and help")
func testScrapeJSONEscaping() {
    var reg: Registry;
    reg.init()
    defer reg.free()

    var c = reg.counter("esc_test", "says \"hello\"")
    c.inc()

    var sb = StringBuilderInit(256)
    defer sb.free()
    reg.scrapeJSON(&sb)

    var out = StringInit(sb.cStr(), sb.size())
    assert(out.contains($"\"help\":\"says \\\"hello\\\"\""))
}

// ---------------------------------------------------------------
// Thread-safety: concurrent counter increments
// ---------------------------------------------------------------

struct CounterStressState {
    counter: Counter
    iters:   i32
}

func counterStressWorker(arg: *void) : i32 {
    var state = arg as (*CounterStressState)
    for (var i = 0; i < state.iters; i += 1) {
        state.counter.inc()
    }
    return 0
}

@test("counter is safe under concurrent increments")
func testCounterConcurrent() {
    const NUM_THREADS = 4
    const ITERS_PER_THREAD = 10_000

    var state: CounterStressState;
    state.counter.init(defaultAllocator)
    defer state.counter.free()
    state.iters = ITERS_PER_THREAD

    var threads: [NUM_THREADS]Thread;
    for (var i = 0; i < NUM_THREADS; i += 1) {
        assert(threads[i].create(counterStressWorker, &state) == ThreadStatus.SUCCESS)
    }
    for (var i = 0; i < NUM_THREADS; i += 1) {
        threads[i].join(null)
    }

    assert(state.counter.get() == NUM_THREADS * ITERS_PER_THREAD)
}

// ---------------------------------------------------------------
// Thread-safety: concurrent histogram observations
// ---------------------------------------------------------------

struct HistogramStressState {
    histogram: Histogram
    iters:     i32
}

func histogramStressWorker(arg: *void) : i32 {
    var state = arg as (*HistogramStressState)
    for (var i = 0; i < state.iters; i += 1) {
        state.histogram.observe(1.0)
    }
    return 0
}

@test("histogram is safe under concurrent observations")
func testHistogramConcurrent() {
    const NUM_THREADS = 4
    const ITERS_PER_THREAD = 10_000

    var bounds = [3]f64 { 1.0, 5.0, 10.0 }
    var state: HistogramStressState;
    state.histogram.init(bounds, 3, defaultAllocator)
    defer state.histogram.free()
    state.iters = ITERS_PER_THREAD

    var threads: [NUM_THREADS]Thread;
    for (var i = 0; i < NUM_THREADS; i += 1) {
        assert(threads[i].create(histogramStressWorker, &state) == ThreadStatus.SUCCESS)
    }
    for (var i = 0; i < NUM_THREADS; i += 1) {
        threads[i].join(null)
    }

    var total = NUM_THREADS * ITERS_PER_THREAD
    assert(state.histogram.totalCount() == total)
    // all observations == 1.0, so bucket 0 (le=1.0) holds all of them
    assert(state.histogram.bucketCount(0) == total)
}
