func testSqliteOrmInsertOneAndQueryOneById() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openSqliteDb(&conn)
    doOrmInsertOneAndQueryOneById(db, &allocator.allocator)
}

