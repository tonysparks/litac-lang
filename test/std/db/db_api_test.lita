// Tests for the generic SqlConnection / SqlStatement / SqlResultSet / ORM APIs.
// SQLite is used as the backing driver, but every operation goes through the
// generic trait interfaces — no SqliteConnection-specific calls after setup.

import "std/libc"
import "std/mem"
import "std/mem/bucket_allocator"
import "std/string"
import "std/string/builder"
import "std/array"
import "std/time"
import "std/assert"

import "std/db"
import "std/db/sqlite"
import "std/db/sqlite/sqlite_db"
import "std/db/orm"

// -----------------------------------------------------------------------
// @table entity used by the ORM tests
// -----------------------------------------------------------------------

@table(
    .name = "item"
)
public struct Item {
    @id(.autogenerated = true)
    @column
    id: i64

    @column
    name: String

    @column
    quantity: i32

    @column
    price: f64

    @column
    created_at: DateTime

    // Not persisted — excluded from all generated SQL
    @db_ignore
    cached: i32
}

// -----------------------------------------------------------------------
// Setup helpers
// -----------------------------------------------------------------------

// Opens an in-memory SQLite database.  Returns the generic SqlConnection.
// The caller owns `conn` and must call conn.close() when done.
func openDb(conn: *SqliteConnection) : SqlConnection {
    var r = Connect(":memory:", conn, .enableWAL = false)
    assert(r.isOk())
    return conn.connection
}

func createItemTable(db: SqlConnection) {
    db.execute(
        """
        CREATE TABLE IF NOT EXISTS item (
            id         INTEGER PRIMARY KEY AUTOINCREMENT,
            name       TEXT    NOT NULL,
            quantity   INTEGER NOT NULL DEFAULT 0,
            price      REAL    NOT NULL DEFAULT 0.0,
            created_at TEXT
        );
        """
    )
    assert(!db.hasError())
}

func seedItems(db: SqlConnection) {
    db.execute(
        """
        INSERT INTO item (name, quantity, price, created_at) VALUES
            ('apple',  10, 0.99,  '2025-01-01T00:00:00'),
            ('banana', 5,  0.49,  '2025-01-02T00:00:00'),
            ('cherry', 20, 2.99,  '2025-01-03T00:00:00');
        """
    )
    assert(!db.hasError())
}

// -----------------------------------------------------------------------
// SqlConnection — execute / error state
// -----------------------------------------------------------------------

@test
func testConnectionExecute() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    // DDL via generic execute
    var r = db.execute("CREATE TABLE exec_test (id INTEGER);")
    assert(r.isOk())
    assert(!db.hasError())

    // DML
    r = db.execute("INSERT INTO exec_test VALUES (1);")
    assert(r.isOk())
    assert(!db.hasError())
}

@test
func testConnectionErrorState() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    // Fresh connection — no error
    assert(!db.hasError())
    assert(db.lastResult().isOk())

    // Set a custom error via the generic API
    db.setError(SqlResult{
        .type        = SqlResultType.ERROR,
        .description = $"test error"
    })
    assert(db.hasError())
    assert(db.lastResult().isError())
    assert(db.lastError().equals($"test error"))

    // clearError restores clean state
    db.clearError()
    assert(!db.hasError())
    assert(db.lastResult().isOk())

    // Invalid SQL sets error
    db.execute("NOT VALID SQL;")
    assert(db.hasError())
    assert(db.lastError().length > 0)

    // Operations are short-circuited while in error state
    var r2 = db.execute("SELECT 1;")
    assert(r2.isError())

    // clearError allows further work
    db.clearError()
    assert(!db.hasError())
}

@test
func testConnectionGetAllocator() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    var alloc = db.getAllocator()
    assert(alloc != null)
}

// -----------------------------------------------------------------------
// SqlConnection — transactions (begin / commit / rollback)
// -----------------------------------------------------------------------

@test
func testConnectionTransactionCommit() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE txn_commit (v INTEGER);")
    assert(!db.hasError())

    var r = db.begin()
    assert(r.isOk())

    db.execute("INSERT INTO txn_commit VALUES (42);")
    assert(!db.hasError())

    r = db.commit()
    assert(r.isOk())

    // Verify row persisted after commit
    var rs: SqlResultSet
    db.query(&rs, $"SELECT v FROM txn_commit")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 42)
}

@test
func testConnectionTransactionRollback() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE txn_rollback (v INTEGER);")
    assert(!db.hasError())

    var r = db.begin()
    assert(r.isOk())

    db.execute("INSERT INTO txn_rollback VALUES (99);")
    assert(!db.hasError())

    r = db.rollback()
    assert(r.isOk())

    // Row must not exist after rollback
    var rs: SqlResultSet
    db.query(&rs, $"SELECT COUNT(*) FROM txn_rollback")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt64(0) == 0_i64)
}

// -----------------------------------------------------------------------
// SqlConnection — generic query with vararg bindings
// -----------------------------------------------------------------------

@test
func testConnectionQueryVarargs() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute(
        """
        CREATE TABLE scores (name TEXT, score INTEGER, rating REAL);
        INSERT INTO scores VALUES ('Alice', 95, 4.8);
        INSERT INTO scores VALUES ('Bob',   80, 3.5);
        """
    )
    assert(!db.hasError())

    // i32 + f64 varargs
    var rs: SqlResultSet
    db.query(&rs, $"SELECT name FROM scores WHERE score > ? AND rating > ?",
        85_i32, 4.0_f64)
    assert(rs.hasNext())
    rs.next()
    assert(strcmp(rs.columnText(0), "Alice") == 0)
    assert(!rs.hasNext())

    // String vararg
    db.query(&rs, $"SELECT score FROM scores WHERE name = ?", $"Bob")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 80)

    // *const char vararg
    db.query(&rs, $"SELECT score FROM scores WHERE name = ?", "Alice")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 95)
}

// -----------------------------------------------------------------------
// SqlConnection — prepare and SqlStatement lifecycle
// -----------------------------------------------------------------------

@test
func testStatementPrepareAndStep() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE pstep (x INTEGER);")
    assert(!db.hasError())

    // prepare → bindInt32 → step
    var stmt: SqlStatement
    db.prepare(&stmt, $"INSERT INTO pstep VALUES (?)")
    assert(!db.hasError())

    stmt.bindInt32(1, 7_i32)
    var r = stmt.step()
    assert(r.isOk())
    stmt.close()

    // Verify via query
    var rs: SqlResultSet
    db.query(&rs, $"SELECT x FROM pstep")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 7)
}

@test
func testStatementBindAllTypes() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute(
        """
        CREATE TABLE bind_all (
            i32_col  INTEGER,
            i64_col  INTEGER,
            f64_col  REAL,
            txt_col  TEXT,
            str_col  TEXT,
            null_col INTEGER,
            dt_col   TEXT
        );
        """
    )
    assert(!db.hasError())

    var now = DateTimeNow()

    var stmt: SqlStatement
    db.prepare(&stmt, $"INSERT INTO bind_all VALUES (?, ?, ?, ?, ?, ?, ?)")
    assert(!db.hasError())

    stmt.bindInt32(1, 42_i32)
    stmt.bindInt64(2, 1234567890_i64)
    stmt.bindFloat64(3, 3.14)
    stmt.bindText(4, "hello", 5)
    stmt.bindString(5, $"world")
    stmt.bindNull(6)
    stmt.bindDateTime(7, now)

    var r = stmt.step()
    assert(r.isOk())
    stmt.close()

    // Read back and verify via generic result set
    var rs: SqlResultSet
    db.query(&rs, $"SELECT i32_col, i64_col, f64_col, txt_col, str_col, null_col, dt_col FROM bind_all")
    assert(rs.hasNext())
    rs.next()

    assert(rs.columnCount() == 7)
    assert(rs.columnInt32(0) == 42)
    assert(rs.columnInt64(1) == 1234567890_i64)

    var d = rs.columnDouble(2)
    assert(d > 3.13 && d < 3.15)

    assert(strcmp(rs.columnText(3), "hello") == 0)
    assert(rs.columnString(4).equals($"world"))

    assert(rs.columnType(5) == SqlColumnType.NULL)
    assert(rs.columnInt32(5) == 0)

    var dt = rs.columnDateTime(6)
    assert(dt.year >= 2025)
}

@test
func testStatementParameterIntrospection() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE param_test (state TEXT, city TEXT);")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt,
        $"SELECT * FROM param_test WHERE state = :STATE AND city = :CITY")
    assert(!db.hasError())

    // parameterCount
    assert(stmt.parameterCount() == 2)

    // parameterName (1-based)
    assert(strcmp(stmt.parameterName(1), ":STATE") == 0)
    assert(strcmp(stmt.parameterName(2), ":CITY") == 0)

    // parameterIndex
    assert(stmt.parameterIndex(":STATE") == 1)
    assert(stmt.parameterIndex(":CITY") == 2)

    stmt.close()
    assert(!db.hasError())
}

@test
func testStatementResetAndClearBindings() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE reset_test (v INTEGER);")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt, $"INSERT INTO reset_test VALUES (?)")
    assert(!db.hasError())

    // First insert
    stmt.bindInt32(1, 1)
    stmt.step()
    stmt.reset()
    assert(!db.hasError())

    // clearBindings + re-bind for second insert
    stmt.clearBindings()
    stmt.bindInt32(1, 2)
    stmt.step()
    stmt.close()
    assert(!db.hasError())

    // Verify both rows
    var rs: SqlResultSet
    db.query(&rs, $"SELECT COUNT(*) FROM reset_test")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt64(0) == 2_i64)
}

@test
func testStatementFinalize() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE fin_test (v INTEGER);")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt, $"SELECT 1")
    assert(!db.hasError())

    var r = stmt.finalize()
    assert(r.isOk())
    assert(!db.hasError())
}

// -----------------------------------------------------------------------
// SqlResultSet — column accessors and metadata
// -----------------------------------------------------------------------

@test
func testResultSetColumnTypes() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute(
        """
        CREATE TABLE col_types (
            int_col  INTEGER,
            big_col  INTEGER,
            real_col REAL,
            text_col TEXT,
            null_col INTEGER
        );
        INSERT INTO col_types VALUES (1, 9000000000, 2.718, 'hi', NULL);
        """
    )
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT int_col, big_col, real_col, text_col, null_col FROM col_types")
    assert(rs.hasNext())
    rs.next()

    assert(rs.columnCount() == 5)

    assert(rs.columnType(0) == SqlColumnType.INT)
    assert(rs.columnInt32(0) == 1)

    assert(rs.columnType(1) == SqlColumnType.INT)
    assert(rs.columnInt64(1) == 9000000000_i64)

    assert(rs.columnType(2) == SqlColumnType.DOUBLE)
    var d = rs.columnDouble(2)
    assert(d > 2.71 && d < 2.72)

    assert(rs.columnType(3) == SqlColumnType.TEXT)
    assert(strcmp(rs.columnText(3), "hi") == 0)

    assert(rs.columnType(4) == SqlColumnType.NULL)
    assert(rs.columnInt32(4) == 0)
}

@test
func testResultSetHasNextAndMultipleRows() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute(
        """
        CREATE TABLE multi_rows (v INTEGER);
        INSERT INTO multi_rows VALUES (10);
        INSERT INTO multi_rows VALUES (20);
        INSERT INTO multi_rows VALUES (30);
        """
    )
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT v FROM multi_rows ORDER BY v")
    assert(rs.hasNext())

    rs.next()
    assert(rs.columnInt32(0) == 10)
    assert(rs.hasNext())

    rs.next()
    assert(rs.columnInt32(0) == 20)
    assert(rs.hasNext())

    rs.next()
    assert(rs.columnInt32(0) == 30)
    assert(!rs.hasNext())
}

@test
func testResultSetStatementAccessor() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE stmt_acc (v INTEGER); INSERT INTO stmt_acc VALUES (1);")
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT v FROM stmt_acc")
    assert(rs.hasNext())
    rs.next()

    // statement() on a live result set must not crash and its connection must be valid
    var stmt = rs.statement()
    assert(!stmt.connection().hasError())
}

@test
func testResultSetCloseAndReleaseAll() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)

    db.execute("CREATE TABLE cra_test (v INTEGER); INSERT INTO cra_test VALUES (5);")
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT v FROM cra_test")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 5)

    var r = rs.closeAndReleaseAll()
    assert(r.isOk())
    assert(!db.hasError())
}

// -----------------------------------------------------------------------
// ORM — insertOne / queryOneById
// -----------------------------------------------------------------------

@test
func testOrmInsertOneAndQueryOneById() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)

    var item = Item {
        .name     = $"widget",
        .quantity = 3,
        .price    = 9.99,
        .cached   = 42,   // @db_ignore — must not be persisted
    }
    var inserted = db.insertOne(&item)
    assert(inserted == 1)
    assert(!db.hasError())

    // Find the inserted id
    var found = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(
        &allocator.allocator,
        &found,
        .alias = $"i",
        .sql   = $"where i.name = ?",
        $"widget"
    )
    assert(found.size() == 1)
    var id = found.get(0).id

    // queryOneById through the generic ORM
    var result = Item{}
    var count = db.queryOneById(&result, id)
    assert(count == 1)
    assert(result.name.equals($"widget"))
    assert(result.quantity == 3)

    var d = result.price
    assert(d > 9.98 && d < 10.0)

    // @db_ignore field must stay at zero value after a read
    assert(result.cached == 0)
}

// -----------------------------------------------------------------------
// ORM — insertMany / queryMany
// -----------------------------------------------------------------------

@test
func testOrmInsertManyAndQueryMany() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)

    var items = ArrayInit<Item>(4, &allocator.allocator)
    items.add(Item{ .name = $"fork",   .quantity = 10, .price = 1.50 })
    items.add(Item{ .name = $"spoon",  .quantity = 8,  .price = 1.25 })
    items.add(Item{ .name = $"knife",  .quantity = 6,  .price = 1.75 })

    var inserted = db.insertMany(&items)
    assert(inserted == 3)
    assert(!db.hasError())

    // queryMany with a filter
    var cheap = ArrayInit<Item>(4, &allocator.allocator)
    var count = db.queryMany(
        &allocator.allocator,
        &cheap,
        .alias = $"i",
        .sql   = $"where i.price < ? order by i.name",
        1.50_f64
    )
    assert(count == 1)
    assert(cheap.get(0).name.equals($"spoon"))

    // queryMany with no filter — all rows
    var all = ArrayInit<Item>(8, &allocator.allocator)
    count = db.queryMany(
        &allocator.allocator,
        &all,
        .alias = $"i",
        .sql   = $"order by i.name"
    )
    assert(count == 3)
    assert(all.get(0).name.equals($"fork"))
    assert(all.get(1).name.equals($"knife"))
    assert(all.get(2).name.equals($"spoon"))
}

// -----------------------------------------------------------------------
// ORM — updateOne / updateMany
// -----------------------------------------------------------------------

@test
func testOrmUpdateOne() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)
    seedItems(db)

    // Fetch apple
    var items = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(
        &allocator.allocator,
        &items,
        .alias = $"i",
        .sql   = $"where i.name = ?",
        $"apple"
    )
    assert(items.size() == 1)
    var apple = items.getPtr(0)

    apple.quantity = 99
    var updated = db.updateOne(apple)
    assert(updated == 1)
    assert(!db.hasError())

    var check = Item{}
    assert(db.queryOneById(&check, apple.id) == 1)
    assert(check.quantity == 99)
    assert(check.name.equals($"apple"))
}

@test
func testOrmUpdateMany() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)
    seedItems(db)

    var items = ArrayInit<Item>(8, &allocator.allocator)
    db.queryMany(
        &allocator.allocator,
        &items,
        .alias = $"i",
        .sql   = $"order by i.id"
    )
    assert(items.size() == 3)

    // Mark all items out of stock
    for(var j = 0; j < items.size(); j += 1) {
        items.getPtr(j).quantity = 0
    }

    var updated = db.updateMany(&items)
    assert(updated == 3)
    assert(!db.hasError())

    var check = ArrayInit<Item>(8, &allocator.allocator)
    db.queryMany(&allocator.allocator, &check, .alias = $"i",
        .sql = $"where i.quantity = 0")
    assert(check.size() == 3)
}

// -----------------------------------------------------------------------
// ORM — deleteById / deleteOne / deleteMany
// -----------------------------------------------------------------------

@test
func testOrmDeleteById() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)
    seedItems(db)

    // Find apple's id
    var items = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(&allocator.allocator, &items, .alias = $"i",
        .sql = $"where i.name = ?", $"apple")
    assert(items.size() == 1)
    var appleId = items.get(0).id

    var deleted = db.deleteById<Item, i64>(appleId)
    assert(deleted == 1)
    assert(!db.hasError())

    var check = Item{}
    assert(db.queryOneById(&check, appleId) == 0)

    // Two remain
    var remaining = ArrayInit<Item>(8, &allocator.allocator)
    db.queryMany(&allocator.allocator, &remaining, .alias = $"i", .sql = $"order by i.id")
    assert(remaining.size() == 2)
}

@test
func testOrmDeleteOne() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)
    seedItems(db)

    var items = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(&allocator.allocator, &items, .alias = $"i",
        .sql = $"where i.name = ?", $"banana")
    assert(items.size() == 1)
    var banana = items.getPtr(0)
    var bananaId = banana.id

    var deleted = db.deleteOne(banana)
    assert(deleted == 1)
    assert(!db.hasError())

    var check = Item{}
    assert(db.queryOneById(&check, bananaId) == 0)
}

@test
func testOrmDeleteMany() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)
    seedItems(db)

    // Delete all items with quantity >= 10
    var toDelete = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(&allocator.allocator, &toDelete, .alias = $"i",
        .sql = $"where i.quantity >= ? order by i.id", 10_i32)
    assert(toDelete.size() == 2)  // apple(10), cherry(20)

    var deleted = db.deleteMany(&toDelete)
    assert(deleted == 2)
    assert(!db.hasError())

    // Only banana remains
    var remaining = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(&allocator.allocator, &remaining, .alias = $"i", .sql = $"order by i.id")
    assert(remaining.size() == 1)
    assert(remaining.get(0).name.equals($"banana"))
}

// -----------------------------------------------------------------------
// ORM — queryMany / queryOneById with no matching rows
// -----------------------------------------------------------------------

@test
func testOrmQueryNoResults() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)

    // queryOneById on empty table
    var result = Item{}
    assert(db.queryOneById(&result, 999_i64) == 0)
    assert(!db.hasError())

    // queryMany with a filter that matches nothing
    var items = ArrayInit<Item>(4, &allocator.allocator)
    var count = db.queryMany(
        &allocator.allocator,
        &items,
        .alias = $"i",
        .sql   = $"where i.name = ?",
        $"nonexistent"
    )
    assert(count == 0)
    assert(items.size() == 0)
    assert(!db.hasError())
}

// -----------------------------------------------------------------------
// ORM — @db_ignore field is absent from all generated SQL
// -----------------------------------------------------------------------

@test
func testOrmDbIgnoreFieldExcluded() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)

    // `cached` is @db_ignore — insertOne must not try to bind it
    var item = Item { .name = $"gadget", .quantity = 1, .price = 5.00, .cached = 77 }
    var inserted = db.insertOne(&item)
    assert(inserted == 1)
    assert(!db.hasError())

    // queryMany must not try to read a column for `cached`
    var items = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(&allocator.allocator, &items, .alias = $"i",
        .sql = $"where i.name = ?", $"gadget")
    assert(items.size() == 1)
    assert(items.get(0).name.equals($"gadget"))
    // `cached` was never written so it stays at the zero value
    assert(items.get(0).cached == 0)
}

// -----------------------------------------------------------------------
// ORM — DateTime round-trip via INSERT / SELECT
// -----------------------------------------------------------------------

@test
func testOrmDateTimeRoundTrip() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    var db = openDb(&conn)
    createItemTable(db)

    var ts = DateTime{
        .date = Date{ .year = 2025, .month = 6_u8, .day = 15_u8 },
        .time = Time{ .hour = 12_u8, .min = 0_u8, .sec = 0_u8 },
    }

    var item = Item { .name = $"timed", .quantity = 1, .price = 1.0, .created_at = ts }
    db.insertOne(&item)
    assert(!db.hasError())

    var items = ArrayInit<Item>(4, &allocator.allocator)
    db.queryMany(&allocator.allocator, &items, .alias = $"i",
        .sql = $"where i.name = ?", $"timed")
    assert(items.size() == 1)

    var read = items.get(0)
    assert(read.created_at.year  == 2025)
    assert(read.created_at.month == 6)
    assert(read.created_at.day   == 15)
}
