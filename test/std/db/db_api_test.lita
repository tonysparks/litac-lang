// ── SQLite-only: named parameter introspection ────────────────────────────────

@test
func testSqliteParameterIntrospection() {
    var conn = SqliteConnection{}
    defer conn.close()
    var db = openSqliteDb(&conn)

    db.execute("CREATE TABLE param_test (state TEXT, city TEXT);")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt, $"SELECT * FROM param_test WHERE state = :STATE AND city = :CITY")
    assert(!db.hasError())

    assert(stmt.parameterCount() == 2)
    assert(strcmp(stmt.parameterName(1), ":STATE") == 0)
    assert(strcmp(stmt.parameterName(2), ":CITY") == 0)
    assert(stmt.parameterIndex(":STATE") == 1)
    assert(stmt.parameterIndex(":CITY") == 2)

    stmt.close()
    assert(!db.hasError())
}

// ── ORM shared test bodies ────────────────────────────────────────────────────

func doOrmInsertOneAndQueryOneById(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)

    var item = Item{.name = $"widget", .quantity = 3, .price = 9.99, .cached = 42}
    assert(db.insertOne(&item) == 1)
    assert(!db.hasError())
    assert(item.id > 0)

    var found = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &found, .alias = $"i", .sql = $"where i.name = $1", $"widget")
    assert(found.size() == 1)
    assert(found.get(0).id == item.id)

    var result = Item{}
    assert(db.queryOneById(&result, item.id) == 1)
    assert(result.name.equals($"widget"))
    assert(result.quantity == 3)
    var d = result.price
    assert(d > 9.98 && d < 10.0)
    assert(result.cached == 0)
}

func doOrmInsertManyAndQueryMany(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)

    var items = ArrayInit<Item>(4, alloc)
    items.add(Item{.name = $"fork",  .quantity = 10, .price = 1.50})
    items.add(Item{.name = $"spoon", .quantity = 8,  .price = 1.25})
    items.add(Item{.name = $"knife", .quantity = 6,  .price = 1.75})

    assert(db.insertMany(&items) == 3)
    assert(!db.hasError())
    assert(items.get(0).id > 0)
    assert(items.get(1).id > 0)
    assert(items.get(2).id > 0)

    var cheap = ArrayInit<Item>(4, alloc)
    assert(db.queryMany(alloc, &cheap, .alias = $"i",
        .sql = $"where i.price < $1 order by i.name", 1.50_f64) == 1)
    assert(cheap.get(0).name.equals($"spoon"))

    var all = ArrayInit<Item>(8, alloc)
    assert(db.queryMany(alloc, &all, .alias = $"i", .sql = $"order by i.name") == 3)
    assert(all.get(0).name.equals($"fork"))
    assert(all.get(1).name.equals($"knife"))
    assert(all.get(2).name.equals($"spoon"))
}

func doOrmUpdateOne(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)
    seedItems(db)

    var items = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &items, .alias = $"i", .sql = $"where i.name = $1", $"apple")
    assert(items.size() == 1)
    var apple = items.getPtr(0)
    apple.quantity = 99

    assert(db.updateOne(apple) == 1)
    assert(!db.hasError())

    var check = Item{}
    assert(db.queryOneById(&check, apple.id) == 1)
    assert(check.quantity == 99)
}

func doOrmUpdateMany(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)
    seedItems(db)

    var items = ArrayInit<Item>(8, alloc)
    db.queryMany(alloc, &items, .alias = $"i", .sql = $"order by i.id")
    assert(items.size() == 3)

    for(var j = 0; j < items.size(); j += 1) {
        items.getPtr(j).quantity = 0
    }
    assert(db.updateMany(&items) == 3)
    assert(!db.hasError())

    var check = ArrayInit<Item>(8, alloc)
    db.queryMany(alloc, &check, .alias = $"i", .sql = $"where i.quantity = 0")
    assert(check.size() == 3)
}

func doOrmDeleteById(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)
    seedItems(db)

    var items = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &items, .alias = $"i", .sql = $"where i.name = $1", $"apple")
    assert(items.size() == 1)
    var appleId = items.get(0).id

    assert(db.deleteById<Item, i64>(appleId) == 1)
    assert(!db.hasError())

    var check = Item{}
    assert(db.queryOneById(&check, appleId) == 0)

    var remaining = ArrayInit<Item>(8, alloc)
    db.queryMany(alloc, &remaining, .alias = $"i", .sql = $"order by i.id")
    assert(remaining.size() == 2)
}

func doOrmDeleteOne(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)
    seedItems(db)

    var items = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &items, .alias = $"i", .sql = $"where i.name = $1", $"banana")
    assert(items.size() == 1)
    var banana = items.getPtr(0)
    var bananaId = banana.id

    assert(db.deleteOne(banana) == 1)
    assert(!db.hasError())

    var check = Item{}
    assert(db.queryOneById(&check, bananaId) == 0)
}

func doOrmDeleteMany(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)
    seedItems(db)

    var toDelete = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &toDelete, .alias = $"i",
        .sql = $"where i.quantity >= $1 order by i.id", 10_i32)
    assert(toDelete.size() == 2)

    assert(db.deleteMany(&toDelete) == 2)
    assert(!db.hasError())

    var remaining = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &remaining, .alias = $"i", .sql = $"order by i.id")
    assert(remaining.size() == 1)
    assert(remaining.get(0).name.equals($"banana"))
}

func doOrmQueryNoResults(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)

    var result = Item{}
    assert(db.queryOneById(&result, 999_i64) == 0)
    assert(!db.hasError())

    var items = ArrayInit<Item>(4, alloc)
    assert(db.queryMany(alloc, &items, .alias = $"i",
        .sql = $"where i.name = $1", $"nonexistent") == 0)
    assert(items.size() == 0)
    assert(!db.hasError())
}

func doOrmDbIgnoreFieldExcluded(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)

    var item = Item{.name = $"gadget", .quantity = 1, .price = 5.00, .cached = 77}
    assert(db.insertOne(&item) == 1)
    assert(!db.hasError())

    var items = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &items, .alias = $"i", .sql = $"where i.name = $1", $"gadget")
    assert(items.size() == 1)
    assert(items.get(0).name.equals($"gadget"))
    assert(items.get(0).cached == 0)
}

func doOrmDateTimeRoundTrip(db: SqlConnection, alloc: *const Allocator) {
    createItemTable(db)

    var ts = DateTime{
        .date = Date{.year = 2025, .month = 6_u8, .day = 15_u8},
        .time = Time{.hour = 12_u8, .min = 0_u8, .sec = 0_u8},
    }

    var item = Item{.name = $"timed", .quantity = 1, .price = 1.0, .created_at = ts}
    db.insertOne(&item)
    assert(!db.hasError())

    var items = ArrayInit<Item>(4, alloc)
    db.queryMany(alloc, &items, .alias = $"i", .sql = $"where i.name = $1", $"timed")
    assert(items.size() == 1)

    var read = items.get(0)
    assert(read.created_at.year  == 2025)
    assert(read.created_at.month == 6)
    assert(read.created_at.day   == 15)
}

