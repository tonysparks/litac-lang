// Tests for the generic SqlConnection / SqlStatement / SqlResultSet / ORM APIs.
// Shared test bodies run against both SQLite and PostgreSQL backends.
// All parameterised SQL uses $1/$2/... — both SQLite and PostgreSQL accept
// positional $N syntax when binding by index.

import "std/libc"
import "std/mem"
import "std/mem/bucket_allocator"
import "std/string"
import "std/string/builder"
import "std/array"
import "std/time"
import "std/assert"
import "std/thread"

import "std/db"
import "std/db/sqlite"
import "std/db/sqlite/sqlite_db"
import "std/db/orm"
import "std/db/postgres/postgres_db" as pgdb
import "std/testcontainers"
import "std/testcontainers/presets"

// ── Shared PostgreSQL container (one per test run) ────────────────────────────

var _pgContainer: Container
var _pgPort: i32 = 0
var _pgSchemaSeq: i32 = 0

@module_init
public func pgModuleInit() {
    var cfg = PostgresContainer(.password = $"secret", .db = $"testdb")
    defer cfg.free()
    assert(_pgContainer.start(&cfg) == ContainerStatus.OK)
    _pgPort = _pgContainer.getPort(5432)

    // The postgres image restarts once during init; retry until the second
    // server start is fully ready.
    var dsn = StringBuilderInit(128)
    defer dsn.free()
    dsn.append("host=127.0.0.1 port=%d dbname=testdb user=postgres password=secret sslmode=disable", _pgPort)

    var probe: pgdb::PgConnection
    var result: SqlResult
    for(var i = 0; i < 30; i += 1) {
        result = pgdb::ConnectDSN(dsn.cStrConst(), &probe)
        if(result.isOk()) { break; }
        probe.close()
        ThreadSleepMSec(1000_i64)
    }
    assert(result.isOk())
    probe.close()
}

@module_destroy
public func pgModuleDestroy() {
    _pgContainer.stop()
}

// ── ORM entity ────────────────────────────────────────────────────────────────

@table(.name = "item")
public struct Item {
    @id(.autogenerated = true)
    @column
    id: i64

    @column
    name: String

    @column
    quantity: i32

    @column
    price: f64

    @column
    created_at: DateTime

    @db_ignore
    cached: i32
}

// ── Connection helpers ────────────────────────────────────────────────────────

func openSqliteDb(conn: *SqliteConnection) : SqlConnection {
    var r = Connect(":memory:", conn, .enableWAL = false)
    assert(r.isOk())
    return conn.connection
}

// Opens a fresh connection to the shared container in its own schema so table
// names don't collide between tests that all share the same database.
func pgConnect(conn: *pgdb::PgConnection) {
    var dsn = StringBuilderInit(128)
    defer dsn.free()
    dsn.append("host=127.0.0.1 port=%d dbname=testdb user=postgres password=secret sslmode=disable", _pgPort)
    var result = pgdb::ConnectDSN(dsn.cStrConst(), conn)
    assert(result.isOk())

    _pgSchemaSeq += 1
    var sql = StringBuilderInit(64)
    defer sql.free()
    sql.append("CREATE SCHEMA s%d", _pgSchemaSeq)
    conn.execute(sql.cStrConst())
    assert(!conn.hasError())
    sql.clear()
    sql.append("SET search_path TO s%d", _pgSchemaSeq)
    conn.execute(sql.cStrConst())
    assert(!conn.hasError())
}

// ── ORM helpers ───────────────────────────────────────────────────────────────

func createItemTable(db: SqlConnection) {
    var item = Item{}
    var sb = StringBuilderInit(512)
    defer sb.free()
    item.getSqlCreateTable(&db, &sb)
    db.execute(sb.cStrConst())
    assert(!db.hasError())
}

func seedItems(db: SqlConnection) {
    db.execute(
        """
        INSERT INTO item (name, quantity, price, created_at) VALUES
            ('apple',  10, 0.99,  '2025-01-01T00:00:00'),
            ('banana', 5,  0.49,  '2025-01-02T00:00:00'),
            ('cherry', 20, 2.99,  '2025-01-03T00:00:00');
        """
    )
    assert(!db.hasError())
}

// ── Shared test bodies ────────────────────────────────────────────────────────

func doConnectionExecute(db: SqlConnection) {
    var r = db.execute("CREATE TABLE exec_test (id INTEGER)")
    assert(r.isOk())
    assert(!db.hasError())

    r = db.execute("INSERT INTO exec_test VALUES (1)")
    assert(r.isOk())
    assert(!db.hasError())
}

func doConnectionErrorState(db: SqlConnection) {
    assert(!db.hasError())
    assert(db.lastResult().isOk())

    db.setError(SqlResult{.type = SqlResultType.ERROR, .description = $"test error"})
    assert(db.hasError())
    assert(db.lastResult().isError())
    assert(db.lastError().equals($"test error"))

    db.clearError()
    assert(!db.hasError())
    assert(db.lastResult().isOk())

    db.execute("NOT VALID SQL")
    assert(db.hasError())
    assert(db.lastError().length > 0)

    var r2 = db.execute("SELECT 1")
    assert(r2.isError())

    db.clearError()
    assert(!db.hasError())
}

func doConnectionGetAllocator(db: SqlConnection) {
    assert(db.getAllocator() != null)
}

func doTransactionCommit(db: SqlConnection) {
    db.execute("CREATE TABLE txn_commit (v INTEGER)")
    assert(!db.hasError())

    assert(db.begin().isOk())
    db.execute("INSERT INTO txn_commit VALUES (42)")
    assert(!db.hasError())
    assert(db.commit().isOk())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT v FROM txn_commit")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 42)
}

func doTransactionRollback(db: SqlConnection) {
    db.execute("CREATE TABLE txn_rollback (v INTEGER)")
    assert(!db.hasError())

    assert(db.begin().isOk())
    db.execute("INSERT INTO txn_rollback VALUES (99)")
    assert(!db.hasError())
    assert(db.rollback().isOk())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT COUNT(*) FROM txn_rollback")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt64(0) == 0_i64)
}

// Uses $1/$2 placeholders — valid in both SQLite ($N named) and PostgreSQL.
func doQueryVarargs(db: SqlConnection) {
    db.execute(
        """
        CREATE TABLE scores (name TEXT, score INTEGER, rating REAL);
        INSERT INTO scores VALUES ('Alice', 95, 4.8);
        INSERT INTO scores VALUES ('Bob',   80, 3.5);
        """
    )
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT name FROM scores WHERE score > $1 AND rating > $2",
        85_i32, 4.0_f64)
    assert(rs.hasNext())
    rs.next()
    assert(strcmp(rs.columnText(0), "Alice") == 0)
    assert(!rs.hasNext())

    db.query(&rs, $"SELECT score FROM scores WHERE name = $1", $"Bob")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 80)

    db.query(&rs, $"SELECT score FROM scores WHERE name = $1", "Alice")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 95)
}

func doPrepareAndStep(db: SqlConnection) {
    db.execute("CREATE TABLE pstep (x INTEGER)")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt, $"INSERT INTO pstep VALUES ($1)")
    assert(!db.hasError())

    stmt.bindInt32(1, 7)
    var r = stmt.step()
    assert(r.isOk())
    stmt.close()

    var rs: SqlResultSet
    db.query(&rs, $"SELECT x FROM pstep")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 7)
}

func doBindAllTypes(db: SqlConnection) {
    db.execute(
        """
        CREATE TABLE bind_all (
            i32_col  INTEGER,
            i64_col  BIGINT,
            f64_col  DOUBLE PRECISION,
            txt_col  TEXT,
            str_col  TEXT,
            null_col INTEGER,
            dt_col   TEXT
        )
        """
    )
    assert(!db.hasError())

    var now = DateTimeNow()

    var stmt: SqlStatement
    db.prepare(&stmt, $"INSERT INTO bind_all VALUES ($1, $2, $3, $4, $5, $6, $7)")
    assert(!db.hasError())

    stmt.bindInt32(1, 42)
    stmt.bindInt64(2, 1234567890_i64)
    stmt.bindFloat64(3, 3.14)
    stmt.bindText(4, "hello", 5)
    stmt.bindString(5, $"world")
    stmt.bindNull(6)
    stmt.bindDateTime(7, now)
    assert(stmt.step().isOk())
    stmt.close()

    var rs: SqlResultSet
    db.query(&rs, $"SELECT i32_col, i64_col, f64_col, txt_col, str_col, null_col, dt_col FROM bind_all")
    assert(rs.hasNext())
    rs.next()

    assert(rs.columnCount() == 7)
    assert(rs.columnInt32(0) == 42)
    assert(rs.columnInt64(1) == 1234567890_i64)

    var d = rs.columnDouble(2)
    assert(d > 3.13 && d < 3.15)

    assert(strcmp(rs.columnText(3), "hello") == 0)
    assert(rs.columnString(4).equals($"world"))

    // NULL column: columnType differs (SQLite: NULL, PostgreSQL: INT per column OID).
    // Verify via accessor return values which are consistent across backends.
    assert(rs.columnText(5) == null)
    assert(rs.columnInt32(5) == 0)

    var dt = rs.columnDateTime(6)
    assert(dt.year >= 2025)
}

func doResetAndClearBindings(db: SqlConnection) {
    db.execute("CREATE TABLE reset_test (v INTEGER)")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt, $"INSERT INTO reset_test VALUES ($1)")
    assert(!db.hasError())

    stmt.bindInt32(1, 1)
    stmt.step()
    stmt.reset()
    assert(!db.hasError())

    stmt.clearBindings()
    stmt.bindInt32(1, 2)
    stmt.step()
    stmt.close()
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT COUNT(*) FROM reset_test")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt64(0) == 2_i64)
}

func doFinalize(db: SqlConnection) {
    db.execute("CREATE TABLE fin_test (v INTEGER)")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt, $"SELECT 1")
    assert(!db.hasError())

    assert(stmt.finalize().isOk())
    assert(!db.hasError())
}

// Tests INT/DOUBLE/TEXT column types (identical on all backends).
// BIGINT columnType and NULL columnType are backend-specific and tested separately.
func doResultSetColumnTypes(db: SqlConnection) {
    db.execute("CREATE TABLE col_types (int_col INTEGER, big_col BIGINT, real_col DOUBLE PRECISION, text_col TEXT, null_col INTEGER)")
    assert(!db.hasError())
    db.execute("INSERT INTO col_types VALUES (1, 9000000000, 2.718, 'hi', NULL)")
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT int_col, big_col, real_col, text_col, null_col FROM col_types")
    assert(rs.hasNext())
    rs.next()

    assert(rs.columnCount() == 5)

    assert(rs.columnType(0) == SqlColumnType.INT)
    assert(rs.columnInt32(0) == 1)

    // BIGINT value is readable on all backends; columnType differs so not asserted here.
    assert(rs.columnInt64(1) == 9000000000_i64)

    assert(rs.columnType(2) == SqlColumnType.DOUBLE)
    var d = rs.columnDouble(2)
    assert(d > 2.71 && d < 2.72)

    assert(rs.columnType(3) == SqlColumnType.TEXT)
    assert(strcmp(rs.columnText(3), "hi") == 0)

    // NULL value readable; columnType differs (SQLite: NULL, PostgreSQL: INT).
    assert(rs.columnText(4) == null)
    assert(rs.columnInt32(4) == 0)
}

func doMultipleRows(db: SqlConnection) {
    db.execute(
        """
        CREATE TABLE multi_rows (v INTEGER);
        INSERT INTO multi_rows VALUES (10);
        INSERT INTO multi_rows VALUES (20);
        INSERT INTO multi_rows VALUES (30);
        """
    )
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT v FROM multi_rows ORDER BY v")
    assert(rs.hasNext())

    rs.next()
    assert(rs.columnInt32(0) == 10)
    assert(rs.hasNext())

    rs.next()
    assert(rs.columnInt32(0) == 20)
    assert(rs.hasNext())

    rs.next()
    assert(rs.columnInt32(0) == 30)
    assert(!rs.hasNext())
}

func doStatementAccessor(db: SqlConnection) {
    db.execute("CREATE TABLE stmt_acc (v INTEGER)")
    assert(!db.hasError())
    db.execute("INSERT INTO stmt_acc VALUES (1)")
    assert(!db.hasError())

    var rs: SqlResultSet
    db.query(&rs, $"SELECT v FROM stmt_acc")
    assert(rs.hasNext())
    rs.next()

    var stmt = rs.statement()
    assert(!stmt.connection().hasError())
}

func doCloseAndReleaseAll(db: SqlConnection) {
    db.execute("CREATE TABLE cra_test (v INTEGER)")
    assert(!db.hasError())
    db.execute("INSERT INTO cra_test VALUES (5)")
    assert(!db.hasError())

    var stmt: SqlStatement
    db.prepare(&stmt, $"SELECT v FROM cra_test")

    var rs: SqlResultSet
    stmt.execute(&rs)
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 5)

    assert(rs.closeAndReleaseAll().isOk())
    assert(!db.hasError())
}

