import "std/libc"
import "std/mem"
import "std/mem/bucket_allocator"
import "std/string"
import "std/string/builder"
import "std/array"
import "std/time"
import "std/assert"

import "std/db"
import "std/db/sqlite"
import "std/db/sqlite/sqlite_db"
import "std/db/orm"

// A table entity with nullable TEXT and DateTime columns.
// The schema intentionally omits NOT NULL so we can insert actual SQL NULLs.
@table(
    .name = "nullable_record"
)
public struct NullableRecord {
    @id(.autogenerated = true)
    @column
    id: i64

    @column
    label: String

    @column
    note: String

    @column
    ts: DateTime
}

// A table entity where one field is annotated @db_ignore — it must be excluded
// from all generated SQL and bind/read operations.
@table(
    .name = "partial_record"
)
public struct PartialRecord {
    @id(.autogenerated = true)
    @column
    id: i64

    @column
    name: String

    // This field exists only in the LitaC struct; it has no DB column.
    @db_ignore
    computed: i32
}

// -----------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------

func createNullableTable(conn: *SqliteConnection) {
    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS nullable_record (
            id    INTEGER PRIMARY KEY AUTOINCREMENT,
            label TEXT,
            note  TEXT,
            ts    TEXT
        );
        """
    )
    assert(!conn.hasError())
}

// -----------------------------------------------------------------------
// NULL TEXT columns — fromResultSet must not crash; field stays empty String
// (exercises the pre_serialization.ape fix: null-check *const char from
//  columnText before passing to sb.append)
// -----------------------------------------------------------------------

@test
func testOrmNullTextColumn() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createNullableTable(&conn)

    // Insert via raw SQL so both TEXT columns are genuine SQL NULLs
    conn.execute("INSERT INTO nullable_record (label, note, ts) VALUES (NULL, NULL, NULL);")
    assert(!conn.hasError())

    var records = ArrayInit<NullableRecord>(4, &allocator.allocator)
    var count = conn.connection.queryMany(
        &allocator.allocator,
        &records,
        .alias = $"r",
        .sql   = $"order by r.id"
    )

    assert(count == 1)
    assert(!conn.hasError())

    var rec = records.get(0)
    assert(rec.id > 0_i64)
    // NULL TEXT columns must produce a zero-length String, not a crash
    assert(rec.label.length == 0)
    assert(rec.note.length == 0)
}

// -----------------------------------------------------------------------
// NULL DateTime column via raw resultSet — columnDateTime must return
// DateTime{} without crash.
// (exercises the sqlite_db.lita fix: null-check *const char before .toString())
// -----------------------------------------------------------------------

@test
func testColumnDateTimeNull() {
    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, .enableWAL = false)

    conn.execute("CREATE TABLE dt_null_test (ts TEXT);")
    assert(!conn.hasError())

    conn.execute("INSERT INTO dt_null_test (ts) VALUES (NULL);")
    assert(!conn.hasError())

    var rs: SqlResultSet
    conn.connection.query(&rs, $"SELECT ts FROM dt_null_test")
    assert(rs.hasNext())
    rs.next()

    assert(rs.columnType(0) == SqlColumnType.NULL)

    // Must not crash; NULL datetime must come back as zero DateTime
    var dt = rs.columnDateTime(0)
    assert(dt.year == 0)
    assert(dt.month == 0)
    assert(dt.day == 0)
}

// -----------------------------------------------------------------------
// NULL DateTime column via ORM fromResultSet — must not crash
// (exercises both fixes together: APE-generated fromResultSet calls
//  columnDateTime, which in turn must handle the null *const char)
// -----------------------------------------------------------------------

@test
func testOrmNullDateTimeColumn() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createNullableTable(&conn)

    // NULL ts, non-NULL label/note so we can verify those still work
    conn.execute("INSERT INTO nullable_record (label, note, ts) VALUES ('hello', 'world', NULL);")
    assert(!conn.hasError())

    var records = ArrayInit<NullableRecord>(4, &allocator.allocator)
    var count = conn.connection.queryMany(
        &allocator.allocator,
        &records,
        .alias = $"r",
        .sql   = $"order by r.id"
    )

    assert(count == 1)
    assert(!conn.hasError())

    var rec = records.get(0)
    assert(rec.label.equals($"hello"))
    assert(rec.note.equals($"world"))
    // NULL DateTime must come back as zero DateTime, not a crash
    assert(rec.ts.year == 0)
    assert(rec.ts.month == 0)
    assert(rec.ts.day == 0)
}

// -----------------------------------------------------------------------
// Non-NULL TEXT and DateTime round-trip — regression guard to ensure the
// NULL fixes did not break the normal (non-NULL) path
// -----------------------------------------------------------------------

@test
func testOrmNonNullTextAndDateTimeRoundTrip() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createNullableTable(&conn)

    conn.execute("INSERT INTO nullable_record (label, note, ts) VALUES ('foo', 'bar', '2025-06-15T12:00:00');")
    assert(!conn.hasError())

    var records = ArrayInit<NullableRecord>(4, &allocator.allocator)
    var count = conn.connection.queryMany(
        &allocator.allocator,
        &records,
        .alias = $"r",
        .sql   = $"order by r.id"
    )

    assert(count == 1)
    assert(!conn.hasError())

    var rec = records.get(0)
    assert(rec.label.equals($"foo"))
    assert(rec.note.equals($"bar"))
    assert(rec.ts.year == 2025)
    assert(rec.ts.month == 6)
    assert(rec.ts.day == 15)
}

// -----------------------------------------------------------------------
// NULL integer columns — document that SQLite silently returns 0 for NULL
// INTEGER/INT64 (no crash, but caller should be aware the value is 0)
// -----------------------------------------------------------------------

@test
func testNullIntegerColumnReturnsZero() {
    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, .enableWAL = false)

    conn.execute(
        """
        CREATE TABLE int_null_test (
            int32_col  INTEGER,
            int64_col  INTEGER,
            double_col REAL
        );
        """
    )
    assert(!conn.hasError())

    conn.execute("INSERT INTO int_null_test VALUES (NULL, NULL, NULL);")
    assert(!conn.hasError())

    var rs: SqlResultSet
    conn.connection.query(&rs, $"SELECT int32_col, int64_col, double_col FROM int_null_test")
    assert(rs.hasNext())
    rs.next()

    assert(rs.columnType(0) == SqlColumnType.NULL)
    assert(rs.columnType(1) == SqlColumnType.NULL)
    assert(rs.columnType(2) == SqlColumnType.NULL)

    // SQLite returns 0 for NULL numeric columns — no crash
    assert(rs.columnInt32(0) == 0)
    assert(rs.columnInt64(1) == 0_i64)
    // double: just verify it doesn't crash
    var d = rs.columnDouble(2)
    assert(d == 0.0)
}

// -----------------------------------------------------------------------
// @db_ignore — field must be absent from all generated SQL and bind/read ops
// -----------------------------------------------------------------------

@test
func testDbIgnoreFieldExcludedFromOrm() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    // Table has only the two mapped columns — no column for `computed`
    conn.execute(
        """
        CREATE TABLE partial_record (
            id   INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL
        );
        """
    )
    assert(!conn.hasError())

    // Insert via ORM — bindValues must not try to bind `computed`
    var item = PartialRecord { .name = $"alice", .computed = 99 }
    var inserted = conn.connection.insertOne(&item)
    assert(inserted == 1)
    assert(!conn.hasError())

    // Query via ORM — fromResultSet must not try to read a column for `computed`
    var records = ArrayInit<PartialRecord>(4, &allocator.allocator)
    var count = conn.connection.queryMany(
        &allocator.allocator,
        &records,
        .alias = $"p",
        .sql   = $"order by p.id"
    )
    assert(count == 1)
    assert(!conn.hasError())

    var rec = records.get(0)
    assert(rec.id > 0_i64)
    assert(rec.name.equals($"alice"))
    // `computed` was never persisted — it stays at its zero value
    assert(rec.computed == 0)
}
