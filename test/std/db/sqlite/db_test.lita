// -----------------------------------------------------------------------
// query() with multiple parameter types via varargs
// -----------------------------------------------------------------------

@test
func testQueryVarargs() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    conn.execute(
        """
        CREATE TABLE scores (
            name TEXT,
            score INTEGER,
            rating REAL
        );
        INSERT INTO scores VALUES ('Alice', 95, 4.8);
        INSERT INTO scores VALUES ('Bob',   80, 3.5);
        INSERT INTO scores VALUES ('Carol', 72, 3.0);
        """
    )
    assert(!conn.hasError())

    // i32 and f64 varargs
    var rs: SqlResultSet
    conn.connection.query(
        &rs,
        $"SELECT name FROM scores WHERE score > ? AND rating > ?",
        85_i32, 4.0_f64
    )
    assert(rs.hasNext())
    rs.next()
    assert(strcmp(rs.columnText(0), "Alice") == 0)
    assert(!rs.hasNext())

    // String vararg
    conn.connection.query(
        &rs,
        $"SELECT score FROM scores WHERE name = ?",
        $"Bob"
    )
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 80)

    // *const char vararg
    conn.connection.query(
        &rs,
        $"SELECT score FROM scores WHERE name = ?",
        "Carol"
    )
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == 72)
}

// -----------------------------------------------------------------------
// ORM: updateOne
// -----------------------------------------------------------------------

@test
func testOrmUpdateOne() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    insertNFLTeams(&conn)

    // Fetch Packers
    var teams = ArrayInit<Team>(4, &allocator.allocator)
    conn.connection.queryMany(
        &allocator.allocator,
        &teams,
        .alias = $"t",
        .sql   = $"where t.state = ?",
        $"WI"
    )
    assert(teams.size() == 1)
    var packers = teams.getPtr(0)

    // Mutate and update
    packers.city = $"Titletown"
    var updated = conn.connection.updateOne(packers)
    assert(updated == 1)
    assert(!conn.hasError())

    // Read back and verify
    var check = Team{}
    assert(conn.connection.queryOneById(&check, packers.id) == 1)
    assert(check.city.equals($"Titletown"))
    assert(check.name.equals($"Green Bay Packers"))
    assert(check.state.equals($"WI"))
}

// -----------------------------------------------------------------------
// ORM: updateMany
// -----------------------------------------------------------------------

@test
func testOrmUpdateMany() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    insertNFLTeams(&conn)

    // Fetch all teams
    var teams = ArrayInit<Team>(8, &allocator.allocator)
    conn.connection.queryMany(
        &allocator.allocator,
        &teams,
        .alias = $"t",
        .sql   = $"order by t.id"
    )
    assert(teams.size() == 4)

    // Relocate every team to Texas
    for(var i = 0; i < teams.size(); i += 1) {
        teams.getPtr(i).state = $"TX"
    }

    var updated = conn.connection.updateMany(&teams)
    assert(updated == 4)
    assert(!conn.hasError())

    // All four should now be in TX
    var txTeams = ArrayInit<Team>(8, &allocator.allocator)
    conn.connection.queryMany(
        &allocator.allocator,
        &txTeams,
        .alias = $"t",
        .sql   = $"where t.state = ?",
        $"TX"
    )
    assert(txTeams.size() == 4)
}

// -----------------------------------------------------------------------
// ORM: deleteOne (entity-based)
// -----------------------------------------------------------------------

@test
func testOrmDeleteOne() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    insertNFLTeams(&conn)

    // Fetch Bears
    var teams = ArrayInit<Team>(4, &allocator.allocator)
    conn.connection.queryMany(
        &allocator.allocator,
        &teams,
        .alias = $"t",
        .sql   = $"where t.state = ?",
        $"IL"
    )
    assert(teams.size() == 1)
    var bears = teams.getPtr(0)
    var bearsId = bears.id

    var deleted = conn.connection.deleteOne(bears)
    assert(deleted == 1)
    assert(!conn.hasError())

    // Verify gone
    var check = Team{}
    assert(conn.connection.queryOneById(&check, bearsId) == 0)

    // Three remaining
    var remaining = ArrayInit<Team>(8, &allocator.allocator)
    conn.connection.queryMany(
        &allocator.allocator,
        &remaining,
        .alias = $"t",
        .sql   = $"order by t.id"
    )
    assert(remaining.size() == 3)
}

// -----------------------------------------------------------------------
// ORM: deleteMany (batch entity-based delete)
// -----------------------------------------------------------------------

@test
func testOrmDeleteMany() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    insertNFLTeams(&conn)

    // Select two teams to delete
    var toDelete = ArrayInit<Team>(4, &allocator.allocator)
    conn.connection.queryMany(
        &allocator.allocator,
        &toDelete,
        .alias = $"t",
        .sql   = $"where t.state in (?, ?) order by t.id",
        $"WI", $"IL"
    )
    assert(toDelete.size() == 2)

    var deleted = conn.connection.deleteMany(&toDelete)
    assert(deleted == 2)
    assert(!conn.hasError())

    // Two should remain
    var remaining = ArrayInit<Team>(8, &allocator.allocator)
    conn.connection.queryMany(
        &allocator.allocator,
        &remaining,
        .alias = $"t",
        .sql   = $"order by t.id"
    )
    assert(remaining.size() == 2)

    // The survivors should be MN and MI
    assert(remaining.get(0).state.equals($"MN"))
    assert(remaining.get(1).state.equals($"MI"))
}

// -----------------------------------------------------------------------
// ORM: queryOneById / queryMany with no matching rows
// -----------------------------------------------------------------------

@test
func testOrmQueryNoResults() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    // No rows inserted

    // queryOneById on empty table
    var result = Team{}
    var found = conn.connection.queryOneById(&result, 1_i64)
    assert(found == 0)

    // queryMany with a filter that matches nothing
    var teams = ArrayInit<Team>(4, &allocator.allocator)
    var count = conn.connection.queryMany(
        &allocator.allocator,
        &teams,
        .alias = $"t",
        .sql   = $"where t.state = ?",
        $"ZZ"
    )
    assert(count == 0)
    assert(teams.size() == 0)
    assert(!conn.hasError())
}

// -----------------------------------------------------------------------
// enableWAL / disableWAL
// -----------------------------------------------------------------------

@test
func testEnableDisableWAL() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    // enableWAL on :memory: succeeds (SQLite silently keeps "memory" mode)
    var r1 = conn.enableWAL()
    assert(!r1.isError())

    // disableWAL should also succeed
    var r2 = conn.disableWAL()
    assert(!r2.isError())

    // Connection still usable
    conn.execute("SELECT 1;")
    assert(!conn.hasError())
}

// -----------------------------------------------------------------------
// statement result-set statement() accessor
// -----------------------------------------------------------------------

@test
func testResultSetStatementAccessor() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    insertNFLTeams(&conn)

    var rs: SqlResultSet
    conn.connection.query(&rs, $"SELECT id, name FROM team ORDER BY id")
    assert(!conn.hasError())
    assert(rs.hasNext())
    rs.next()

    // statement() on the result set returns the owning statement
    var stmt = rs.statement()
    // The statement's connection should be error-free
    assert(!stmt.connection().hasError())
}

// -----------------------------------------------------------------------
// Verify connection is idempotently closeable (double-close safety)
// -----------------------------------------------------------------------

@test
func testConnectionClose() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)
    var r = conn.close()
    assert(r.isOk())
}
