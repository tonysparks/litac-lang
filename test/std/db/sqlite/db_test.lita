
import "std/libc"
import "std/mem"
import "std/mem/bucket_allocator"
import "std/string"
import "std/string/builder"
import "std/string/buffer"
import "std/array"
import "std/time"

import "std/db"
import "std/db/sqlite"
import "std/db/sqlite/sqlite_db"
import "std/db/orm"

@table(
    .name = "team"
)
public struct Team {
    @id(.autogenerated = true)
    @column
    id: i64

    @column
    name: String

    @column
    city: String

    @column
    state: String
}

import "std/assert"

// -----------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------

func createTeamTable(conn: *SqliteConnection) {
    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS team (
            id   INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            city TEXT NOT NULL,
            state TEXT NOT NULL
        );
        """
    )
    assert(!conn.hasError())
}

func insertNFLTeams(conn: *SqliteConnection) {
    conn.execute(
        """
        INSERT INTO team (name, city, state) VALUES
            ('Green Bay Packers', 'Green Bay', 'WI'),
            ('Chicago Bears',     'Chicago',   'IL'),
            ('Minnesota Vikings', 'Minneapolis','MN'),
            ('Detroit Lions',     'Detroit',   'MI');
        """
    )
    assert(!conn.hasError())
}

// -----------------------------------------------------------------------
// testDatabase – original integration smoke test
// -----------------------------------------------------------------------

@test
func testDatabase() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{};
    defer conn.close()

    Connect(
        ":memory:",
        &conn,
        SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE,
        true,
        &allocator.allocator
    )

    conn.execute(
        """
        CREATE TABLE IF NOT EXISTS team (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            city TEXT NOT NULL,
            state TEXT NOT NULL
        );
        """
    )

    conn.begin()
    conn.execute(
        """
        INSERT INTO
            team (name, city, state)
        VALUES
            ('Green Bay Packers', 'Green Bay', 'WI'),
            ('Chicago Bears', 'Chicago', 'IL'),
            ('Minnesota Vikings', 'Minneapolis', 'MN'),
            ('Detroit Lions', 'Detroit', 'MI');
        """
    )

    if(conn.commit().isError()) {
        var error = conn.lastError()
        printf("Database error: '%.*s', rolling back\n", error.length, error.buffer)
        conn.rollback()
        assert(false)
    }

    assert(conn.lastResult().isOk())

    var resultSet: SqlResultSet
    // TODO: Fix
    //defer resultSet.closeAndReleaseAll()
    conn.connection.query(
        &resultSet,
        $"""
        select count(*)
        from team t
        where t.state = ?
        """,
        $"WI"
    )
    assert(resultSet.hasNext())
    resultSet.next()
    assert(resultSet.columnInt32(0))

    // Query By ORM for one
    {
        var packers = Team{}
        var result = conn.connection.queryOneById(&packers, 1)
        assert(result == 1)
        assert(packers.name.equals($"Green Bay Packers"))
        assert(packers.city.equals($"Green Bay"))
        assert(packers.state.equals($"WI"))
    }

    // Query via ORM for Many
    {
        var teams = ArrayInit<Team>(16, &allocator.allocator)
        var result = conn.connection.queryMany(
            &allocator.allocator,
            &teams,
            .alias = $"t",
            .sql = $"""
                where
                    t.state = ? or t.state = ?
                order by t.id
                """,
            $"WI",
            $"IL"
        )

        assert(result == 2)
        assert(teams.size() == 2)
        var packers = teams.getPtr(0)
        assert(packers.state.equals($"WI"))
        var bears = teams.getPtr(1)
        assert(bears.state.equals($"IL"))
    }

    // Insert via ORM many
    {
        var buc = Team {
            .name = $"Buccaneers",
            .city = $"Tampa Bay",
            .state = $"FL",
        }

        var falcons = Team {
            .name = $"Falcons",
            .city = $"Atlanta",
            .state = $"GA",
        }

        var newTeams = ArrayInit<Team>(2, &allocator.allocator)
        newTeams.add(buc)
        newTeams.add(falcons)

        var numOfInserts = conn.connection.insertMany(newTeams)
        assert(!conn.hasError())
        assert(numOfInserts == 2)

        var readTeams = ArrayInit<Team>(16, &allocator.allocator)
        conn.connection.queryMany(
            &allocator.allocator,
            &readTeams,
            .alias = $"t",
            .sql = $"where state in (?, ?) order by t.id",
            $"GA", $"FL"
        )
        assert(readTeams.size() == 2)
        var t1 = readTeams.get(0)
        assert(t1.state.equals($"FL"))
        var t2 = readTeams.get(1)
        assert(t2.state.equals($"GA"))

    }

    // Insert One, queryByOneId, deleteOneById
    {
        var panthers = Team {
            .name = $"Panthers",
            .city = $"Carolina",
            .state = $"SC",
        }
        // TODO: get the id generated... postgres and sqlite offer
        // different ways of doing this..
        var inserted = conn.connection.insertOne(&panthers)
        assert(inserted == 1)
        assert(conn.lastResult().isOk())

        var readTeams = ArrayInit<Team>(16, &allocator.allocator)
        conn.connection.queryMany(
            &allocator.allocator,
            &readTeams,
            .alias = $"t",
            .sql = $"where state = ?",
            $"SC"
        )
        assert(readTeams.size() == 1)
        var t1 = readTeams.getPtr(0)

        var result = Team{}
        var numRead = conn.connection.queryOneById(&result, t1.id)
        assert(numRead == 1)

        assert(result.id == t1.id)
        assert(result.name.equals(panthers.name))
        assert(result.city.equals(panthers.city))
        assert(result.state.equals(panthers.state))

        var numDeleted = conn.connection.deleteById<Team, i64>(t1.id)
        assert(numDeleted == 1)

        var result2 = Team{}
        numRead = conn.connection.queryOneById(&result2, t1.id)
        assert(numRead == 0)
    }
}

// -----------------------------------------------------------------------
// SqlResult helper methods: isOk, isError, isEmptyResults
// -----------------------------------------------------------------------

@test
func testSqlResultHelpers() {
    var ok = SqlResult{.type = SqlResultType.OK, .category = SqlResultCategory.NONE}
    assert(ok.isOk())
    assert(!ok.isError())
    assert(!ok.isEmptyResults())

    var empty = SqlResult{
        .type     = SqlResultType.OK,
        .category = SqlResultCategory.EMPTY_RESULTS
    }
    assert(empty.isOk())
    assert(!empty.isError())
    assert(empty.isEmptyResults())

    var err = SqlResult{.type = SqlResultType.ERROR}
    assert(!err.isOk())
    assert(err.isError())
    assert(!err.isEmptyResults())
}

// -----------------------------------------------------------------------
// Error handling: hasError, setError, clearError, lastError, lastResult
// -----------------------------------------------------------------------

@test
func testErrorHandling() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    // Fresh connection – no error
    assert(!conn.hasError())
    assert(conn.lastResult().isOk())

    // setError
    conn.setError(SqlResult{
        .type        = SqlResultType.ERROR,
        .description = $"custom error"
    })
    assert(conn.hasError())
    assert(conn.lastResult().isError())
    assert(conn.lastError().equals($"custom error"))

    // clearError restores clean state
    conn.clearError()
    assert(!conn.hasError())
    assert(conn.lastResult().isOk())

    // Invalid SQL triggers an error
    conn.execute("NOT VALID SQL!!!;")
    assert(conn.hasError())
    assert(conn.lastError().length > 0)

    // Operations are short-circuited while in error state
    var r = conn.execute("SELECT 1;")
    assert(r.isError())

    // clearError allows further operations
    conn.clearError()
    assert(!conn.hasError())
    conn.execute("SELECT 1;")
    assert(!conn.hasError())
}

// -----------------------------------------------------------------------
// Transaction rollback
// -----------------------------------------------------------------------

@test
func testTransactionRollback() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    insertNFLTeams(&conn)

    // Verify baseline count
    var rs: SqlResultSet
    conn.connection.query(&rs, $"SELECT count(*) FROM team")
    assert(rs.hasNext())
    rs.next()
    var baseline = rs.columnInt32(0)
    assert(baseline == 4)

    // Insert inside a transaction, then roll back
    conn.begin()
    conn.execute("INSERT INTO team (name, city, state) VALUES ('Patriots', 'Foxborough', 'MA');")
    assert(!conn.hasError())
    var rollbackResult = conn.rollback()
    assert(rollbackResult.isOk())

    // Count must still be baseline
    conn.connection.query(&rs, $"SELECT count(*) FROM team")
    assert(rs.hasNext())
    rs.next()
    assert(rs.columnInt32(0) == baseline)
}

// -----------------------------------------------------------------------
// Raw statement API: prepare, bind*, parameterCount/Name/Index,
//                    clearBindings, step, reset, finalize
// -----------------------------------------------------------------------

@test
func testRawStatementApi() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    createTeamTable(&conn)
    insertNFLTeams(&conn)

    // Prepare a statement with named parameters
    var stmt: SqlStatement
    conn.prepare(
        &stmt,
        $"SELECT id, name, city, state FROM team WHERE state = :STATE AND city = :CITY"
    )
    assert(!conn.hasError())

    // parameterCount
    assert(stmt.parameterCount() == 2)

    // parameterName (1-based)
    var n1 = stmt.parameterName(1)
    assert(strcmp(n1, ":STATE") == 0)
    var n2 = stmt.parameterName(2)
    assert(strcmp(n2, ":CITY") == 0)

    // parameterIndex
    assert(stmt.parameterIndex(":STATE") == 1)
    assert(stmt.parameterIndex(":CITY") == 2)

    // Bind by index and execute
    stmt.bindText(1, "WI", 2)
    stmt.bindText(2, "Green Bay", 9)
    var rs: SqlResultSet
    stmt.execute(&rs)
    assert(rs.hasNext())
    rs.next()

    // columnCount
    assert(rs.columnCount() == 4)

    // columnInt64 for the id column
    var id = rs.columnInt64(0)
    assert(id > 0)

    // columnText
    var nameText = rs.columnText(1)
    assert(strcmp(nameText, "Green Bay Packers") == 0)

    // columnString
    var cityStr = rs.columnString(2)
    assert(cityStr.equals($"Green Bay"))

    // columnType
    assert(rs.columnType(0) == SqlColumnType.INT)
    assert(rs.columnType(1) == SqlColumnType.TEXT)
    assert(rs.columnType(2) == SqlColumnType.TEXT)

    // reset + clearBindings + re-bind
    stmt.reset()
    assert(!conn.hasError())
    stmt.clearBindings()
    assert(!conn.hasError())

    stmt.bindString(1, $"IL")
    stmt.bindString(2, $"Chicago")
    stmt.execute(&rs)
    assert(rs.hasNext())
    rs.next()
    assert(strcmp(rs.columnText(1), "Chicago Bears") == 0)

    // finalize explicitly
    stmt.finalize()
    assert(!conn.hasError())
}

// -----------------------------------------------------------------------
// bindInt32, bindInt64, bindFloat64, bindNull, bindBlob, bindBlob64,
// bindText, bindText64, bindString
// columnInt32, columnInt64, columnDouble, columnText, columnString,
// columnBlob, columnType, columnCount
// -----------------------------------------------------------------------

@test
func testColumnTypes() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    conn.execute(
        """
        CREATE TABLE types_test (
            int_col  INTEGER,
            big_col  INTEGER,
            real_col REAL,
            text_col TEXT,
            str_col  TEXT,
            blob_col BLOB,
            null_col INTEGER
        );
        """
    )
    assert(!conn.hasError())

    // Insert a row exercising every bind variant
    var stmt: SqlStatement
    conn.prepare(
        &stmt,
        $"INSERT INTO types_test (int_col, big_col, real_col, text_col, str_col, blob_col, null_col) VALUES (?, ?, ?, ?, ?, ?, ?)"
    )
    assert(!conn.hasError())

    var blobData: *const char = "BLOBDATA"

    stmt.bindInt32(1, 42_i32)
    stmt.bindInt64(2, 9000000000_i64)
    stmt.bindFloat64(3, 2.718281828)
    stmt.bindText(4, "hello", 5)
    stmt.bindString(5, $"world")
    stmt.bindBlob(6, blobData as (*const void), 8)
    stmt.bindNull(7)

    var stepResult = stmt.step()
    assert(stepResult.isOk())
    stmt.close()
    assert(!conn.hasError())

    // Read back and verify every column type and value
    var qstmt: SqlStatement
    conn.prepare(&qstmt, $"SELECT int_col, big_col, real_col, text_col, str_col, blob_col, null_col FROM types_test")
    assert(!conn.hasError())

    var rs: SqlResultSet
    qstmt.execute(&rs)
    assert(rs.hasNext())
    rs.next()

    assert(rs.columnCount() == 7)

    // int_col
    assert(rs.columnType(0) == SqlColumnType.INT)
    assert(rs.columnInt32(0) == 42)

    // big_col
    assert(rs.columnType(1) == SqlColumnType.INT)
    assert(rs.columnInt64(1) == 9000000000_i64)

    // real_col
    assert(rs.columnType(2) == SqlColumnType.DOUBLE)
    var dbl = rs.columnDouble(2)
    assert(dbl > 2.71 && dbl < 2.72)

    // text_col (bindText)
    assert(rs.columnType(3) == SqlColumnType.TEXT)
    assert(strcmp(rs.columnText(3), "hello") == 0)

    // str_col (bindString)
    assert(rs.columnType(4) == SqlColumnType.TEXT)
    assert(rs.columnString(4).equals($"world"))

    // blob_col
    assert(rs.columnType(5) == SqlColumnType.BLOB)
    var blob = rs.columnBlob(5) as (*const char)
    assert(blob != null)
    assert(strncmp(blob, "BLOBDATA", 8) == 0)

    // null_col
    assert(rs.columnType(6) == SqlColumnType.NULL)
    assert(rs.columnInt32(6) == 0) // SQLite returns 0 for NULL integer

    qstmt.close()
    assert(!conn.hasError())
}

// -----------------------------------------------------------------------
// bindBlob64 and bindText64
// -----------------------------------------------------------------------

@test
func testBindBlob64AndText64() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    conn.execute("CREATE TABLE b64_test (name TEXT, data BLOB);")
    assert(!conn.hasError())

    var stmt: SqlStatement
    conn.prepare(&stmt, $"INSERT INTO b64_test (name, data) VALUES (?, ?)")

    // bindText64 with SQLITE_UTF8 encoding (value = 1)
    stmt.bindText64(1, "Saints", 6_u64, 1_u8)

    var blob64: *const char = "RAWBLOB"
    stmt.bindBlob64(2, blob64 as (*const void), 7_u64)

    stmt.step()
    stmt.close()
    assert(!conn.hasError())

    // Verify
    var qstmt: SqlStatement
    conn.prepare(&qstmt, $"SELECT name, data FROM b64_test")
    var rs: SqlResultSet
    qstmt.execute(&rs)
    assert(rs.hasNext())
    rs.next()

    assert(strcmp(rs.columnText(0), "Saints") == 0)
    var b = rs.columnBlob(1) as (*const char)
    assert(b != null)
    assert(strncmp(b, "RAWBLOB", 7) == 0)

    qstmt.close()
}

// -----------------------------------------------------------------------
// bindDateTime / columnDateTime
// -----------------------------------------------------------------------

@test
func testBindAndColumnDateTime() {
    var allocator = BucketAllocator{}
    allocator.init(defaultAllocator, 32)
    defer allocator.free()

    var conn = SqliteConnection{}
    defer conn.close()
    Connect(":memory:", &conn, SQLITE_OPEN_READWRITE | SQLITE_OPEN_CREATE, false, &allocator.allocator)

    conn.execute("CREATE TABLE dt_test (ts TEXT);")
    assert(!conn.hasError())

    var now = DateTimeNow()

    var stmt: SqlStatement
    conn.prepare(&stmt, $"INSERT INTO dt_test (ts) VALUES (?)")
    stmt.bindDateTime(1, now)
    stmt.step()
    stmt.close()
    assert(!conn.hasError())

    // Read back via columnDateTime
    var qstmt: SqlStatement
    conn.prepare(&qstmt, $"SELECT ts FROM dt_test")
    var rs: SqlResultSet
    qstmt.execute(&rs)
    assert(rs.hasNext())
    rs.next()

    // Stored as ISO text
    assert(rs.columnType(0) == SqlColumnType.TEXT)

    // Round-trip: parsed DateTime must be a plausible year
    var dt = rs.columnDateTime(0)
    assert(dt.year >= 2024)

    qstmt.close()
    assert(!conn.hasError())
}

