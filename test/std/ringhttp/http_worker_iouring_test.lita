import "std/libc"
import "std/mem"
import "std/assert"
import "std/array"

// ---------------------------------------------------------------------------
// Tests: RingOperation packing and stale-generation detection
// ---------------------------------------------------------------------------

#if OS == "LINUX"
import "std/ringhttp/http_worker_iouring"

// Bug fix: RingOperation packing — opcode, generation, and contextIndex must
// survive a round-trip through the u64 encoding used in io_uring user_data.
@test
func testRingOperationPacking() {
    // Basic round-trip: opcode=TIMEOUT, generation=0, contextIndex=42
    {
        var op = RingOperation { .data = makeOp(RingOpcode.TIMEOUT, 42, 0) }
        assert(op.opcode() == RingOpcode.TIMEOUT)
        assert(op.contextIndex == 42)
        assert(op.opGeneration() == 0_u32)
    }

    // opcode=ACCEPT
    {
        var op = RingOperation { .data = makeOp(RingOpcode.ACCEPT, 0, 0) }
        assert(op.opcode() == RingOpcode.ACCEPT)
    }

    // opcode=CLOSE
    {
        var op = RingOperation { .data = makeOp(RingOpcode.CLOSE, 0, 0) }
        assert(op.opcode() == RingOpcode.CLOSE)
    }

    // Non-zero generation round-trip.
    {
        var op = RingOperation { .data = makeOp(RingOpcode.READ, 7, 255) }
        assert(op.opcode() == RingOpcode.READ)
        assert(op.contextIndex == 7)
        assert(op.opGeneration() == 255_u32)
    }

    // Generation at maximum 24-bit value must not corrupt the opcode bits.
    {
        var maxGen: u32 = (1_u32 << 24) - 1_u32
        var op = RingOperation { .data = makeOp(RingOpcode.CANCEL, 100, maxGen) }
        assert(op.opcode() == RingOpcode.CANCEL)
        assert(op.contextIndex == 100)
        assert(op.opGeneration() == maxGen)
    }

    // Large socket fd in MSG_RING path — contextIndex must not be truncated.
    {
        var op = RingOperation { .data = makeOp(RingOpcode.MSG_RING, 1023, 0) }
        assert(op.opcode() == RingOpcode.MSG_RING)
        assert(op.contextIndex == 1023)
    }

    // Negative contextIndex (-1 sentinel) must survive the encoding.
    {
        var op = RingOperation { .data = makeOp(RingOpcode.READ, -1, 3) }
        assert(op.opcode() == RingOpcode.READ)
        assert(op.contextIndex == -1)
        assert(op.opGeneration() == 3_u32)
    }
}

// Bug fix: stale-CQE detection — a CQE carrying generation N must be
// discarded when the session now holds generation N+1 (slot was reused).
@test
func testStaleGenerationDetection() {
    // Simulate a session that has been reused once.
    var sessionGeneration: u32 = 2

    // CQE from the previous occupant carries generation 1 — stale.
    var staleOp = RingOperation { .data = makeOp(RingOpcode.READ, 0, 1) }
    assert(staleOp.opGeneration() != sessionGeneration)

    // CQE from the current occupant carries generation 2 — fresh.
    var freshOp = RingOperation { .data = makeOp(RingOpcode.READ, 0, 2) }
    assert(freshOp.opGeneration() == sessionGeneration)

    // Generation 0 (never-incremented slot) must also be detectable as stale
    // once the slot has been recycled.
    var gen0Op = RingOperation { .data = makeOp(RingOpcode.READ, 0, 0) }
    assert(gen0Op.opGeneration() != sessionGeneration)
}

#end