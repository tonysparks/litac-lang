@test("http2_e2e_pseudo_after_regular_header")
func testH2PseudoAfterRegularHeader() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // A regular header appears before :path — illegal ordering.
    var hpack = StringBuilderInit(32, defaultAllocator)
    defer hpack.free()
    hpackIndexed(2, &hpack)               // :method GET
    hpackIndexed(6, &hpack)               // :scheme http
    hpackWriteInt(0x00, 4, 0x00, &hpack)  // literal no-index, new name
    hpackWriteStr($"x-custom", &hpack)
    hpackWriteStr($"value", &hpack)
    hpackIndexed(4, &hpack)               // :path / — after a regular header
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    assert(expectRstProtocolError(fd, 1_u32))

    hpack.clear()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 3_u32, &hpack, true))
    var frame2: H2Frame
    assert(readNextFrame(fd, 0x01, &frame2))
    assert(decodeResponseStatus(frame2.payload, frame2.length) == 200)
}

// ---------------------------------------------------------------------------
// Connection-specific header fields (RFC 7540 §8.1.2.2)
// ---------------------------------------------------------------------------
//
// connection, keep-alive, transfer-encoding, upgrade, and te (unless value
// is "trailers") MUST NOT appear in HTTP/2 requests.  Each is a
// stream-level PROTOCOL_ERROR; the connection must survive.

// Helper: send a GET /hello with one extra regular header appended.
func sendGetWithExtraHeader(fd: i32, streamId: u32, extraName: String, extraValue: String) : bool {
    var hpack = StringBuilderInit(64, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)
    hpackWriteInt(0x00, 4, 0x00, &hpack)  // literal no-index, new name
    hpackWriteStr(extraName, &hpack)
    hpackWriteStr(extraValue, &hpack)
    return sendHeadersFrame(fd, streamId, &hpack, true)
}

