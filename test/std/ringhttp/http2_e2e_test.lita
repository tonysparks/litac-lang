// ---------------------------------------------------------------------------
// Uppercase header field names (RFC 7540 §8.1.2)
// ---------------------------------------------------------------------------
//
// "A request or response containing uppercase header field names MUST be
//  treated as malformed." → stream PROTOCOL_ERROR, connection survives.

@test("http2_e2e_uppercase_header_name")
func testH2UppercaseHeaderName() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Send GET /hello with an uppercase regular header "X-Custom: val"
    assert(sendGetWithExtraHeader(fd, 1_u32, $"X-Custom", $"val"))
    assert(expectRstProtocolError(fd, 1_u32))

    // Connection must remain usable.
    var hpack = StringBuilderInit(16, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 3_u32, &hpack, true))
    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// ---------------------------------------------------------------------------
// Unknown frame types (RFC 7540 §4.1)
// ---------------------------------------------------------------------------
//
// "Frames of unknown or unsupported types MUST be ignored and discarded."
// On stream 0 the connection must survive; on a known stream the server
// sends RST_STREAM and then handles subsequent requests normally.

@test("http2_e2e_unknown_frame_stream0_ignored")
func testH2UnknownFrameOnStream0Ignored() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Frame type 0xF0 is not defined — send it on stream 0.
    var payload: [4]char
    payload[0] = 0x01 as (char)
    payload[1] = 0x02 as (char)
    payload[2] = 0x03 as (char)
    payload[3] = 0x04 as (char)
    assert(sendRawFrame(fd, 4, 0xF0, 0x00, 0_u32, payload))

    // The server must not close the connection — a normal request succeeds.
    var hpack = StringBuilderInit(16, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))
    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

@test("http2_e2e_unknown_frame_on_stream_ignored")
func testH2UnknownFrameOnStreamIgnored() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Send unknown frame type 0xF1 on a non-zero stream — must be discarded,
    // not RST_STREAM'd (RFC 7540 §4.1 makes no exception for stream frames).
    var payload: [2]char
    payload[0] = 0xAA as (char)
    payload[1] = 0xBB as (char)
    assert(sendRawFrame(fd, 2, 0xF1, 0x00, 1_u32, payload))

    // Connection must remain fully functional.
    var hpack = StringBuilderInit(16, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 3_u32, &hpack, true))
    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// ---------------------------------------------------------------------------
// PRIORITY frame (RFC 7540 §6.3)
// ---------------------------------------------------------------------------
//
// "A PRIORITY frame can be sent on a stream in any state, even idle or
//  closed streams." The server MUST accept and ignore it (advisory only).

@test("http2_e2e_priority_frame_ignored")
func testH2PriorityFrameIgnored() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // PRIORITY frame: 5-byte payload (stream dependency + weight), stream 1.
    var prio: [5]char
    prio[0] = 0x00 as (char)  // exclusive=0, stream dep = 0 (none)
    prio[1] = 0x00 as (char)
    prio[2] = 0x00 as (char)
    prio[3] = 0x00 as (char)
    prio[4] = 0x0F as (char)  // weight = 16
    assert(sendRawFrame(fd, 5, 0x02, 0x00, 1_u32, prio))

    // Connection must remain fully functional.
    var hpack = StringBuilderInit(16, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))
    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// ---------------------------------------------------------------------------
// HEADERS / DATA with PADDED flag (RFC 7540 §6.1, §6.2)
// ---------------------------------------------------------------------------

// HEADERS with PADDED flag: payload = [padLen] + HPACK + [padLen zero bytes].
func sendPaddedHeadersFrame(fd: i32, streamId: u32, hpack: *StringBuilder, padLen: i32, endStream: bool) : bool {
    var payloadLen = 1 + hpack.length + padLen
    var payload: [512]char
    payload[0] = padLen as (char)
    for(var i = 0; i < hpack.length; i += 1) {
        payload[1 + i] = hpack.buffer[i]
    }
    for(var i = 0; i < padLen; i += 1) {
        payload[1 + hpack.length + i] = 0_i8
    }
    var flags = 0x04 | 0x08  // END_HEADERS | PADDED
    if(endStream) { flags |= 0x01 }
    var hdr: [9]char
    h2WriteFrameHdr(hdr, payloadLen, 0x01, flags, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, payloadLen)
}

// HEADERS with PRIORITY_F flag: payload = [5-byte priority block] + HPACK.
func sendPriorityHeadersFrame(fd: i32, streamId: u32, hpack: *StringBuilder, endStream: bool) : bool {
    var payloadLen = 5 + hpack.length
    var payload: [512]char
    payload[0] = 0_i8   // exclusive=0, stream dependency = 0 (high byte)
    payload[1] = 0_i8
    payload[2] = 0_i8
    payload[3] = 0_i8
    payload[4] = 0x0F_i8  // weight = 16
    for(var i = 0; i < hpack.length; i += 1) {
        payload[5 + i] = hpack.buffer[i]
    }
    var flags = 0x04 | 0x20  // END_HEADERS | PRIORITY_F
    if(endStream) { flags |= 0x01 }
    var hdr: [9]char
    h2WriteFrameHdr(hdr, payloadLen, 0x01, flags, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, payloadLen)
}

// DATA with PADDED flag: payload = [padLen] + body + [padLen zero bytes].
func sendPaddedDataFrame(fd: i32, streamId: u32, body: *const char, bodyLen: i32, padLen: i32, endStream: bool) : bool {
    var payloadLen = 1 + bodyLen + padLen
    var payload: [512]char
    payload[0] = padLen as (char)
    for(var i = 0; i < bodyLen; i += 1) {
        payload[1 + i] = body[i]
    }
    for(var i = 0; i < padLen; i += 1) {
        payload[1 + bodyLen + i] = 0_i8
    }
    var flags = 0x08  // PADDED
    if(endStream) { flags |= 0x01 }
    var hdr: [9]char
    h2WriteFrameHdr(hdr, payloadLen, 0x00, flags, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, payloadLen)
}

// ---------------------------------------------------------------------------
// HPACK incremental indexing (RFC 7541 §6.2.1)
// ---------------------------------------------------------------------------

// Literal with incremental indexing, new name.
// Adds (name, value) to the dynamic table (entries start at index 62).
func hpackIncrementalLiteralName(name: String, value: String, out: *StringBuilder) {
    hpackWriteInt(0, 6, 0x40, out)  // 0x40 prefix, index=0 means new name
    hpackWriteStr(name, out)
    hpackWriteStr(value, out)
}

// ---------------------------------------------------------------------------
// HEADERS with PADDED flag tests
// ---------------------------------------------------------------------------

// Valid HEADERS with PADDED flag — server strips padding, dispatches normally.
@test("http2_e2e_headers_padded_valid")
func testH2HeadersPaddedValid() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hpack = StringBuilderInit(32, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)

    // padLen=4: payload = [4] + HPACK + [4 zero bytes]
    assert(sendPaddedHeadersFrame(fd, 1_u32, &hpack, 4, true))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// HEADERS with PADDED flag where padLen claims more bytes than the frame holds.
// Server must send GOAWAY PROTOCOL_ERROR (connection-level error).
@test("http2_e2e_headers_padded_overflow")
func testH2HeadersPaddedOverflow() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // payload[0]=100 claims 100 padding bytes; only 3 bytes follow → underflow.
    var payload: [4]char
    payload[0] = 100_i8  // padLen = 100
    payload[1] = 0x82_i8 // garbage HPACK bytes (never reached)
    payload[2] = 0x84_i8
    payload[3] = 0x86_i8
    // flags: PADDED(0x08) | END_HEADERS(0x04) | END_STREAM(0x01) = 0x0D
    assert(sendRawFrame(fd, 4, 0x01, 0x0D, 1_u32, payload))

    assert(expectGoaway(fd))
}

// ---------------------------------------------------------------------------
// HEADERS with PRIORITY_F flag tests
// ---------------------------------------------------------------------------

// Valid HEADERS with PRIORITY_F flag — server strips 5-byte priority block,
// dispatches normally.
@test("http2_e2e_headers_priority_flag_valid")
func testH2HeadersPriorityFlagValid() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hpack = StringBuilderInit(32, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)

    assert(sendPriorityHeadersFrame(fd, 1_u32, &hpack, true))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// HEADERS with PRIORITY_F flag but total payload is only 1 byte (< 5 required).
// Server must send GOAWAY PROTOCOL_ERROR.
@test("http2_e2e_headers_priority_flag_too_short")
func testH2HeadersPriorityFlagTooShort() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // 1-byte payload, PRIORITY_F(0x20) | END_HEADERS(0x04) = 0x24
    var payload: [1]char
    payload[0] = 0x82_i8  // irrelevant — server rejects before reading HPACK
    assert(sendRawFrame(fd, 1, 0x01, 0x24, 1_u32, payload))

    assert(expectGoaway(fd))
}

// ---------------------------------------------------------------------------
// DATA with PADDED flag tests
// ---------------------------------------------------------------------------

// Valid DATA with PADDED flag — server strips padding, echoes the real body.
@test("http2_e2e_data_padded_valid")
func testH2DataPaddedValid() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hpack = StringBuilderInit(32, defaultAllocator)
    defer hpack.free()
    buildPostHpack($"/echo", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, false))  // no END_STREAM

    // DATA: padLen=4, body="hi", 4 zero-bytes of padding
    const body = "hi"
    assert(sendPaddedDataFrame(fd, 1_u32, body, 2, 4, true))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)

    assert(readNextFrame(fd, 0x00, &frame))
    assert(frame.streamId == 1_u32)
    assert(frame.length == 2)
    assert(memcmp(frame.payload, body as (*const void), 2_usize) == 0)
}

// DATA with PADDED flag where padLen overflows the frame.
// Server must send GOAWAY PROTOCOL_ERROR.
@test("http2_e2e_data_padded_overflow")
func testH2DataPaddedOverflow() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Open stream 1 so handleData is reached (stream must be in OPEN state).
    var hpack = StringBuilderInit(32, defaultAllocator)
    defer hpack.free()
    buildPostHpack($"/echo", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, false))

    // DATA: 1-byte payload, padLen=100 — dataLen = 1 - 1 - 100 = -100 < 0.
    // flags: PADDED(0x08) | END_STREAM(0x01) = 0x09
    var badData: [1]char
    badData[0] = 100_i8  // padLen
    assert(sendRawFrame(fd, 1, 0x00, 0x09, 1_u32, badData))

    assert(expectGoaway(fd))
}

// ---------------------------------------------------------------------------
// HPACK dynamic table (RFC 7541 §6.2.1)
// ---------------------------------------------------------------------------
//
// Request 1 adds a custom header to the dynamic table via incremental indexing.
// Request 2 on the same connection references it by index 62 (first dynamic entry).
// Both requests must succeed with status 200.

@test("http2_e2e_hpack_dynamic_table")
func testH2HpackDynamicTable() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Request 1 (stream 1): GET /hello + "x-myheader: myvalue" with incremental
    // indexing — server adds it to the dynamic table at index 62.
    var hpack1 = StringBuilderInit(64, defaultAllocator)
    defer hpack1.free()
    buildGetHpack($"/hello", &hpack1)
    hpackIncrementalLiteralName($"x-myheader", $"myvalue", &hpack1)
    assert(sendHeadersFrame(fd, 1_u32, &hpack1, true))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
    // Drain DATA frame
    assert(readNextFrame(fd, 0x00, &frame))
    assert(frame.streamId == 1_u32)

    // Request 2 (stream 3): GET /hello + index 62 (dynamic table reference).
    // The HPACK context is connection-scoped, so index 62 resolves to the entry
    // added by request 1.
    var hpack2 = StringBuilderInit(32, defaultAllocator)
    defer hpack2.free()
    buildGetHpack($"/hello", &hpack2)
    hpackIndexed(62, &hpack2)  // x-myheader: myvalue from dynamic table
    assert(sendHeadersFrame(fd, 3_u32, &hpack2, true))

    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 3_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}
