// HTTP/2 end-to-end tests for ringhttp.
//
// Tests the full request/response cycle over h2c (cleartext HTTP/2) using
// raw sockets and hand-encoded HPACK.  The server is started once for all
// tests in this file.
//
// Run with:  litac test -file test/http2_e2e_test.lita

import "std/libc"
import "std/assert"
import "std/mem"
import "std/thread"
import "std/thread/barrier"
import "std/string"
import "std/string/builder"
import "std/net/posix_socket"
import "std/ringhttp/http_ring"


@raw("""
#include <sys/socket.h>
#include <sys/time.h>
void _h2e2e_setRecvTimeout(int fd, int seconds) {
    struct timeval tv = { seconds, 0 };
    setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, (const void*)&tv, sizeof(tv));
}
""");
@foreign func _h2e2e_setRecvTimeout(fd: i32, seconds: i32);

// ---------------------------------------------------------------------------
// Test server port (separate from main_test.lita to avoid conflicts)
// ---------------------------------------------------------------------------

const H2E2E_PORT: u16 = 9393_u16

// ---------------------------------------------------------------------------
// Route handlers
// ---------------------------------------------------------------------------

func H2HelloHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.body.append("hello")
    return 1
}

func H2EchoBodyHandler(ctx: *RequestHandlerContext) : i32 {
    var req = ctx.request
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.body.appendStrn(req.body.buffer, req.body.length)
    return 1
}

func H2JsonHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.addHeaderStr("content-type", "application/json")
    ctx.response.body.append("{\"ok\":true}")
    return 1
}

// Returns 20 KB of 'A' — forces at least two DATA frames with the default 16 KB max frame size.
const H2_LARGE_BODY_SIZE: i32 = 20480

func H2LargeHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    for(var i = 0; i < H2_LARGE_BODY_SIZE; i += 1) {
        ctx.response.body.appendChar('A')
    }
    return 1
}

// ---------------------------------------------------------------------------
// Server — started once for all tests
// ---------------------------------------------------------------------------

struct H2E2ETestServer {
    config:  HttpConfig
    barrier: Barrier
}

// Module-level globals so their addresses are stable for the server thread.
var gServer: H2E2ETestServer
var gServerReady = false

func H2E2EServerThread(arg: *void) : i32 {
    var ts = arg as (*H2E2ETestServer)
    var server = HttpServer{}
    server.init(&ts.config)
    server.addHttpController(HttpMethod.GET,  "/hello", null,
        HttpController{.callback = H2HelloHandler})
    server.addHttpController(HttpMethod.POST, "/echo",  null,
        HttpController{.callback = H2EchoBodyHandler})
    server.addHttpController(HttpMethod.GET,  "/json",  null,
        HttpController{.callback = H2JsonHandler})
    server.addHttpController(HttpMethod.GET,  "/large", null,
        HttpController{.callback = H2LargeHandler})
    ts.barrier.wait()
    server.start()
    defer server.close()
    return 0
}

func ensureServer() {
    if(gServerReady) {
        return;
    }

    gServer.config = HttpConfig{
        .allocator             = defaultAllocator,
        .port                  = H2E2E_PORT,
        .numThreads            = 2,
        .maxPoolSize           = 32,
        .keepAliveTimeoutInSec = 10,
        .isLogEnabled          = false,
    }
    gServer.barrier.init(2)

    var thread = Thread{}
    assert(thread.create(H2E2EServerThread, &gServer) == ThreadStatus.SUCCESS)
    gServer.barrier.wait()
    ThreadSleepMSec(200)  // let the listen socket bind
    gServerReady = true
}

// ---------------------------------------------------------------------------
// Raw socket helpers
// ---------------------------------------------------------------------------

func h2Connect() : i32 {
    var fd = socket(AF_INET, SOCK_STREAM, 0)
    if(fd < 0) { return -1 }

    var addr: sockaddr_in
    memset(&addr, 0, sizeof(:sockaddr_in))
    addr.sin_family = AF_INET
    addr.sin_port   = htons(H2E2E_PORT)
    inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr)

    if(connect(fd, (&addr) as (*sockaddr), sizeof(:sockaddr_in) as (socklen_t)) < 0) {
        close(fd)
        return -1
    }
    _h2e2e_setRecvTimeout(fd, 10)
    return fd
}

func h2WriteAll(fd: i32, buf: *const char, n: i32) : bool {
    var sent = 0
    while(sent < n) {
        var r = send(fd, (buf + sent) as (*void), (n - sent) as (usize), 0)
        if(r <= 0) { return false }
        sent += r as (i32)
    }
    return true
}

func h2ReadAtLeast(fd: i32, buf: *char, minBytes: i32, bufSize: i32) : i32 {
    var total = 0
    while(total < minBytes && total < bufSize) {
        var r = recv(fd, (buf + total) as (*void), (bufSize - total) as (usize), 0)
        if(r <= 0) { break }
        total += r as (i32)
    }
    return total
}

// ---------------------------------------------------------------------------
// Frame encoding helpers
// ---------------------------------------------------------------------------

func h2WriteFrameHdr(buf: *char, length: i32, frameType: i32, flags: i32, streamId: u32) {
    buf[0] = ((length   >> 16) & 0xFF) as (char)
    buf[1] = ((length   >>  8) & 0xFF) as (char)
    buf[2] =  (length          & 0xFF) as (char)
    buf[3] = (frameType        & 0xFF) as (char)
    buf[4] = (flags            & 0xFF) as (char)
    buf[5] = ((streamId >> 24) & 0x7F) as (char)
    buf[6] = ((streamId >> 16) & 0xFF) as (char)
    buf[7] = ((streamId >>  8) & 0xFF) as (char)
    buf[8] =  (streamId        & 0xFF) as (char)
}

// HPACK integer with a given prefix-bit width and first-byte mask.
func hpackWriteInt(val: i32, prefixBits: i32, firstBytePrefix: i32, out: *StringBuilder) {
    var maxFirst = (1 << prefixBits) - 1
    if(val < maxFirst) {
        var b = (firstBytePrefix | val) as (char)
        out.appendStrn(&b, 1)
        return;
    }
    var b = (firstBytePrefix | maxFirst) as (char)
    out.appendStrn(&b, 1)
    val -= maxFirst
    while(val > 127) {
        var nb = ((val & 0x7f) | 0x80) as (char)
        out.appendStrn(&nb, 1)
        val >>= 7
    }
    var last = val as (char)
    out.appendStrn(&last, 1)
}

// HPACK string literal — length-prefixed, no Huffman.
func hpackWriteStr(s: String, out: *StringBuilder) {
    hpackWriteInt(s.length, 7, 0x00, out)
    if(s.length > 0) {
        out.appendStrn(s.buffer, s.length)
    }
}

// Indexed header field (RFC 7541 §6.1).
func hpackIndexed(idx: i32, out: *StringBuilder) {
    hpackWriteInt(idx, 7, 0x80, out)
}

// Literal without indexing, indexed name (RFC 7541 §6.2.2).
func hpackLiteralName(nameIdx: i32, value: String, out: *StringBuilder) {
    hpackWriteInt(nameIdx, 4, 0x00, out)
    hpackWriteStr(value, out)
}

// Build minimal HPACK block for a GET request.
// Static indices: 2=:method GET, 4=:path /, 6=:scheme http
func buildGetHpack(path: String, out: *StringBuilder) {
    hpackIndexed(2, out)             // :method: GET
    hpackLiteralName(4, path, out)   // :path: <path>  (name index 4)
    hpackIndexed(6, out)             // :scheme: http
}

// Build minimal HPACK block for a POST request.
func buildPostHpack(path: String, out: *StringBuilder) {
    hpackIndexed(3, out)             // :method: POST
    hpackLiteralName(4, path, out)   // :path: <path>
    hpackIndexed(6, out)             // :scheme: http
}

// Send a HEADERS frame.
func sendHeadersFrame(fd: i32, streamId: u32, hpack: *StringBuilder, endStream: bool) : bool {
    var flags = 0x04  // END_HEADERS
    if(endStream) { flags |= 0x01 }
    var hdr: [9]char
    h2WriteFrameHdr(hdr, hpack.length, 0x01, flags, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, hpack.buffer, hpack.length)
}

// Send a DATA frame.
func sendDataFrame(fd: i32, streamId: u32, data: *const char, dataLen: i32, endStream: bool) : bool {
    var flags = 0
    if(endStream) { flags = 0x01 }
    var hdr: [9]char
    h2WriteFrameHdr(hdr, dataLen, 0x00, flags, streamId)
    if(!h2WriteAll(fd, hdr, 9)) { return false }
    if(dataLen > 0) { return h2WriteAll(fd, data, dataLen) }
    return true
}

// Send an empty SETTINGS frame.
func sendSettingsFrame(fd: i32) : bool {
    var hdr: [9]char
    h2WriteFrameHdr(hdr, 0, 0x04, 0x00, 0_u32)
    return h2WriteAll(fd, hdr, 9)
}

// Send a SETTINGS frame with a single INITIAL_WINDOW_SIZE parameter.
func sendSettingsWindowSize(fd: i32, windowSize: i32) : bool {
    // 6-byte parameter: id (2 bytes) + value (4 bytes)
    var payload: [6]char
    payload[0] = 0_i8          // SETTINGS_INITIAL_WINDOW_SIZE id high byte
    payload[1] = 4_i8          // SETTINGS_INITIAL_WINDOW_SIZE id low byte (0x0004)
    payload[2] = ((windowSize >> 24) & 0xFF) as (i8)
    payload[3] = ((windowSize >> 16) & 0xFF) as (i8)
    payload[4] = ((windowSize >>  8) & 0xFF) as (i8)
    payload[5] =  (windowSize        & 0xFF) as (i8)
    var hdr: [9]char
    h2WriteFrameHdr(hdr, 6, 0x04, 0x00, 0_u32)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, 6)
}

// Send a WINDOW_UPDATE frame.
func sendWindowUpdate(fd: i32, streamId: u32, increment: i32) : bool {
    var payload: [4]char
    payload[0] = ((increment >> 24) & 0x7F) as (i8)
    payload[1] = ((increment >> 16) & 0xFF) as (i8)
    payload[2] = ((increment >>  8) & 0xFF) as (i8)
    payload[3] =  (increment        & 0xFF) as (i8)
    var hdr: [9]char
    h2WriteFrameHdr(hdr, 4, 0x08, 0x00, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, 4)
}

// Send a SETTINGS ACK.
func sendSettingsAck(fd: i32) : bool {
    var hdr: [9]char
    h2WriteFrameHdr(hdr, 0, 0x04, 0x01, 0_u32)
    return h2WriteAll(fd, hdr, 9)
}

// Send a PING frame (8-byte payload).
func sendPingFrame(fd: i32, payload: *const char) : bool {
    var hdr: [9]char
    h2WriteFrameHdr(hdr, 8, 0x06, 0x00, 0_u32)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, 8)
}

// ---------------------------------------------------------------------------
// Frame decoding helpers
// ---------------------------------------------------------------------------

struct H2Frame {
    frameType: i32
    flags:     i32
    streamId:  u32
    length:    i32
    payload:   [16384]char
}

func readFrame(fd: i32, out: *H2Frame) : bool {
    var hdr: [9]char
    var n = h2ReadAtLeast(fd, hdr, 9, 9)
    if(n < 9) { return false }

    out.length    = ((hdr[0] as (i32) & 0xFF) << 16) |
                    ((hdr[1] as (i32) & 0xFF) <<  8) |
                     (hdr[2] as (i32) & 0xFF)
    out.frameType =   hdr[3] as (i32) & 0xFF
    out.flags     =   hdr[4] as (i32) & 0xFF
    out.streamId  = (((hdr[5] as (u32)) << 24) |
                     ((hdr[6] as (u32)) << 16) |
                     ((hdr[7] as (u32)) <<  8) |
                      (hdr[8] as (u32))) & 0x7FFFFFFF_u32

    if(out.length > 0) {
        if(out.length > 16384) { return false }
        var got = h2ReadAtLeast(fd, out.payload, out.length, out.length)
        if(got < out.length) { return false }
    }
    return true
}

// Read frames, skipping WINDOW_UPDATE (0x8) and SETTINGS (0x4),
// until a frame of wantType arrives or we exhaust retries.
func readNextFrame(fd: i32, wantType: i32, out: *H2Frame) : bool {
    for(var tries = 0; tries < 16; tries += 1) {
        if(!readFrame(fd, out)) { return false }
        if(out.frameType == 0x04) {       // SETTINGS
            if((out.flags & 0x01) == 0) {
                sendSettingsAck(fd)       // ACK server SETTINGS
            }
            continue
        }
        if(out.frameType == 0x08) {       // WINDOW_UPDATE — flow-control noise
            continue
        }
        return out.frameType == wantType
    }
    return false
}

// ---------------------------------------------------------------------------
// HPACK response status decoder
// ---------------------------------------------------------------------------
//
// The server uses indexed representations for known status codes
// (0x80|idx where idx 8-14 = 200,204,206,304,400,404,500), and
// literal-without-indexing (first byte 0x08) for everything else.

func decodeResponseStatus(hpack: *const char, hpackLen: i32) : i32 {
    if(hpackLen < 1) { return -1 }
    var first = hpack[0] as (i32) & 0xFF

    // Indexed representation: bit 7 set
    if(first & 0x80) {
        var idx = first & 0x7F
        if(idx == 8)  { return 200 }
        if(idx == 9)  { return 204 }
        if(idx == 10) { return 206 }
        if(idx == 11) { return 304 }
        if(idx == 12) { return 400 }
        if(idx == 13) { return 404 }
        if(idx == 14) { return 500 }
        return -1
    }

    // Literal without indexing, name index 8 (:status)
    if(first == 0x08 && hpackLen >= 3) {
        var strLen = hpack[1] as (i32) & 0x7F   // no Huffman, 7-bit prefix
        if(2 + strLen > hpackLen || strLen < 1) { return -1 }
        var status = 0
        for(var i = 0; i < strLen; i += 1) {
            var c = hpack[2 + i] as (i32) & 0xFF
            if(c < 0x30 || c > 0x39) { return -1 }
            status = status * 10 + (c - 0x30)
        }
        return status
    }

    return -1
}

// ---------------------------------------------------------------------------
// Handshake — send preface + SETTINGS, absorb server SETTINGS + ACK,
//             respond with SETTINGS ACK.
// ---------------------------------------------------------------------------

func doHandshake(fd: i32) : bool {
    const preface = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    if(!h2WriteAll(fd, preface, 24)) { return false }
    if(!sendSettingsFrame(fd))        { return false }

    // Read at least 18 bytes: server SETTINGS (9) + SETTINGS ACK (9)
    var buf: [512]char
    var n = h2ReadAtLeast(fd, buf, 18, 512)
    if(n < 18) { return false }

    // Validate server SETTINGS at offset 0
    if((buf[3] as (i32) & 0xFF) != 0x04) { return false }
    if((buf[4] as (i32) & 0xFF) != 0x00) { return false }

    // Validate SETTINGS ACK at offset 9
    if((buf[12] as (i32) & 0xFF) != 0x04) { return false }
    if((buf[13] as (i32) & 0xFF) != 0x01) { return false }

    return sendSettingsAck(fd)
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

@test("http2_e2e_get_hello")
func testH2GetHello() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    // GET /hello — END_HEADERS | END_STREAM in one HEADERS frame
    var hpack = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    var frame = H2Frame{}
    assert(readNextFrame(fd, 0x01, &frame))   // HEADERS
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)

    assert(readNextFrame(fd, 0x00, &frame))   // DATA
    assert(frame.streamId == 1_u32)
    assert(frame.length == 5)
    assert(memcmp(frame.payload, "hello" as (*const void), 5_usize) == 0)
    assert(frame.flags & 0x01)                // END_STREAM
}

@test("http2_e2e_not_found")
func testH2NotFound() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    var hpack = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/no-such-route", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    var frame = H2Frame{}
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 404)
}

@test("http2_e2e_post_with_body")
func testH2PostWithBody() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    // HEADERS without END_STREAM — body follows
    var hpack = StringBuilderInit(64, defaultAllocator)
    buildPostHpack($"/echo", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, false))

    // DATA with END_STREAM
    const body = "ping"
    assert(sendDataFrame(fd, 1_u32, body, 4, true))

    var frame = H2Frame{}
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)

    assert(readNextFrame(fd, 0x00, &frame))
    assert(frame.streamId == 1_u32)
    assert(frame.length == 4)
    assert(memcmp(frame.payload, "ping" as (*const void), 4_usize) == 0)
}

@test("http2_e2e_ping_ack")
func testH2PingAck() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    const pingData = "TESTPING"
    assert(sendPingFrame(fd, pingData))

    var frame = H2Frame{}
    assert(readNextFrame(fd, 0x06, &frame))   // PING
    assert(frame.flags & 0x01)                // ACK flag
    assert(frame.length == 8)
    assert(memcmp(frame.payload, pingData as (*const void), 8_usize) == 0)
}

@test("http2_e2e_multiple_streams")
func testH2MultipleStreams() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    // Stream 1: GET /hello
    var hpack1 = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/hello", &hpack1)
    assert(sendHeadersFrame(fd, 1_u32, &hpack1, true))

    var frame = H2Frame{}
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
    assert(readNextFrame(fd, 0x00, &frame))
    assert(frame.streamId == 1_u32)

    // Stream 3: GET /json  (client streams are odd and strictly increasing)
    var hpack2 = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/json", &hpack2)
    assert(sendHeadersFrame(fd, 3_u32, &hpack2, true))

    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 3_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
    assert(readNextFrame(fd, 0x00, &frame))
    assert(frame.streamId == 3_u32)
}

@test("http2_e2e_headers_flags")
func testH2HeadersFlags() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    var hpack = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/json", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    var frame = H2Frame{}

    // HEADERS must have END_HEADERS (0x4)
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.flags & 0x04)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)

    // DATA must have END_STREAM (0x1)
    assert(readNextFrame(fd, 0x00, &frame))
    assert(frame.flags & 0x01)
}

@test("http2_e2e_large_body")
func testH2LargeBody() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    var hpack = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/large", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    // Read HEADERS frame (status 200)
    var frame = H2Frame{}
    assert(readNextFrame(fd, 0x01, &frame))
    assert(frame.streamId == 1_u32)
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)

    // Accumulate all DATA frames until END_STREAM; verify total byte count
    var totalBytes = 0
    while(true) {
        assert(readNextFrame(fd, 0x00, &frame))
        assert(frame.streamId == 1_u32)
        // Each chunk must be <= default max frame size (16384)
        assert(frame.length <= 16384)
        totalBytes += frame.length
        if(frame.flags & 0x01) {
            break  // END_STREAM
        }
    }
    assert(totalBytes == H2_LARGE_BODY_SIZE)
}

// Handshake where the client advertises a small INITIAL_WINDOW_SIZE.
// Returns true on success.
func doHandshakeSmallWindow(fd: i32, windowSize: i32) : bool {
    const preface = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    if(!h2WriteAll(fd, preface, 24)) { return false }
    if(!sendSettingsWindowSize(fd, windowSize)) { return false }

    var buf: [512]char
    var n = h2ReadAtLeast(fd, buf, 18, 512)
    if(n < 18) { return false }

    if((buf[3] as (i32) & 0xFF) != 0x04) { return false }
    if((buf[4] as (i32) & 0xFF) != 0x00) { return false }
    if((buf[12] as (i32) & 0xFF) != 0x04) { return false }
    if((buf[13] as (i32) & 0xFF) != 0x01) { return false }

    return sendSettingsAck(fd)
}

@test("http2_e2e_flow_control")
func testH2FlowControl() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    // Advertise an initial stream window of 1024 bytes — server must respect it.
    const SMALL_WINDOW: i32 = 1024
    assert(doHandshakeSmallWindow(fd, SMALL_WINDOW))

    var hpack = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/large", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    // Read HEADERS (status 200)
    var frame = H2Frame{}
    assert(readNextFrame(fd, 0x01, &frame))
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)

    // Drain DATA frames, sending WINDOW_UPDATEs to keep flow going.
    // Each DATA frame must be <= SMALL_WINDOW (the stream's send window).
    var totalBytes = 0
    var grantedExtra = 0
    while(true) {
        assert(readNextFrame(fd, 0x00, &frame))
        assert(frame.streamId == 1_u32)
        assert(frame.length <= SMALL_WINDOW)
        totalBytes += frame.length
        if(frame.flags & 0x01) {
            break  // END_STREAM
        }
        // Open both stream and connection windows so server can continue
        assert(sendWindowUpdate(fd, 1_u32, frame.length))
        assert(sendWindowUpdate(fd, 0_u32, frame.length))
        grantedExtra += frame.length
    }
    assert(totalBytes == H2_LARGE_BODY_SIZE)
}

// Send two requests on streams 1 and 3 before reading any response.
// Both must be dispatched from a single process() call and both responses
// must arrive with their correct stream IDs.
@test("http2_e2e_pipelined_requests")
func testH2PipelinedRequests() {
    ensureServer()

    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    assert(doHandshake(fd))

    // Stream 1: GET /hello  (END_STREAM in HEADERS)
    var hpack1 = StringBuilderInit(64, defaultAllocator)
    buildGetHpack($"/hello", &hpack1)
    assert(sendHeadersFrame(fd, 1_u32, &hpack1, true))

    // Stream 3: POST /echo  (HEADERS + DATA with END_STREAM)
    var hpack2 = StringBuilderInit(64, defaultAllocator)
    buildPostHpack($"/echo", &hpack2)
    assert(sendHeadersFrame(fd, 3_u32, &hpack2, false))
    assert(sendDataFrame(fd, 3_u32, "world", 5, true))

    // Collect both responses regardless of arrival order.
    var got1  = false
    var got3  = false
    var body1 = false
    var body3 = false

    var frame = H2Frame{}
    for(var iter = 0; iter < 16 && !(got1 && got3); iter += 1) {
        // Accept any frame type (pass a type that won't match so the loop reads one frame)
        if(!readFrame(fd, &frame)) { break }
        // Skip SETTINGS and WINDOW_UPDATE noise
        if(frame.frameType == 0x04) { sendSettingsAck(fd); continue }
        if(frame.frameType == 0x08) { continue }

        if(frame.frameType == 0x01) {  // HEADERS
            assert(decodeResponseStatus(frame.payload, frame.length) == 200)
            if(frame.streamId == 1_u32 && (frame.flags & 0x01)) { got1 = true }
            if(frame.streamId == 3_u32 && (frame.flags & 0x01)) { got3 = true }
        } else if(frame.frameType == 0x00) {  // DATA
            if(frame.streamId == 1_u32) {
                assert(frame.length == 5)
                assert(memcmp(frame.payload, "hello" as (*const void), 5_usize) == 0)
                if(frame.flags & 0x01) { got1 = true; body1 = true }
            } else if(frame.streamId == 3_u32) {
                assert(frame.length == 5)
                assert(memcmp(frame.payload, "world" as (*const void), 5_usize) == 0)
                if(frame.flags & 0x01) { got3 = true; body3 = true }
            }
        }
    }

    assert(got1)
    assert(got3)
    assert(body1)
    assert(body3)
}

// ---------------------------------------------------------------------------
// Error-path helpers
// ---------------------------------------------------------------------------

// Read frames until a GOAWAY (type 0x07) arrives or the connection is closed.
// Both outcomes are valid responses to a fatal protocol error.
func expectGoaway(fd: i32) : bool {
    var frame: H2Frame
    for(var tries = 0; tries < 20; tries += 1) {
        if(!readFrame(fd, &frame)) {
            return true  // connection closed — acceptable after fatal error
        }
        if(frame.frameType == 0x07) {
            return true
        }
    }
    return false
}

// Send a SETTINGS frame with one 6-byte parameter.
func sendSettingsParam(fd: i32, paramId: u16, value: u32) : bool {
    var payload: [6]char
    payload[0] = ((paramId >> 8) & 0xFF) as (char)
    payload[1] =  (paramId       & 0xFF) as (char)
    payload[2] = ((value >> 24)  & 0xFF) as (char)
    payload[3] = ((value >> 16)  & 0xFF) as (char)
    payload[4] = ((value >>  8)  & 0xFF) as (char)
    payload[5] =  (value         & 0xFF) as (char)
    var hdr: [9]char
    h2WriteFrameHdr(hdr, 6, 0x04, 0x00, 0_u32)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, 6)
}

// Send a raw frame with an arbitrary payload.
func sendRawFrame(fd: i32, length: i32, frameType: i32, flags: i32, streamId: u32, payload: *const char) : bool {
    var hdr: [9]char
    h2WriteFrameHdr(hdr, length, frameType, flags, streamId)
    if(!h2WriteAll(fd, hdr, 9)) { return false }
    if(length > 0 && payload != null) {
        return h2WriteAll(fd, payload, length)
    }
    return true
}

// Send a CONTINUATION frame.
func sendContinuationFrame(fd: i32, streamId: u32, hpack: *StringBuilder, endHeaders: bool) : bool {
    var flags = endHeaders ? 0x04 : 0x00
    var hdr: [9]char
    h2WriteFrameHdr(hdr, hpack.length, 0x09, flags, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, hpack.buffer, hpack.length)
}

// Read the RST_STREAM error code from a frame payload (4-byte big-endian).
func rstStreamErrorCode(frame: *H2Frame) : u32 {
    if(frame.length < 4) { return 0xFFFFFFFF_u32 }
    return ((frame.payload[0] as (u32) & 0xFF) << 24) |
           ((frame.payload[1] as (u32) & 0xFF) << 16) |
           ((frame.payload[2] as (u32) & 0xFF) <<  8) |
            (frame.payload[3] as (u32) & 0xFF)
}

// ---------------------------------------------------------------------------
// GOAWAY error-path tests — fatal protocol violations that close the connection
// ---------------------------------------------------------------------------

// Client sends non-HTTP/2 bytes as connection preface.
@test("http2_e2e_error_invalid_preface")
func testH2ErrorInvalidPreface() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)

    const garbage = "GET / HTTP/1.1\r\nHost: localhost\r\n\r\n"
    h2WriteAll(fd, garbage, strlen(garbage) as (i32))

    assert(expectGoaway(fd))
}

// SETTINGS frame sent on a non-zero stream (RFC 7540 §6.5: must be stream 0).
@test("http2_e2e_error_settings_on_stream")
func testH2ErrorSettingsOnStream() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hdr: [9]char
    h2WriteFrameHdr(hdr, 0, 0x04, 0x00, 1_u32)  // SETTINGS on stream 1
    assert(h2WriteAll(fd, hdr, 9))

    assert(expectGoaway(fd))
}

// SETTINGS payload length not a multiple of 6 bytes (RFC 7540 §6.5).
@test("http2_e2e_error_settings_bad_length")
func testH2ErrorSettingsBadLength() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var payload: [5]char
    assert(sendRawFrame(fd, 5, 0x04, 0x00, 0_u32, payload))  // length=5, not mult of 6

    assert(expectGoaway(fd))
}

// SETTINGS INITIAL_WINDOW_SIZE > 2^31-1 (RFC 7540 §6.9.2: FLOW_CONTROL_ERROR).
@test("http2_e2e_error_settings_window_overflow")
func testH2ErrorSettingsWindowOverflow() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // paramId 0x0004 = SETTINGS_INITIAL_WINDOW_SIZE, value = 0x80000000
    assert(sendSettingsParam(fd, 0x0004_u16, 0x80000000_u32))

    assert(expectGoaway(fd))
}

// PING sent on a non-zero stream (RFC 7540 §6.7: must be stream 0).
@test("http2_e2e_error_ping_on_stream")
func testH2ErrorPingOnStream() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var payload: [8]char
    assert(sendRawFrame(fd, 8, 0x06, 0x00, 1_u32, payload))  // PING on stream 1

    assert(expectGoaway(fd))
}

// PING with wrong payload length (must be exactly 8 bytes).
@test("http2_e2e_error_ping_bad_length")
func testH2ErrorPingBadLength() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var payload: [7]char
    assert(sendRawFrame(fd, 7, 0x06, 0x00, 0_u32, payload))  // PING with 7-byte payload

    assert(expectGoaway(fd))
}

// HEADERS sent on stream 0 (RFC 7540 §6.2: must be non-zero stream).
@test("http2_e2e_error_headers_on_stream0")
func testH2ErrorHeadersOnStream0() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hpack = StringBuilderInit(64, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)

    var hdr: [9]char
    h2WriteFrameHdr(hdr, hpack.length, 0x01, 0x05, 0_u32)  // HEADERS on stream 0
    assert(h2WriteAll(fd, hdr, 9))
    assert(h2WriteAll(fd, hpack.buffer, hpack.length))

    assert(expectGoaway(fd))
}

// CONTINUATION frame arrives without a preceding HEADERS frame (RFC 7540 §6.10).
@test("http2_e2e_error_continuation_without_headers")
func testH2ErrorContinuationWithoutHeaders() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hpack = StringBuilderInit(64, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)

    assert(sendContinuationFrame(fd, 1_u32, &hpack, true))

    assert(expectGoaway(fd))
}

// DATA sent on stream 0 (RFC 7540 §6.1: must be non-zero stream).
@test("http2_e2e_error_data_on_stream0")
func testH2ErrorDataOnStream0() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    const body = "hello"
    assert(sendRawFrame(fd, 5, 0x00, 0x01, 0_u32, body))  // DATA on stream 0

    assert(expectGoaway(fd))
}

// RST_STREAM sent on stream 0 (RFC 7540 §6.4: must be non-zero stream).
@test("http2_e2e_error_rst_stream_on_stream0")
func testH2ErrorRstStreamOnStream0() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var payload: [4]char  // error code = 0 (NO_ERROR)
    assert(sendRawFrame(fd, 4, 0x03, 0x00, 0_u32, payload))

    assert(expectGoaway(fd))
}

// Connection-level WINDOW_UPDATE with increment=0 (RFC 7540 §6.9.1: PROTOCOL_ERROR).
@test("http2_e2e_error_window_update_zero_connection")
func testH2ErrorWindowUpdateZeroConnection() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    assert(sendWindowUpdate(fd, 0_u32, 0))

    assert(expectGoaway(fd))
}

// ---------------------------------------------------------------------------
// RST_STREAM error-path tests — stream violations that leave connection open
// ---------------------------------------------------------------------------

// HEADERS with even stream ID (RFC 7540 §5.1.1: client streams are odd).
// This is a connection error (GOAWAY), not a stream error.
@test("http2_e2e_error_even_stream_id")
func testH2ErrorEvenStreamId() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hpack = StringBuilderInit(64, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)

    var hdr: [9]char
    h2WriteFrameHdr(hdr, hpack.length, 0x01, 0x05, 2_u32)  // HEADERS, END_HEADERS|END_STREAM, stream 2
    assert(h2WriteAll(fd, hdr, 9))
    assert(h2WriteAll(fd, hpack.buffer, hpack.length))

    assert(expectGoaway(fd))
}

// DATA arrives on a stream that was never opened (idle state).
// RFC 7540 §5.1: MUST treat as a connection error of type PROTOCOL_ERROR.
@test("http2_e2e_error_data_unknown_stream")
func testH2ErrorDataUnknownStream() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Send DATA on stream 7 — never opened via HEADERS.
    const body = "hi"
    assert(sendRawFrame(fd, 2, 0x00, 0x01, 7_u32, body))

    assert(expectGoaway(fd))
}

// Stream-level WINDOW_UPDATE with increment=0 (RFC 7540 §6.9.1: RST_STREAM PROTOCOL_ERROR).
@test("http2_e2e_error_window_update_zero_stream")
func testH2ErrorWindowUpdateZeroStream() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Open stream 1 so WINDOW_UPDATE on it is valid target.
    var hpack = StringBuilderInit(64, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, false))  // no END_STREAM: stream stays OPEN

    // WINDOW_UPDATE with increment=0 on stream 1.
    assert(sendWindowUpdate(fd, 1_u32, 0))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x03, &frame))  // expect RST_STREAM
    assert(frame.streamId == 1_u32)
    assert(rstStreamErrorCode(&frame) == 1_u32)  // PROTOCOL_ERROR = 0x1
}

// Opening more than MAX_H2_STREAMS (16) concurrent streams triggers RST_STREAM REFUSED_STREAM.
@test("http2_e2e_error_stream_limit_exceeded")
func testH2ErrorStreamLimitExceeded() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hpack = StringBuilderInit(64, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/hello", &hpack)

    // Open 16 streams without END_STREAM so they remain OPEN.
    for(var i = 0; i < 16; i += 1) {
        var streamId = (1_u32 + (2_u32 * i as (u32)))
        assert(sendHeadersFrame(fd, streamId, &hpack, false))
    }

    // Stream 33 (17th concurrent) must be refused.
    assert(sendHeadersFrame(fd, 33_u32, &hpack, false))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x03, &frame))  // expect RST_STREAM
    assert(frame.streamId == 33_u32)
    assert(rstStreamErrorCode(&frame) == 7_u32)  // REFUSED_STREAM
}

// ---------------------------------------------------------------------------
// Helper: HEADERS frame without END_HEADERS (for CONTINUATION tests)
// ---------------------------------------------------------------------------

func sendHeadersFrameNoEndHeaders(fd: i32, streamId: u32, hpack: *StringBuilder, endStream: bool) : bool {
    var flags = endStream ? 0x01 : 0x00  // END_STREAM only, no END_HEADERS
    var hdr: [9]char
    h2WriteFrameHdr(hdr, hpack.length, 0x01, flags, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, hpack.buffer, hpack.length)
}

// Helper: RST_STREAM frame sent by the client.
func sendRstStreamFrame(fd: i32, streamId: u32, errorCode: u32) : bool {
    var payload: [4]char
    payload[0] = ((errorCode >> 24) & 0xFF) as (char)
    payload[1] = ((errorCode >> 16) & 0xFF) as (char)
    payload[2] = ((errorCode >>  8) & 0xFF) as (char)
    payload[3] =  (errorCode        & 0xFF) as (char)
    var hdr: [9]char
    h2WriteFrameHdr(hdr, 4, 0x03, 0x00, streamId)
    return h2WriteAll(fd, hdr, 9) && h2WriteAll(fd, payload, 4)
}

// ---------------------------------------------------------------------------
// CONTINUATION happy-path tests
// ---------------------------------------------------------------------------

// GET whose HPACK is split: HEADERS carries :method only (no END_HEADERS),
// CONTINUATION carries :path + :scheme (END_HEADERS).  The original HEADERS
// frame also carries END_STREAM (no body) so the request must be dispatched
// once END_HEADERS arrives.
@test("http2_e2e_continuation_happy_path")
func testH2ContinuationHappyPath() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Split: HEADERS sends :method GET (1 byte: indexed field #2)
    var hdrsHpack = StringBuilderInit(16, defaultAllocator)
    defer hdrsHpack.free()
    hpackIndexed(2, &hdrsHpack)  // :method: GET

    // CONTINUATION sends :path /hello + :scheme http
    var contHpack = StringBuilderInit(32, defaultAllocator)
    defer contHpack.free()
    hpackLiteralName(4, $"/hello", &contHpack)  // :path: /hello
    hpackIndexed(6, &contHpack)                  // :scheme: http

    // Stream 1: HEADERS with END_STREAM, no END_HEADERS
    assert(sendHeadersFrameNoEndHeaders(fd, 1_u32, &hdrsHpack, true))
    // CONTINUATION with END_HEADERS finalises the header block and triggers dispatch
    assert(sendContinuationFrame(fd, 1_u32, &contHpack, true))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))  // HEADERS response
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// Same idea with two CONTINUATION frames: HEADERS + CONT (no END_HEADERS) + CONT (END_HEADERS).
@test("http2_e2e_continuation_multi_part")
func testH2ContinuationMultiPart() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    var hdrsHpack = StringBuilderInit(16, defaultAllocator)
    defer hdrsHpack.free()
    hpackIndexed(2, &hdrsHpack)  // :method: GET

    var cont1Hpack = StringBuilderInit(16, defaultAllocator)
    defer cont1Hpack.free()
    hpackLiteralName(4, $"/hello", &cont1Hpack)  // :path: /hello

    var cont2Hpack = StringBuilderInit(16, defaultAllocator)
    defer cont2Hpack.free()
    hpackIndexed(6, &cont2Hpack)  // :scheme: http

    assert(sendHeadersFrameNoEndHeaders(fd, 1_u32, &hdrsHpack, true))
    assert(sendContinuationFrame(fd, 1_u32, &cont1Hpack, false))  // not END_HEADERS
    assert(sendContinuationFrame(fd, 1_u32, &cont2Hpack, true))   // END_HEADERS

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))  // HEADERS response
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// POST whose HEADERS has no END_STREAM and no END_HEADERS; CONTINUATION
// finalises the header block; DATA with END_STREAM delivers the body.
@test("http2_e2e_continuation_post")
func testH2ContinuationPost() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // HEADERS: :method POST + :scheme http (no END_STREAM, no END_HEADERS)
    var hdrsHpack = StringBuilderInit(32, defaultAllocator)
    defer hdrsHpack.free()
    hpackIndexed(3, &hdrsHpack)  // :method: POST
    hpackIndexed(6, &hdrsHpack)  // :scheme: http

    // CONTINUATION: :path /echo (END_HEADERS)
    var contHpack = StringBuilderInit(16, defaultAllocator)
    defer contHpack.free()
    hpackLiteralName(4, $"/echo", &contHpack)

    assert(sendHeadersFrameNoEndHeaders(fd, 1_u32, &hdrsHpack, false))
    assert(sendContinuationFrame(fd, 1_u32, &contHpack, true))

    const body = "greet"
    assert(sendDataFrame(fd, 1_u32, body, 5, true))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))  // HEADERS response
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
    assert(readNextFrame(fd, 0x00, &frame))  // DATA frame
    assert(frame.length == 5)
}

// ---------------------------------------------------------------------------
// RST_STREAM from client
// ---------------------------------------------------------------------------

// Client cancels a stream (RST_STREAM CANCEL) while it is still open.
// The connection must survive: a subsequent request on a new stream succeeds.
@test("http2_e2e_rst_stream_from_client")
func testH2RstStreamFromClient() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Open stream 1 as POST /echo without END_STREAM (server waits for DATA).
    var hpack = StringBuilderInit(32, defaultAllocator)
    defer hpack.free()
    buildPostHpack($"/echo", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, false))

    // Client cancels it immediately.
    assert(sendRstStreamFrame(fd, 1_u32, 8_u32))  // CANCEL = 0x8

    // A subsequent GET /hello on stream 3 must succeed.
    hpack.clear()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 3_u32, &hpack, true))

    var frame: H2Frame
    assert(readNextFrame(fd, 0x01, &frame))
    assert(decodeResponseStatus(frame.payload, frame.length) == 200)
}

// ---------------------------------------------------------------------------
// MAX_FRAME_SIZE negotiation
// ---------------------------------------------------------------------------

// Client negotiates MAX_FRAME_SIZE = 16384 (minimum valid per RFC 7540 §6.5.2).
// The server's 20 KB response to /large must arrive in DATA frames each ≤ 16384 bytes,
// producing at least two frames (16384 + 4096).
@test("http2_e2e_max_frame_size_negotiation")
func testH2MaxFrameSizeNegotiation() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Tell server our max frame size is 16384 (RFC minimum; also the default,
    // so this verifies the server processes SETTINGS correctly and still chunks).
    assert(sendSettingsParam(fd, 0x0005_u16, 16384_u32))

    var hpack = StringBuilderInit(32, defaultAllocator)
    defer hpack.free()
    buildGetHpack($"/large", &hpack)
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    // Collect DATA frames until END_STREAM.
    var totalData = 0
    var maxSeen   = 0
    for(var tries = 0; tries < 64; tries += 1) {
        var frame: H2Frame
        if(!readFrame(fd, &frame)) { break }
        if(frame.frameType == 0x04) {  // SETTINGS
            if((frame.flags & 0x01) == 0) { sendSettingsAck(fd) }
            continue
        }
        if(frame.frameType == 0x08) { continue }  // WINDOW_UPDATE
        if(frame.frameType == 0x01) { continue }  // HEADERS response
        if(frame.frameType == 0x07) { break }      // GOAWAY — unexpected, will fail asserts
        if(frame.frameType == 0x00) {              // DATA
            assert(frame.length <= 16384)
            if(frame.length > maxSeen) { maxSeen = frame.length }
            totalData += frame.length
            if(frame.flags & 0x01) { break }       // END_STREAM
        }
    }
    assert(totalData == H2_LARGE_BODY_SIZE)
    assert(maxSeen > 0 && maxSeen <= 16384)
}

// ---------------------------------------------------------------------------
// HPACK malformed input
// ---------------------------------------------------------------------------

// Indexed header field with index 0 is invalid per RFC 7541 §6.1.
// Server must respond with GOAWAY COMPRESSION_ERROR (connection-level error).
@test("http2_e2e_hpack_invalid_index_zero")
func testH2HpackInvalidIndexZero() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // 0x80 = indexed field, index 0 — explicitly forbidden by HPACK spec.
    var badHpack: [1]char
    badHpack[0] = 0x80 as (char)
    // HEADERS frame: END_STREAM | END_HEADERS, stream 1, 1-byte payload
    assert(sendRawFrame(fd, 1, 0x01, 0x05, 1_u32, badHpack))

    assert(expectGoaway(fd))
}

// Literal header field whose string length claims more bytes than remain.
// Server must respond with GOAWAY COMPRESSION_ERROR.
@test("http2_e2e_hpack_truncated_string")
func testH2HpackTruncatedString() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // Literal without indexing (0x00), new name: length=50 claimed, 2 bytes given.
    var badHpack: [4]char
    badHpack[0] = 0x00 as (char)  // literal, no index
    badHpack[1] = 0x32 as (char)  // name length = 50 (no Huffman)
    badHpack[2] = 'x' as (char)   // only 2 bytes of claimed 50
    badHpack[3] = 'x' as (char)
    assert(sendRawFrame(fd, 4, 0x01, 0x05, 1_u32, badHpack))

    assert(expectGoaway(fd))
}

// ---------------------------------------------------------------------------
// Pseudo-header validation (RFC 7540 §8.1.2.3)
// ---------------------------------------------------------------------------
//
// :method, :path, :scheme must all be present and non-empty for every
// non-CONNECT request.  A violation is a stream-level PROTOCOL_ERROR
// (RST_STREAM 0x03, error code 0x1), NOT a connection error, so the
// connection must remain open for subsequent requests.
//
// HPACK static table indices used below:
//   2 = :method GET    4 = :path /    6 = :scheme http

// Helper: send a HEADERS frame carrying raw HPACK bytes, then read the
// next frame skipping SETTINGS/WINDOW_UPDATE, and verify it is a
// RST_STREAM PROTOCOL_ERROR on the expected stream.
func expectRstProtocolError(fd: i32, streamId: u32) : bool {
    var frame: H2Frame
    if(!readNextFrame(fd, 0x03, &frame)) { return false }   // 0x03 = RST_STREAM
    if(frame.streamId != streamId) { return false }
    return rstStreamErrorCode(&frame) == 1_u32   // PROTOCOL_ERROR
}

@test("http2_e2e_pseudo_missing_method")
func testH2PseudoMissingMethod() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // :path / (idx 4) + :scheme http (idx 6) — no :method
    var hpack = StringBuilderInit(8, defaultAllocator)
    defer hpack.free()
    hpackIndexed(4, &hpack)   // :path /
    hpackIndexed(6, &hpack)   // :scheme http
