// ---------------------------------------------------------------------------
// Duplicate pseudo-headers (RFC 7540 §8.1.2.1)
// ---------------------------------------------------------------------------
//
// Each pseudo-header field must appear at most once.  Duplicates are a
// stream-level PROTOCOL_ERROR (RST_STREAM 0x03, error code 0x1).
// The connection must remain usable for subsequent requests.

@test("http2_e2e_pseudo_duplicate_method")
func testH2DuplicatePseudoMethod() {
    ensureServer()
    var fd = h2Connect()
    assert(fd >= 0)
    defer close(fd)
    assert(doHandshake(fd))

    // :method GET twice, plus the required :path and :scheme
    var hpack = StringBuilderInit(16, defaultAllocator)
    defer hpack.free()
    hpackIndexed(2, &hpack)   // :method GET  (first)
    hpackIndexed(2, &hpack)   // :method GET  (duplicate)
    hpackIndexed(4, &hpack)   // :path /
    hpackIndexed(6, &hpack)   // :scheme http
    assert(sendHeadersFrame(fd, 1_u32, &hpack, true))

    assert(expectRstProtocolError(fd, 1_u32))

    hpack.clear()
    buildGetHpack($"/hello", &hpack)
    assert(sendHeadersFrame(fd, 3_u32, &hpack, true))
    var frame2: H2Frame
    assert(readNextFrame(fd, 0x01, &frame2))
    assert(decodeResponseStatus(frame2.payload, frame2.length) == 200)
}

