import "std/string"
import "std/string/builder"
import "std/array"
import "std/mem"
import "std/libc"
import "std/assert"

import "std/ringhttp/http_request"
import "std/ringhttp/http_parser"
import "std/ringhttp/http_common"

@test
func testParse() {
    var result: HttpRequest;

    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var input = StringInit(
"GET /this/is/path HTTP/1.1\r\nContent-Type: application/x-www-form-urlencoded\r\nOrigin: example.com\r\nAgent:Some other Stuff/And some thingds end.\r\n\r\nname=Anthony+Sparks&address=3265+FORDHAM+CT&phone=414-315-1920"
);

    assert(parser.parse(input, &result) == Status.OK)

    // request line
    assert(result.method == HttpMethod.GET)
    assert(result.path.equals($"/this/is/path"))
    assert(result.version.equals($"HTTP/1.1"))

    // headers
    assert(result.headers.size() == 3)
    assert(result.headers.getPtr(0).name.equals($"Content-Type"))
    assert(result.headers.getPtr(0).values.equals($"application/x-www-form-urlencoded"))
    assert(result.headers.getPtr(1).name.equals($"Origin"))
    assert(result.headers.getPtr(1).values.equals($"example.com"))
    assert(result.headers.getPtr(2).name.equals($"Agent"))
    assert(result.headers.getPtr(2).values.equals($"Some other Stuff/And some thingds end."))

    assert(result.bodyType == BodyType.FORM_URLENCODED)

    // body — parse form params from the portion after \r\n\r\n
    var bodyStr = input.substring(input.endIndexOf($"\r\n\r\n"))
    assert(parser.parseBody(bodyStr, &result) == Status.OK)

    assert(result.formParams.size() == 3)
    assert(result.formParams.getPtr(0).name.equals($"name"))
    assert(result.formParams.getPtr(0).value.equals($"Anthony Sparks"))
    assert(result.formParams.getPtr(1).name.equals($"address"))
    assert(result.formParams.getPtr(1).value.equals($"3265 FORDHAM CT"))
    assert(result.formParams.getPtr(2).name.equals($"phone"))
    assert(result.formParams.getPtr(2).value.equals($"414-315-1920"))
}

@test
func testParseMultipart() {
    var result: HttpRequest;

    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var input = StringInit(
"POST /upload HTTP/1.1\r\nHost: example.com\r\nContent-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW\r\nContent-Length: 356\r\n\r\n------WebKitFormBoundary7MA4YWxkTrZu0gW\r\nContent-Disposition: form-data; name=\"name\"\r\n\r\nJohn Doe\r\n------WebKitFormBoundary7MA4YWxkTrZu0gW\r\nContent-Disposition: form-data; name=\"address\"\r\n\r\n123 Elm Street\r\n------WebKitFormBoundary7MA4YWxkTrZu0gW\r\nContent-Disposition: form-data; name=\"phone\"\r\n\r\n+1234567890\r\n------WebKitFormBoundary7MA4YWxkTrZu0gW\r\nContent-Disposition: form-data; name=\"file\"; filename=\"example.txt\"\r\nContent-Type: text/plain\r\n\r\nThis is the content of the file.\r\n------WebKitFormBoundary7MA4YWxkTrZu0gW--"
);

    assert(parser.parse(input, &result) == Status.OK)

    // request line
    assert(result.method == HttpMethod.POST)
    assert(result.path.equals($"/upload"))
    assert(result.version.equals($"HTTP/1.1"))

    // request headers
    assert(result.headers.size() == 3)
    assert(result.headers.getPtr(0).name.equals($"Host"))
    assert(result.headers.getPtr(0).values.equals($"example.com"))
    assert(result.headers.getPtr(1).name.equals($"Content-Type"))
    assert(result.headers.getPtr(1).values.equals($"multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW"))
    assert(result.headers.getPtr(2).name.equals($"Content-Length"))
    assert(result.headers.getPtr(2).values.equals($"356"))

    assert(result.bodyType == BodyType.MULTIPART_FORMDATA)
    assert(result.multipart.boundary.equals($"----WebKitFormBoundary7MA4YWxkTrZu0gW"))

    // parse the multipart body
    var bodyStr = input.substring(input.endIndexOf($"\r\n\r\n"))
    assert(parser.parseBody(bodyStr, &result) == Status.OK)

    assert(result.multipart.parts.size() == 4)

    var part0 = result.multipart.parts.getPtr(0)
    assert(part0.bodyType == BodyType.FORMDATA)
    assert(part0.formData.name.equals($"name"))
    assert(part0.formData.filename.length == 0)
    assert(part0.formData.value.equals($"John Doe"))

    var part1 = result.multipart.parts.getPtr(1)
    assert(part1.bodyType == BodyType.FORMDATA)
    assert(part1.formData.name.equals($"address"))
    assert(part1.formData.filename.length == 0)
    assert(part1.formData.value.equals($"123 Elm Street"))

    var part2 = result.multipart.parts.getPtr(2)
    assert(part2.bodyType == BodyType.FORMDATA)
    assert(part2.formData.name.equals($"phone"))
    assert(part2.formData.filename.length == 0)
    assert(part2.formData.value.equals($"+1234567890"))

    var part3 = result.multipart.parts.getPtr(3)
    assert(part3.bodyType == BodyType.FORMDATA)
    assert(part3.formData.name.equals($"file"))
    assert(part3.formData.filename.equals($"example.txt"))
    assert(part3.formData.value.equals($"This is the content of the file."))
}

// Bug 4: chunk size 0x80000000 would truncate to i32 min (-2147483648),
// which is < 0, so it slipped through the size < 1 guard before the fix.
// Now the range check must reject it as ERROR_INVALID_CHUNK.
@test
func testParseChunkSizeTruncation() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest;

    // 0x80000000 in hex followed by the mandatory CRLF terminator sequence.
    var input = StringInit("80000000\r\n0\r\n\r\n")
    var status = parser.parseChunk(input, &result)
    assert(status == Status.ERROR_HTTP_PARSING_INVALID_CHUNK)

    // Sanity-check: a normal small chunk still parses correctly.
    var result2: HttpRequest;
    var input2 = StringInit("5\r\nhello\r\n0\r\n\r\n")
    var status2 = parser.parseChunk(input2, &result2)
    assert(status2 == Status.OK)
    assert(result2.body.body.equalsString("hello"))
}

// Bug 5: a multipart part whose name or filename is a lone quote char (")
// has length 1.  Before the fix, length -= 2 would wrap to a huge value.
// After the fix the quotes are left in place when length < 2.
@test
func testParseMultipartSingleCharQuotedName() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest;

    // The name field value is a single quote — Content-Disposition: form-data; name="
    // (no closing quote, no semicolon — endIndex hits end-of-line, giving a 1-char slice).
    var input = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=--B\r\nContent-Length: 100\r\n\r\n----B\r\nContent-Disposition: form-data; name=\"\"\r\n\r\nval\r\n----B--"
);

    var status = parser.parse(input, &result)
    // Must not crash or produce a corrupted-length string — either OK or a
    // defined error is acceptable, but length must never be negative/huge.
    // Primary safety check: parsing must not crash or corrupt memory.
    // Don't assert parts.size() > 0; parser may skip or fail parts with
    // unusual disposition values, which is legitimate behaviour.
    if(status == Status.OK && result.multipart.parts.size() > 0) {
        var part = result.multipart.parts.getPtr(0)
        // After the fix length is either 0 (quotes stripped) or 2 (kept intact).
        assert(part.formData.name.length >= 0 && part.formData.name.length <= 2)
    }
}

// Bug 5 (filename variant): same underflow guard for the filename field.
@test
func testParseMultipartSingleCharQuotedFilename() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest;

    var input = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=--B\r\nContent-Length: 120\r\n\r\n----B\r\nContent-Disposition: form-data; name=\"file\"; filename=\"\"\r\nContent-Type: text/plain\r\n\r\ndata\r\n----B--"
);

    var status = parser.parse(input, &result)
    // Primary safety check: parsing must not crash or corrupt memory.
    // If the parser also returns a well-formed part, validate the filename
    // length; but we do NOT demand a specific part count because the parser
    // may legitimately reject or skip parts with unusual sub-headers.
    if(status == Status.OK && result.multipart.parts.size() > 0) {
        var part = result.multipart.parts.getPtr(0)
        assert(part.formData.filename.length >= 0 && part.formData.filename.length <= 2)
    }
}

// Bug 6: a multipart body section shorter than 4 bytes would cause
// body.length - 4 to wrap (unsigned underflow).  The fix returns
// ERROR_INVALID_MULTIPART instead.
@test
func testParseMultipartBodyTooShort() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest;

    // The body between the headers and the closing boundary is "ab" — only
    // 2 bytes, well under the 4-byte minimum needed to strip "\r\n--".
    var input = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=--B\r\nContent-Length: 60\r\n\r\n----B\r\nContent-Disposition: form-data; name=\"x\"\r\n\r\nab\r\n----B--"
);

    var status = parser.parse(input, &result)
    // Must not crash — either the body is accepted (edge-case tolerance) or
    // ERROR_INVALID_MULTIPART is returned.  It must never silently corrupt.
    assert(status == Status.ERROR_HTTP_PARSING_INVALID_MULTIPART || status == Status.OK)
}

// Bug fix: chunk end index was computed as (size + 3) instead of (index + 2 + size).
// For single-digit hex sizes index==1 so the two expressions coincide, masking the
// bug.  For any multi-digit hex size (index >= 2) the old formula reads one fewer
// byte per extra digit.
@test
func testParseChunkMultiDigitHexSize() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // "0a" is hex for 10.  index==2, so the old formula (size+3==13) would have
    // stopped at position 12, dropping the last byte ("9") of the payload.
    var result: HttpRequest;
    var input = StringInit("0a\r\n0123456789\r\n0\r\n\r\n")
    var status = parser.parseChunk(input, &result)
    assert(status == Status.OK)
    assert(result.body.body.equalsString("0123456789"))

    // Two chunks with multi-digit sizes.
    var result2: HttpRequest;
    var input2 = StringInit("05\r\nhello\r\n06\r\nworld!\r\n0\r\n\r\n")
    var status2 = parser.parseChunk(input2, &result2)
    assert(status2 == Status.OK)
    assert(result2.body.body.equalsString("helloworld!"))
}

// Bug fix: checkHeaderBody set bodyType=MULTIPART_FORMDATA before validating the
// boundary value.  A Content-Type of "multipart/form-data; boundary=" (empty value)
// now leaves bodyType as UNKNOWN rather than creating an empty-boundary multipart.
@test
func testParseMultipartEmptyBoundary() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Content-Type header with "boundary=" but no actual boundary value.
    var result: HttpRequest;
    var input = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=\r\nContent-Length: 10\r\n\r\nbody"
)
    var status = parser.parse(input, &result)
    // Must not crash.  When bodyType is MULTIPART_FORMDATA the boundary must be
    // non-empty; if boundary validation failed the bodyType must not be MULTIPART.
    assert(result.multipart.boundary.length > 0 || result.bodyType != BodyType.MULTIPART_FORMDATA)
}

// Fix 1: header value was truncated at the second colon.
// Any header whose value contains a colon (Date, Authorization, WWW-Authenticate,
// custom headers with URLs, etc.) previously lost everything after the second colon.
@test
func testHeaderValueWithColon() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest;
    var input = StringInit(
"GET / HTTP/1.1\r\nDate: Thu, 01 Jan 1970 00:00:00 GMT\r\nAuthorization: Bearer tok:en\r\nX-Custom: http://example.com/path\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.headers.size() == 3)
    assert(result.headers.getPtr(0).name.equals($"Date"))
    assert(result.headers.getPtr(0).values.equals($"Thu, 01 Jan 1970 00:00:00 GMT"))
    assert(result.headers.getPtr(1).name.equals($"Authorization"))
    assert(result.headers.getPtr(1).values.equals($"Bearer tok:en"))
    assert(result.headers.getPtr(2).name.equals($"X-Custom"))
    assert(result.headers.getPtr(2).values.equals($"http://example.com/path"))
}

// Fix 2 & 3: Transfer-Encoding and Connection token matching must be case-insensitive.
// RFC 7230 §3.2: header field values that are tokens are case-insensitive.
@test
func testTransferEncodingCaseInsensitive() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // "Chunked" (capital C) must set CHUNKED_ENCODING just like "chunked".
    var result: HttpRequest;
    var input = StringInit(
"POST /upload HTTP/1.1\r\nTransfer-Encoding: Chunked\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.flags & HttpFlags.CHUNKED_ENCODING)

    // "CHUNKED" (all caps).
    var result2: HttpRequest;
    var input2 = StringInit(
"POST /upload HTTP/1.1\r\nTransfer-Encoding: CHUNKED\r\n\r\n"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert(result2.flags & HttpFlags.CHUNKED_ENCODING)
}

@test
func testConnectionUpgradeCaseInsensitive() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Lowercase "upgrade" must still set UPGRADE_REQUEST.
    var result: HttpRequest;
    var input = StringInit(
"GET /ws HTTP/1.1\r\nConnection: upgrade\r\nUpgrade: websocket\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.flags & HttpFlags.UPGRADE_REQUEST)

    // Mixed case.
    var result2: HttpRequest;
    var input2 = StringInit(
"GET /ws HTTP/1.1\r\nConnection: Upgrade\r\nUpgrade: websocket\r\n\r\n"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert(result2.flags & HttpFlags.UPGRADE_REQUEST)
}

// Feature: Expect: 100-continue flag is parsed from request headers.
@test
func testParseExpectContinue() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Standard lowercase "100-continue" value.
    var result: HttpRequest;
    var input = StringInit(
"POST /upload HTTP/1.1\r\nHost: example.com\r\nExpect: 100-continue\r\nContent-Length: 5\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert((result.flags & HttpFlags.EXPECT_CONTINUE) != 0)

    // Case-insensitive variant.
    var result2: HttpRequest;
    var input2 = StringInit(
"POST /upload HTTP/1.1\r\nHost: example.com\r\nExpect: 100-Continue\r\nContent-Length: 5\r\n\r\n"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert((result2.flags & HttpFlags.EXPECT_CONTINUE) != 0)

    // No Expect header → flag must NOT be set.
    var result3: HttpRequest;
    memset(&result3, 0, sizeof(:HttpRequest))   // zero flags before parse
    var input3 = StringInit(
"POST /upload HTTP/1.1\r\nHost: example.com\r\nContent-Length: 5\r\n\r\n"
)
    assert(parser.parse(input3, &result3) == Status.OK)
    assert((result3.flags & HttpFlags.EXPECT_CONTINUE) == 0)
}

// Fix 4: When both Transfer-Encoding and Content-Length are present,
// Transfer-Encoding wins and Content-Length must be cleared (RFC 7230 §3.3.3).
@test
func testTransferEncodingTakesPrecedenceOverContentLength() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Request carries both headers; after parsing the TE flag must be set
    // and bodyLength must be 0 (CL cleared by the worker before chunk parsing).
    // We can only verify the flag state here — the CL-clearing happens in the
    // worker when chunked is detected.  So assert both flags are set by the parser
    // and that the bodyLength reflects the Content-Length value before clearing.
    var result: HttpRequest;
    var input = StringInit(
"POST /data HTTP/1.1\r\nTransfer-Encoding: chunked\r\nContent-Length: 99\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.flags & HttpFlags.CHUNKED_ENCODING)
    // The worker strips CONTENT_LENGTH_PROVIDED when CHUNKED_ENCODING is set.
    // At parse time both flags may be present; the important invariant is that
    // CHUNKED_ENCODING is recognized regardless of CL being present.
    assert(result.flags & HttpFlags.CONTENT_LENGTH_PROVIDED)  // set by parser
    assert(result.bodyLength == 99)                           // will be zeroed by worker
}

// Fix B (parser): RFC 7230 §5.3.2 — request-target in absolute-form (full URI).
// Proxies and some clients send "GET http://example.com/path HTTP/1.1".
// The parser must strip the scheme and authority so routing sees "/path".
@test
func testAbsoluteFormUriStripping() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Basic case: scheme + authority + path.
    var result: HttpRequest;
    var input = StringInit(
"GET http://example.com/some/path HTTP/1.1\r\nHost: example.com\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.path.equals($"/some/path"))
    assert(result.scheme.equals($"http"))

    // With query string: scheme+authority must be stripped, query preserved.
    var result2: HttpRequest;
    var input2 = StringInit(
"GET http://example.com/search?q=hello&page=2 HTTP/1.1\r\nHost: example.com\r\n\r\n"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert(result2.path.equals($"/search"))
    assert(result2.query.equals($"q=hello&page=2"))

    // No path after authority: must default to "/".
    var result3: HttpRequest;
    var input3 = StringInit(
"GET http://example.com HTTP/1.1\r\nHost: example.com\r\n\r\n"
)
    assert(parser.parse(input3, &result3) == Status.OK)
    assert(result3.path.equals($"/"))

    // Normal origin-form must still work unchanged.
    var result4: HttpRequest;
    var input4 = StringInit(
"GET /origin/path HTTP/1.1\r\nHost: example.com\r\n\r\n"
)
    assert(parser.parse(input4, &result4) == Status.OK)
    assert(result4.path.equals($"/origin/path"))
}

// Fix A (parser): Connection: keep-alive must set KEEP_ALIVE_REQUESTED flag.
// HTTP/1.0 clients opt in to keep-alive by sending this header explicitly.
@test
func testKeepAliveRequestedFlag() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Explicit keep-alive must set the flag.
    var result: HttpRequest;
    var input = StringInit(
"GET / HTTP/1.0\r\nHost: example.com\r\nConnection: keep-alive\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert((result.flags & HttpFlags.KEEP_ALIVE_REQUESTED) != 0)
    // Must NOT set DISABLE_KEEP_ALIVE — only "close" sets that.
    assert((result.flags & HttpFlags.DISABLE_KEEP_ALIVE) == 0)

    // "Connection: close" must NOT set KEEP_ALIVE_REQUESTED.
    var result2: HttpRequest;
    var input2 = StringInit(
"GET / HTTP/1.1\r\nHost: example.com\r\nConnection: close\r\n\r\n"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert((result2.flags & HttpFlags.KEEP_ALIVE_REQUESTED) == 0)
    assert((result2.flags & HttpFlags.DISABLE_KEEP_ALIVE) != 0)

    // Combined "Connection: keep-alive, upgrade" — both flags set.
    var result3: HttpRequest;
    var input3 = StringInit(
"GET /ws HTTP/1.1\r\nHost: example.com\r\nConnection: keep-alive, upgrade\r\n\r\n"
)
    assert(parser.parse(input3, &result3) == Status.OK)
    assert((result3.flags & HttpFlags.KEEP_ALIVE_REQUESTED) != 0)
    assert((result3.flags & HttpFlags.UPGRADE_REQUEST) != 0)
}

// Fix A (parser): Expect header with an unknown value must set EXPECT_UNKNOWN.
// RFC 7231 §5.1.1: server MUST respond 417 for unrecognised Expect values.
@test
func testExpectUnknownFlag() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Unknown Expect value must set EXPECT_UNKNOWN and not EXPECT_CONTINUE.
    var result: HttpRequest;
    var input = StringInit(
"POST /upload HTTP/1.1\r\nHost: example.com\r\nExpect: i-can-fly\r\nContent-Length: 5\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert((result.flags & HttpFlags.EXPECT_UNKNOWN) != 0)
    assert((result.flags & HttpFlags.EXPECT_CONTINUE) == 0)

    // "100-continue" must NOT set EXPECT_UNKNOWN.
    var result2: HttpRequest;
    var input2 = StringInit(
"POST /upload HTTP/1.1\r\nHost: example.com\r\nExpect: 100-continue\r\nContent-Length: 5\r\n\r\n"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert((result2.flags & HttpFlags.EXPECT_UNKNOWN) == 0)
    assert((result2.flags & HttpFlags.EXPECT_CONTINUE) != 0)
}

// Fix C (parser): chunk data completeness — must return CHUNK_INCOMPLETE when
// the declared chunk size exceeds the bytes actually present in the buffer.
@test
func testChunkDataCompleteness() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Declare 256-byte chunk ("100" in hex) but only send the terminator sequence.
    // The buffer ends with \r\n\r\n (passes the endsWith guard) but the data for
    // the first chunk is nowhere near 256 bytes.
    var result: HttpRequest;
    var input = StringInit("100\r\n0\r\n\r\n")
    var status = parser.parseChunk(input, &result)
    assert(status == Status.ERROR_HTTP_PARSING_CHUNK_INCOMPLETE)

    // Sanity: a fully-buffered chunk must still parse correctly.
    var result2: HttpRequest;
    var input2 = StringInit("5\r\nhello\r\n0\r\n\r\n")
    var status2 = parser.parseChunk(input2, &result2)
    assert(status2 == Status.OK)
    assert(result2.body.body.equalsString("hello"))
}

// Fix D (parser): multipart boundary quoted with double-quotes must be stripped.
// RFC 2046 §5.1.1 allows boundary=<quoted-string>; the quotes are not part of
// the delimiter.
@test
func testQuotedMultipartBoundary() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Quoted boundary — quotes must be stripped before storing.
    var result: HttpRequest;
    var input = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=\"----MyBoundary\"\r\nContent-Length: 100\r\n\r\n"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.bodyType == BodyType.MULTIPART_FORMDATA)
    // Boundary must be the unquoted value.
    assert(result.multipart.boundary.equals($"----MyBoundary"))

    // Unquoted boundary must still work unchanged.
    var result2: HttpRequest;
    var input2 = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=----MyBoundary\r\nContent-Length: 100\r\n\r\n"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert(result2.bodyType == BodyType.MULTIPART_FORMDATA)
    assert(result2.multipart.boundary.equals($"----MyBoundary"))
}

// Fix 2: duplicate Content-Length headers with different values must set the
// CONFLICTING_CONTENT_LENGTH flag so the worker can reject with 400.
// RFC 7230 §3.3.2.
@test
func testDuplicateContentLengthConflict() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Differing values — must set the conflict flag.
    var result: HttpRequest;
    var input = StringInit(
"POST /submit HTTP/1.1\r\nHost: example.com\r\nContent-Length: 5\r\nContent-Length: 10\r\n\r\nhello"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert((result.flags & HttpFlags.CONFLICTING_CONTENT_LENGTH) != 0)

    // Identical duplicates are benign — no conflict flag.
    var result2: HttpRequest;
    var input2 = StringInit(
"POST /submit HTTP/1.1\r\nHost: example.com\r\nContent-Length: 5\r\nContent-Length: 5\r\n\r\nhello"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert((result2.flags & HttpFlags.CONFLICTING_CONTENT_LENGTH) == 0)
    assert(result2.bodyLength == 5)

    // Single Content-Length — baseline, no conflict flag.
    var result3: HttpRequest;
    var input3 = StringInit(
"POST /submit HTTP/1.1\r\nHost: example.com\r\nContent-Length: 7\r\n\r\nabcdefg"
)
    assert(parser.parse(input3, &result3) == Status.OK)
    assert((result3.flags & HttpFlags.CONFLICTING_CONTENT_LENGTH) == 0)
    assert(result3.bodyLength == 7)
}

// Fix 3: chunked requests with RFC 7230 §4.1.2 trailer headers must be
// accepted — trailers must be skipped rather than causing ERROR_INVALID_CHUNK.
@test
func testChunkWithTrailers() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Single chunk followed by a trailer header and terminating CRLF.
    var result: HttpRequest;
    var input = StringInit("5\r\nhello\r\n0\r\nX-Checksum: abc123\r\n\r\n")
    var status = parser.parseChunk(input, &result)
    assert(status == Status.OK)
    assert(result.body.body.equalsString("hello"))

    // Multiple trailers.
    var result2: HttpRequest;
    var input2 = StringInit("3\r\nfoo\r\n0\r\nX-A: 1\r\nX-B: 2\r\n\r\n")
    var status2 = parser.parseChunk(input2, &result2)
    assert(status2 == Status.OK)
    assert(result2.body.body.equalsString("foo"))

    // No trailers — still OK.
    var result3: HttpRequest;
    var input3 = StringInit("5\r\nworld\r\n0\r\n\r\n")
    var status3 = parser.parseChunk(input3, &result3)
    assert(status3 == Status.OK)
    assert(result3.body.body.equalsString("world"))
}

// Bug 3+4 (parser): Content-Type matching must be case-insensitive and must
// ignore parameters such as "; charset=utf-8".
// RFC 7231 §3.1.1.1: media-type names are case-insensitive.
@test
func testContentTypeCaseInsensitive() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // Upper-case type must still detect JSON.
    var result: HttpRequest;
    var input = StringInit(
"POST /api HTTP/1.1\r\nHost: example.com\r\nContent-Type: APPLICATION/JSON\r\nContent-Length: 2\r\n\r\n{}"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.bodyType == BodyType.JSON)

    // Mixed-case form-urlencoded must be detected.
    var result2: HttpRequest;
    var input2 = StringInit(
"POST /api HTTP/1.1\r\nHost: example.com\r\nContent-Type: Application/X-WWW-Form-Urlencoded\r\nContent-Length: 5\r\n\r\na=b&c"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert(result2.bodyType == BodyType.FORM_URLENCODED)

    // Mixed-case multipart must be detected and boundary extracted.
    var result3: HttpRequest;
    var input3 = StringInit(
"POST /api HTTP/1.1\r\nHost: example.com\r\nContent-Type: Multipart/Form-Data; boundary=----Bound\r\nContent-Length: 10\r\n\r\n"
)
    assert(parser.parse(input3, &result3) == Status.OK)
    assert(result3.bodyType == BodyType.MULTIPART_FORMDATA)
    assert(result3.multipart.boundary.equals($"----Bound"))
}

@test
func testContentTypeWithParameters() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // "application/json; charset=utf-8" must be recognised as JSON.
    var result: HttpRequest;
    var input = StringInit(
"POST /api HTTP/1.1\r\nHost: example.com\r\nContent-Type: application/json; charset=utf-8\r\nContent-Length: 2\r\n\r\n{}"
)
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.bodyType == BodyType.JSON)

    // "application/x-www-form-urlencoded; charset=UTF-8" must be recognised.
    var result2: HttpRequest;
    var input2 = StringInit(
"POST /api HTTP/1.1\r\nHost: example.com\r\nContent-Type: application/x-www-form-urlencoded; charset=UTF-8\r\nContent-Length: 3\r\n\r\na=b"
)
    assert(parser.parse(input2, &result2) == Status.OK)
    assert(result2.bodyType == BodyType.FORM_URLENCODED)

    // Combined: upper-case type with a parameter.
    var result3: HttpRequest;
    var input3 = StringInit(
"POST /api HTTP/1.1\r\nHost: example.com\r\nContent-Type: APPLICATION/JSON;charset=utf-8\r\nContent-Length: 2\r\n\r\n{}"
)
    assert(parser.parse(input3, &result3) == Status.OK)
    assert(result3.bodyType == BodyType.JSON)
}

// ---------------------------------------------------------------------------
// HTTP method parsing
// ---------------------------------------------------------------------------

func assertMethodParsed(method: *const char, expected: HttpMethod) {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var buf: [64]char
    var len = snprintf(buf, 64_usize, "%s / HTTP/1.1\r\n\r\n", method)
    var input = String{.buffer = buf as (*const char), .length = len}
    assert(parser.parse(input, &result) == Status.OK)
    assert(result.method == expected)
}

// Every method token the switch table must recognise, plus an unknown token
// that must map to HttpMethod.INVALID.
@test
func testAllHttpMethods() {
    assertMethodParsed("GET",     HttpMethod.GET)
    assertMethodParsed("POST",    HttpMethod.POST)
    assertMethodParsed("PUT",     HttpMethod.PUT)
    assertMethodParsed("HEAD",    HttpMethod.HEAD)
    assertMethodParsed("DELETE",  HttpMethod.DELETE)
    assertMethodParsed("PATCH",   HttpMethod.PATCH)
    assertMethodParsed("OPTIONS", HttpMethod.OPTIONS)
    assertMethodParsed("TRACE",   HttpMethod.TRACE)
    assertMethodParsed("CONNECT", HttpMethod.CONNECT)
    assertMethodParsed("FROBBLE", HttpMethod.INVALID)   // unknown → INVALID
}

// ---------------------------------------------------------------------------
// Accept-Encoding flags
// ---------------------------------------------------------------------------

// Accept-Encoding: gzip must set ACCEPT_GZIP_ENCODING.
// Accept-Encoding: deflate must set ACCEPT_DEFLATE_ENCODING.
// Both tokens in a single header must set both flags.
@test
func testAcceptEncodingFlags() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // gzip only
    var r1: HttpRequest
    var i1 = StringInit("GET / HTTP/1.1\r\nAccept-Encoding: gzip\r\n\r\n")
    assert(parser.parse(i1, &r1) == Status.OK)
    assert((r1.flags & HttpFlags.ACCEPT_GZIP_ENCODING) != 0)
    assert((r1.flags & HttpFlags.ACCEPT_DEFLATE_ENCODING) == 0)

    // deflate only
    var r2: HttpRequest
    var i2 = StringInit("GET / HTTP/1.1\r\nAccept-Encoding: deflate\r\n\r\n")
    assert(parser.parse(i2, &r2) == Status.OK)
    assert((r2.flags & HttpFlags.ACCEPT_GZIP_ENCODING) == 0)
    assert((r2.flags & HttpFlags.ACCEPT_DEFLATE_ENCODING) != 0)

    // Both in a single header value (typical browser header)
    var r3: HttpRequest
    var i3 = StringInit("GET / HTTP/1.1\r\nAccept-Encoding: gzip, deflate, br\r\n\r\n")
    assert(parser.parse(i3, &r3) == Status.OK)
    assert((r3.flags & HttpFlags.ACCEPT_GZIP_ENCODING) != 0)
    assert((r3.flags & HttpFlags.ACCEPT_DEFLATE_ENCODING) != 0)

    // Case-insensitive: "Gzip" and "Deflate"
    var r4: HttpRequest
    var i4 = StringInit("GET / HTTP/1.1\r\nAccept-Encoding: Gzip, Deflate\r\n\r\n")
    assert(parser.parse(i4, &r4) == Status.OK)
    assert((r4.flags & HttpFlags.ACCEPT_GZIP_ENCODING) != 0)
    assert((r4.flags & HttpFlags.ACCEPT_DEFLATE_ENCODING) != 0)
}

// ---------------------------------------------------------------------------
// Content-Encoding flags
// ---------------------------------------------------------------------------

// Content-Encoding on a received request body sets the appropriate decode flag.
@test
func testContentEncodingFlags() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var r1: HttpRequest
    var i1 = StringInit("POST /upload HTTP/1.1\r\nContent-Encoding: gzip\r\nContent-Length: 0\r\n\r\n")
    assert(parser.parse(i1, &r1) == Status.OK)
    assert((r1.flags & HttpFlags.GZIP_ENCODING) != 0)
    assert((r1.flags & HttpFlags.DEFLATE_ENCODING) == 0)

    var r2: HttpRequest
    var i2 = StringInit("POST /upload HTTP/1.1\r\nContent-Encoding: deflate\r\nContent-Length: 0\r\n\r\n")
    assert(parser.parse(i2, &r2) == Status.OK)
    assert((r2.flags & HttpFlags.DEFLATE_ENCODING) != 0)
    assert((r2.flags & HttpFlags.GZIP_ENCODING) == 0)

    var r3: HttpRequest
    var i3 = StringInit("POST /upload HTTP/1.1\r\nContent-Encoding: compressed\r\nContent-Length: 0\r\n\r\n")
    assert(parser.parse(i3, &r3) == Status.OK)
    assert((r3.flags & HttpFlags.COMPRESSED_ENCODING) != 0)

    // Case insensitive: "GZIP"
    var r4: HttpRequest
    var i4 = StringInit("POST /upload HTTP/1.1\r\nContent-Encoding: GZIP\r\nContent-Length: 0\r\n\r\n")
    assert(parser.parse(i4, &r4) == Status.OK)
    assert((r4.flags & HttpFlags.GZIP_ENCODING) != 0)
}

// ---------------------------------------------------------------------------
// SSE flag
// ---------------------------------------------------------------------------

// "Accept: text/event-stream" must set the SSE flag.
@test
func testSseFlag() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var r1: HttpRequest
    var i1 = StringInit("GET /events HTTP/1.1\r\nAccept: text/event-stream\r\n\r\n")
    assert(parser.parse(i1, &r1) == Status.OK)
    assert((r1.flags & HttpFlags.SSE) != 0)

    // SSE token within a multi-type Accept header
    var r2: HttpRequest
    var i2 = StringInit("GET /events HTTP/1.1\r\nAccept: text/html,text/event-stream\r\n\r\n")
    assert(parser.parse(i2, &r2) == Status.OK)
    assert((r2.flags & HttpFlags.SSE) != 0)

    // No Accept header → SSE must NOT be set
    var r3: HttpRequest
    var i3 = StringInit("GET /events HTTP/1.1\r\n\r\n")
    assert(parser.parse(i3, &r3) == Status.OK)
    assert((r3.flags & HttpFlags.SSE) == 0)
}

// ---------------------------------------------------------------------------
// WebSocket protocol flag
// ---------------------------------------------------------------------------

// "Upgrade: websocket" must set WEB_SOCKET_PROTOCOL (in addition to
// UPGRADE_REQUEST that "Connection: upgrade" sets).
@test
func testWebSocketProtocolFlag() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var r1: HttpRequest
    var i1 = StringInit(
"GET /ws HTTP/1.1\r\nHost: example.com\r\nConnection: Upgrade\r\nUpgrade: websocket\r\nSec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n\r\n"
)
    assert(parser.parse(i1, &r1) == Status.OK)
    assert((r1.flags & HttpFlags.WEB_SOCKET_PROTOCOL) != 0)
    assert((r1.flags & HttpFlags.UPGRADE_REQUEST) != 0)

    // "Upgrade: WebSocket" (mixed case) must also set the flag.
    var r2: HttpRequest
    var i2 = StringInit(
"GET /ws HTTP/1.1\r\nConnection: Upgrade\r\nUpgrade: WebSocket\r\n\r\n"
)
    assert(parser.parse(i2, &r2) == Status.OK)
    assert((r2.flags & HttpFlags.WEB_SOCKET_PROTOCOL) != 0)

    // "Upgrade: h2c" (not websocket) must NOT set WEB_SOCKET_PROTOCOL.
    var r3: HttpRequest
    var i3 = StringInit(
"GET / HTTP/1.1\r\nConnection: Upgrade\r\nUpgrade: h2c\r\n\r\n"
)
    assert(parser.parse(i3, &r3) == Status.OK)
    assert((r3.flags & HttpFlags.WEB_SOCKET_PROTOCOL) == 0)
    assert((r3.flags & HttpFlags.UPGRADE_REQUEST) != 0)   // Connection: upgrade still fires
}

// ---------------------------------------------------------------------------
// JSON body type detection
// ---------------------------------------------------------------------------

// Content-Type: application/json must set bodyType = JSON.
@test
func testJsonBodyTypeDetection() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var r1: HttpRequest
    var i1 = StringInit(
"POST /api HTTP/1.1\r\nContent-Type: application/json\r\nContent-Length: 2\r\n\r\n{}"
)
    assert(parser.parse(i1, &r1) == Status.OK)
    assert(r1.bodyType == BodyType.JSON)

    // Unrecognised Content-Type must leave bodyType = UNKNOWN
    var r2: HttpRequest
    var i2 = StringInit(
"POST /api HTTP/1.1\r\nContent-Type: application/octet-stream\r\nContent-Length: 4\r\n\r\ndata"
)
    assert(parser.parse(i2, &r2) == Status.OK)
    assert(r2.bodyType == BodyType.UNKNOWN)
}

// ---------------------------------------------------------------------------
// Malformed request line
// ---------------------------------------------------------------------------

@test
func testMalformedRequestLine() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // No CRLF anywhere — can't find the end of the request line.
    var r1: HttpRequest
    var i1 = StringInit("GET / HTTP/1.1")
    assert(parser.parse(i1, &r1) == Status.ERROR_HTTP_PARSING_INVALID_REQUEST_LINE)

    // No space between method and path.
    var r2: HttpRequest
    var i2 = StringInit("GET/path HTTP/1.1\r\n\r\n")
    assert(parser.parse(i2, &r2) == Status.ERROR_HTTP_PARSING_INVALID_REQUEST_LINE)

    // Only one space — no second space to delimit path from version.
    var r3: HttpRequest
    var i3 = StringInit("GET /pathHTTP/1.1\r\n\r\n")
    assert(parser.parse(i3, &r3) == Status.ERROR_HTTP_PARSING_INVALID_REQUEST_LINE)
}

// ---------------------------------------------------------------------------
// Header without colon
// ---------------------------------------------------------------------------

// A header line that lacks ':' must cause ERROR_INVALID_HEADER_PARAM.
@test
func testHeaderWithoutColon() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var r1: HttpRequest
    var i1 = StringInit("GET / HTTP/1.1\r\nBadHeaderNoColon\r\n\r\n")
    assert(parser.parse(i1, &r1) == Status.ERROR_HTTP_PARSING_INVALID_HEADER_PARAM)
}

// ==========================================================================
// Unhappy-path tests
// ==========================================================================

// ---------------------------------------------------------------------------
// Chunk parser unhappy paths
// ---------------------------------------------------------------------------

// Chunk data not followed by CRLF must return ERROR_INVALID_CHUNK.
// The whole input ends with \r\n\r\n so the outer guard passes, but the
// byte after "hello" is 'X' rather than '\r' → inner check fires.
@test
func testChunkMissingTrailingCrLf() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var input = StringInit("5\r\nhelloX\r\n0\r\n\r\n")
    assert(parser.parseChunk(input, &result) == Status.ERROR_HTTP_PARSING_INVALID_CHUNK)
}

// RFC 7230 §4.1.1 chunk extensions (";name=value" after the size) must be
// silently ignored — parseHex() stops at ';' so only the hex digits count.
@test
func testChunkSizeWithExtension() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var input = StringInit("5; ext=value\r\nhello\r\n0\r\n\r\n")
    assert(parser.parseChunk(input, &result) == Status.OK)
    assert(result.body.body.equalsString("hello"))
}

// A zero-length terminal chunk with no trailers must produce an empty body
// and return OK — it is not an error.
@test
func testZeroSizeChunkEmptyBody() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var input = StringInit("0\r\n\r\n")
    assert(parser.parseChunk(input, &result) == Status.OK)
    assert(result.body.body.length == 0)
}

// Uppercase hex digits (A-F) in the chunk size line must decode correctly.
@test
func testChunkUppercaseHex() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // "A" is 10 in hex; body must be exactly 10 bytes.
    var result: HttpRequest
    var input = StringInit("A\r\n0123456789\r\n0\r\n\r\n")
    assert(parser.parseChunk(input, &result) == Status.OK)
    assert(result.body.body.equalsString("0123456789"))
}

// Two consecutive chunks where the first is well-formed but the second
// is missing its trailing CRLF must return ERROR_INVALID_CHUNK.
@test
func testChunkSecondChunkMissingCrLf() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // First chunk "hi" is correct; second "3\r\nbad" is not followed by CRLF.
    var result: HttpRequest
    var input = StringInit("2\r\nhi\r\n3\r\nbadX\r\n0\r\n\r\n")
    assert(parser.parseChunk(input, &result) == Status.ERROR_HTTP_PARSING_INVALID_CHUNK)
}

// ---------------------------------------------------------------------------
// Form-urlencoded body unhappy paths
// ---------------------------------------------------------------------------

// A form body parameter with no '=' separator is treated as a name with an
// empty value — the same behaviour as query-string parsing.
// (The split("=") iterator yields two elements "name" and "" for "name",
// so the second hasNext() guard passes and no error is raised.)
@test
func testFormUrlencodedBodyBareParam() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    // "name" with no '=' — parsed as name="" value (not an error).
    var result: HttpRequest
    var hi = StringInit(
"POST /submit HTTP/1.1\r\nContent-Type: application/x-www-form-urlencoded\r\nContent-Length: 4\r\n\r\n"
)
    assert(parser.parse(hi, &result) == Status.OK)
    assert(result.bodyType == BodyType.FORM_URLENCODED)
    assert(parser.parseBody(StringInit("name"), &result) == Status.OK)
    assert(result.formParams.size() == 1)
    assert(result.formParams.getPtr(0).name.equalsString("name"))
}

// Double-ampersand (&&) produces an empty token that must be silently skipped;
// parsing must not error and must only yield the two real parameters.
@test
func testFormUrlencodedDoubleAmpersand() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var hi = StringInit(
"POST /submit HTTP/1.1\r\nContent-Type: application/x-www-form-urlencoded\r\nContent-Length: 17\r\n\r\n"
)
    assert(parser.parse(hi, &result) == Status.OK)
    assert(parser.parseBody(StringInit("a=1&&b=2"), &result) == Status.OK)
    assert(result.formParams.size() == 2)
    assert(result.formParams.getPtr(0).name.equalsString("a"))
    assert(result.formParams.getPtr(1).name.equalsString("b"))
}

// ---------------------------------------------------------------------------
// JSON body unhappy paths
// ---------------------------------------------------------------------------

// When Content-Type is application/json but the body cannot be parsed as JSON,
// parseBody must set bodyType = MALFORMED_INPUT (it still returns OK).
@test
func testMalformedJsonBodySetsType() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var hi = StringInit(
"POST /api HTTP/1.1\r\nContent-Type: application/json\r\nContent-Length: 8\r\n\r\n"
)
    assert(parser.parse(hi, &result) == Status.OK)
    assert(result.bodyType == BodyType.JSON)

    assert(parser.parseBody(StringInit("not json"), &result) == Status.OK)
    assert(result.bodyType == BodyType.MALFORMED_INPUT)
}

// An empty body with Content-Type application/json must NOT trigger MALFORMED_INPUT
// (the guard is `input.length > 0`).
@test
func testEmptyJsonBodyNotMalformed() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var hi = StringInit(
"POST /api HTTP/1.1\r\nContent-Type: application/json\r\nContent-Length: 0\r\n\r\n"
)
    assert(parser.parse(hi, &result) == Status.OK)
    assert(result.bodyType == BodyType.JSON)

    assert(parser.parseBody(StringInit(""), &result) == Status.OK)
    assert(result.bodyType == BodyType.JSON)  // not MALFORMED — body was empty
}

// ---------------------------------------------------------------------------
// Multipart body unhappy paths
// ---------------------------------------------------------------------------

// A multipart body that does not start with "--" must return
// ERROR_INVALID_MULTIPART_BOUNDARY.
@test
func testMultipartBodyMissingLeadingDashes() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var hi = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=myboundary\r\nContent-Length: 20\r\n\r\n"
)
    assert(parser.parse(hi, &result) == Status.OK)
    assert(result.bodyType == BodyType.MULTIPART_FORMDATA)

    assert(parser.parseBody(StringInit("NotBoundary\r\n"), &result) == Status.ERROR_HTTP_PARSING_INVALID_MULTIPART_BOUNDARY)
}

// A multipart body that starts with "--" but uses a wrong boundary string
// must return ERROR_INVALID_MULTIPART_BOUNDARY (endIndexOf returns -1).
@test
func testMultipartBodyWrongBoundary() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var hi = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=myboundary\r\nContent-Length: 20\r\n\r\n"
)
    assert(parser.parse(hi, &result) == Status.OK)

    var body = StringInit("--wrongboundary\r\nContent-Disposition: form-data; name=\"x\"\r\n\r\nval\r\n--wrongboundary--")
    assert(parser.parseBody(body, &result) == Status.ERROR_HTTP_PARSING_INVALID_MULTIPART_BOUNDARY)
}

// A part header inside a multipart body that has no ':' separator must return
// ERROR_INVALID_MULTIPART_HEADER.
@test
func testMultipartPartHeaderWithoutColon() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var hi = StringInit(
"POST /upload HTTP/1.1\r\nContent-Type: multipart/form-data; boundary=myboundary\r\nContent-Length: 60\r\n\r\n"
)
    assert(parser.parse(hi, &result) == Status.OK)

    // "BadHeaderNoColon" has no ':' → ERROR_INVALID_MULTIPART_HEADER
    var body = StringInit("--myboundary\r\nBadHeaderNoColon\r\n\r\nvalue\r\n--myboundary--")
    assert(parser.parseBody(body, &result) == Status.ERROR_HTTP_PARSING_INVALID_MULTIPART_HEADER)
}

// ---------------------------------------------------------------------------
// Content-Length edge cases
// ---------------------------------------------------------------------------

// RFC 7230 §3.3.2: a non-numeric Content-Length must be rejected with an error.
@test
func testNonNumericContentLength() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var input = StringInit("GET / HTTP/1.1\r\nContent-Length: abc\r\n\r\n")
    assert(parser.parse(input, &result) == Status.ERROR_INVALID_CONTENT_LENGTH)
}

// A very large Content-Length that overflows i32 must be clamped to 0 by
// the MAX(0, ...) guard and must not crash.
@test
func testOverflowContentLength() {
    var parser = HttpParser{}
    parser.init(defaultAllocator)

    var result: HttpRequest
    var input = StringInit("GET / HTTP/1.1\r\nContent-Length: 99999999999999999999\r\n\r\n")
    assert(parser.parse(input, &result) == Status.ERROR_INVALID_CONTENT_LENGTH)
}
