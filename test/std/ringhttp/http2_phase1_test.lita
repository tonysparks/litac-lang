// Phase 1 smoke test for HTTP/2 cleartext (h2c) support.
// Verifies via raw sockets that the server completes the HTTP/2 settings handshake.

import "std/libc"
import "std/assert"
import "std/mem"
import "std/thread"
import "std/thread/barrier"
import "std/string"
import "std/string/builder"

import "std/net/posix_socket"
import "std/ringhttp"


@raw("""
#include <sys/socket.h>
#include <sys/time.h>
void _h2p1_setRecvTimeout(int fd, int seconds) {
    struct timeval tv = { seconds, 0 };
    setsockopt(fd, SOL_SOCKET, SO_RCVTIMEO, (const void*)&tv, sizeof(tv));
}
""");
@foreign func _h2p1_setRecvTimeout(fd: i32, seconds: i32);

// ---------------------------------------------------------------------------
// Minimal HTTP handler
// ---------------------------------------------------------------------------

func HelloHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.body.append("hello")
    return 1
}

// ---------------------------------------------------------------------------
// Server thread
// ---------------------------------------------------------------------------

public struct H2TestServer {
    config:  *HttpConfig
    barrier: Barrier
}

func ServerThread(arg: *void) : i32 {
    var ts = arg as (*H2TestServer)
    var server = HttpServer{}
    server.init(ts.config)
    server.addHttpController(HttpMethod.GET, "/hello", null, HttpController{.callback = HelloHandler})
    ts.barrier.wait()
    var status = server.start()
    defer server.close()
    return 0
}

// ---------------------------------------------------------------------------
// Raw socket helpers
// ---------------------------------------------------------------------------

func rawConnect(port: u16) : i32 {
    var fd = socket(AF_INET, SOCK_STREAM, 0)
    if(fd < 0) {
        return -1
    }

    var addr: sockaddr_in;
    memset(&addr, 0, sizeof(:sockaddr_in))
    addr.sin_family = AF_INET
    addr.sin_port   = htons(port)
    inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr)

    if(connect(fd, (&addr) as (*sockaddr), sizeof(:sockaddr_in) as (socklen_t)) < 0) {
        close(fd)
        return -1
    }
    _h2p1_setRecvTimeout(fd, 10)
    return fd
}

func writeAll(fd: i32, buf: *char, n: i32) : bool {
    var sent = 0
    while(sent < n) {
        var r = send(fd, (buf + sent) as (*void), (n - sent) as (usize), 0)
        if(r <= 0) {
            return false
        }
        sent += r as (i32)
    }
    return true
}

func readAtLeast(fd: i32, buf: *char, minBytes: i32, bufSize: i32) : i32 {
    var total = 0
    while(total < minBytes) {
        var r = recv(fd, (buf + total) as (*void), (bufSize - total) as (usize), 0)
        if(r <= 0) {
            break
        }
        total += r as (i32)
    }
    return total
}

// ---------------------------------------------------------------------------
// Test: HTTP/2 settings handshake over cleartext (h2c)
// ---------------------------------------------------------------------------

@test("http2_settings_handshake")
func testHttp2SettingsHandshake() {
    var config = HttpConfig {
        .allocator             = defaultAllocator,
        .port                  = 9191_u16,
        .numThreads            = 2,
        .maxPoolSize           = 16,
        .keepAliveTimeoutInSec = 5,
        .isLogEnabled          = false,
    }

    var ts = H2TestServer{ .config = &config }
    ts.barrier.init(2)

    var thread = Thread{}
    assert(thread.create(ServerThread, &ts) == ThreadStatus.SUCCESS)
    ts.barrier.wait()
    ThreadSleepMSec(200)

    var fd = rawConnect(9191_u16)
    assert(fd >= 0)

    // -------------------------------------------------------------------
    // Send: client connection preface + empty SETTINGS frame
    // -------------------------------------------------------------------
    // Preface: "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n" (24 bytes)
    var preface: [24]char;
    var prefaceStr = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    memcpy(preface, prefaceStr as (*const void), 24_usize)
    assert(writeAll(fd, preface, 24))

    // Empty SETTINGS frame: 9-byte header, payload length = 0, type = 0x4, flags = 0
    var clientSettings: [9]char;
    clientSettings[0] = 0_i8   // length[0] (MSB)
    clientSettings[1] = 0_i8   // length[1]
    clientSettings[2] = 0_i8   // length[2] (LSB) → payload = 0 bytes
    clientSettings[3] = 4_i8   // type = SETTINGS (0x4)
    clientSettings[4] = 0_i8   // flags = none
    clientSettings[5] = 0_i8   // stream_id (big-endian 31-bit) = 0
    clientSettings[6] = 0_i8
    clientSettings[7] = 0_i8
    clientSettings[8] = 0_i8
    assert(writeAll(fd, clientSettings, 9))

    // -------------------------------------------------------------------
    // Read: expect at least 18 bytes from the server:
    //   offset 0: server SETTINGS  (9 bytes, type=0x4, flags=0x0)
    //   offset 9: SETTINGS ACK     (9 bytes, type=0x4, flags=0x1)
    // -------------------------------------------------------------------
    var buf: [256]char;
    var n = readAtLeast(fd, buf, 18, 256)
    assert(n >= 18)

    // Server SETTINGS at offset 0
    var srvSettingsType  = buf[3] as (i32)
    var srvSettingsFlags = buf[4] as (i32)
    assert(srvSettingsType  == 0x4)  // SETTINGS
    assert(srvSettingsFlags == 0x0)  // not an ACK

    // SETTINGS ACK at offset 9
    var srvAckType  = buf[12] as (i32)
    var srvAckFlags = buf[13] as (i32)
    assert(srvAckType  == 0x4)  // SETTINGS
    assert(srvAckFlags == 0x1)  // ACK flag set

    close(fd)
}
