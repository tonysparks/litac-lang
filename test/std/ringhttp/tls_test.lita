// TLS + ALPN integration tests for ringhttp.
//
// Starts ringhttp with tlsCertFile/tlsKeyFile set (self-signed cert in test/certs/).
// Verifies that:
//   - A curl client with --http2 (ALPN) negotiates h2 and gets a 200
//   - A curl client without --http2 falls back to http/1.1 and gets a 200
//   - A raw TLS connection that offers only "http/1.1" in ALPN gets HTTP/1.1
//
// Uses the std/http/http Http client (which sets CURLOPT_HTTP_VERSION_2_0
// when priorKnowledge=false, letting ALPN drive negotiation) and the libcurl
// @foreign bindings for raw control.

import "std/mem"
import "std/assert"
import "std/string"
import "std/string/builder"
import "std/map"
import "std/thread"
import "std/thread/barrier"
import "std/libc"
import "std/net/posix_socket"
import "std/ssl/openssl"

import "std/http/http" as stdhttp

import "std/ringhttp"


// ---------------------------------------------------------------------------
// Test server — TLS on port 9595
// ---------------------------------------------------------------------------

const TLS_TEST_PORT: u16 = 9595_u16

// Absolute paths to the test cert/key generated by OpenSSL.
//const TLS_CERT = "/build/test/certs/cert.pem"
//const TLS_KEY  = "/build/test/certs/key.pem"
const TLS_CERT = $"../../test/std/ringhttp/certs/cert.pem"
const TLS_KEY  = $"../../test/std/ringhttp/certs/key.pem"


func TlsHelloHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.addHeaderStr("content-type", "text/plain")
    ctx.response.body.append("tls-hello")
    return 1
}

func TlsEchoHandler(ctx: *RequestHandlerContext) : i32 {
    var req = ctx.request
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.body.appendStrn(req.body.buffer, req.body.length)
    return 1
}

struct TlsTestServer {
    config:  HttpConfig
    barrier: Barrier
}

var gTlsServer: TlsTestServer
var gTlsServerReady = false

func TlsServerThread(arg: *void) : i32 {
    var ts = arg as (*TlsTestServer)
    var server = HttpServer{}
    server.init(&ts.config)
    server.addHttpController(HttpMethod.GET,  "/hello", null,
        HttpController{.callback = TlsHelloHandler})
    server.addHttpController(HttpMethod.POST, "/echo",  null,
        HttpController{.callback = TlsEchoHandler})
    ts.barrier.wait()
    server.start()
    defer server.close()
    return 0
}

func ensureTlsServer() {
    if(gTlsServerReady) { return; }

    gTlsServer.config = HttpConfig{
        .allocator             = defaultAllocator,
        .port                  = TLS_TEST_PORT,
        .numThreads            = 2,
        .maxPoolSize           = 32,
        .keepAliveTimeoutInSec = 10,
        .isLogEnabled          = false,
        .tlsCertFile           = TLS_CERT,
        .tlsKeyFile            = TLS_KEY,
    }
    gTlsServer.barrier.init(2)

    var thread = Thread{}
    assert(thread.create(TlsServerThread, &gTlsServer) == ThreadStatus.SUCCESS)
    gTlsServer.barrier.wait()
    ThreadSleepMSec(500)  // give TLS init + worker thread startup a moment
    gTlsServerReady = true
}

func tlsUrl(path: *const char, buf: *char, bufLen: i32) : *const char {
    snprintf(buf, bufLen as (usize), "https://127.0.0.1:%d%s",
        TLS_TEST_PORT as (i32), path)
    return buf
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

// HTTP/2 over TLS (ALPN negotiates h2).
@test("tls_h2_get")
func testTlsH2Get() {
    ensureTlsServer()

    // http2=true → curl offers h2 via ALPN; verifySsl=false for self-signed test cert
    var opts = stdhttp::HttpOptions{ .http2 = true, .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = tlsUrl("/hello", urlBuf, 128)
    assert(client.get(url, &resp))
    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"tls-hello"))
}

// HTTP/1.1 over TLS (ALPN negotiates http/1.1 because we don't set http2=true).
@test("tls_h1_get")
func testTlsH1Get() {
    ensureTlsServer()

    var opts = stdhttp::HttpOptions{ .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = tlsUrl("/hello", urlBuf, 128)
    assert(client.get(url, &resp))
    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"tls-hello"))
}

// POST over TLS with ALPN h2.
@test("tls_h2_post")
func testTlsH2Post() {
    ensureTlsServer()

    var opts = stdhttp::HttpOptions{ .http2 = true, .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = tlsUrl("/echo", urlBuf, 128)
    assert(client.post(url, &resp, $"tls-payload"))
    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"tls-payload"))
}

// ---------------------------------------------------------------------------
// Raw TLS client helper
// ---------------------------------------------------------------------------

// Connect a blocking TLS client to the TLS test server with the given ALPN list.
// Returns the SSL object on success (caller must SSL_free + close underlying fd),
// or null on failure.
func tlsRawConnect(alpnProtos: *const u8, alpnLen: u32) : *SSL {
    var ctx = SSL_CTX_new(TLS_client_method())
    if(!ctx) { return null }

    SSL_CTX_set_verify(ctx, SSL_VERIFY_NONE, null)
    if(alpnProtos != null && alpnLen > 0) {
        SSL_CTX_set_alpn_protos(ctx, alpnProtos, alpnLen)
    }

    var fd = socket(AF_INET, SOCK_STREAM, 0)
    if(fd < 0) {
        SSL_CTX_free(ctx)
        return null
    }

    var addr: sockaddr_in
    memset(&addr, 0, sizeof(:sockaddr_in))
    addr.sin_family = AF_INET
    addr.sin_port   = htons(TLS_TEST_PORT)
    inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr)
    if(connect(fd, (&addr) as (*sockaddr), sizeof(:sockaddr_in) as (socklen_t)) < 0) {
        close(fd)
        SSL_CTX_free(ctx)
        return null
    }

    var ssl = SSL_new(ctx)
    SSL_CTX_free(ctx)
    if(!ssl) {
        close(fd)
        return null
    }

    SSL_set_fd(ssl, fd)
    if(SSL_connect(ssl) != 1) {
        SSL_free(ssl)
        close(fd)
        return null
    }
    return ssl
}

// ---------------------------------------------------------------------------
// Handshake error-path tests
// ---------------------------------------------------------------------------

// Client opens a TCP connection to the TLS port then immediately closes it
// without sending any bytes.
// Exercises: io_uring bytesRead==0 in TLS_HANDSHAKING READ CQE → queueCancelAndClose
//            kqueue: disconnect arrives while waiting for WANT_READ → closeSession
@test("tls_client_abort")
func testTlsClientAbort() {
    ensureTlsServer()

    for(var i = 0; i < 3; i += 1) {
        var fd = socket(AF_INET, SOCK_STREAM, 0)
        assert(fd >= 0)

        var addr: sockaddr_in
        memset(&addr, 0, sizeof(:sockaddr_in))
        addr.sin_family = AF_INET
        addr.sin_port   = htons(TLS_TEST_PORT)
        inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr)
        connect(fd, (&addr) as (*sockaddr), sizeof(:sockaddr_in) as (socklen_t))
        close(fd)
    }

    ThreadSleepMSec(100)

    // Server must still be healthy.
    var opts = stdhttp::HttpOptions{ .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()
    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)
    var urlBuf: [128]char
    assert(client.get(tlsUrl("/hello", urlBuf, 128), &resp))
    assert(resp.statusCode == 200)
}

// Client connects via TCP then sends plaintext HTTP bytes instead of a TLS ClientHello.
// Exercises: fatal SSL_accept error → queueCancelAndClose (io_uring) / closeSession (kqueue)
@test("tls_garbage_handshake")
func testTlsGarbageHandshake() {
    ensureTlsServer()

    for(var i = 0; i < 3; i += 1) {
        var fd = socket(AF_INET, SOCK_STREAM, 0)
        assert(fd >= 0)

        var addr: sockaddr_in
        memset(&addr, 0, sizeof(:sockaddr_in))
        addr.sin_family = AF_INET
        addr.sin_port   = htons(TLS_TEST_PORT)
        inet_pton(AF_INET, "127.0.0.1", &addr.sin_addr)
        connect(fd, (&addr) as (*sockaddr), sizeof(:sockaddr_in) as (socklen_t))

        var garbage = "GET / HTTP/1.1\r\nHost: localhost\r\n\r\n"
        send(fd, garbage as (*void), strlen(garbage), 0)
        ThreadSleepMSec(50)
        close(fd)
    }

    ThreadSleepMSec(100)

    // Server must still be healthy.
    var opts = stdhttp::HttpOptions{ .verifySsl = false }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()
    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)
    var urlBuf: [128]char
    assert(client.get(tlsUrl("/hello", urlBuf, 128), &resp))
    assert(resp.statusCode == 200)
}

// Client negotiates http/1.1-only via ALPN, then sends two pipelined requests
// on the same TLS connection.
// Exercises: ALPN else-branch (not h2) → READ_REQUEST_LINE
//            http/1.1 keep-alive TLS state save/restore across session.begin()
@test("tls_h1_keep_alive")
func testTlsH1KeepAlive() {
    ensureTlsServer()

    // Wire-format: \x08http/1.1
    var alpn = [9]u8 {
        8_u8,
        104_u8, 116_u8, 116_u8, 112_u8, 47_u8, 49_u8, 46_u8, 49_u8
    }
    var ssl = tlsRawConnect(alpn as (*const u8), 9_u32)
    assert(ssl != null)
    var fd = SSL_get_fd(ssl)
    defer {
        SSL_shutdown(ssl)
        SSL_free(ssl)
        close(fd)
    }

    const req = "GET /hello HTTP/1.1\r\nHost: localhost\r\nConnection: keep-alive\r\n\r\n"
    var reqLen = strlen(req) as (i32)

    var buf: [4096]char

    for(var i = 0; i < 2; i += 1) {
        assert(SSL_write(ssl, req as (*const void), reqLen) == reqLen)

        var total = 0
        while(total < 4096) {
            var n = SSL_read(ssl, (buf + total) as (*void), 4096 - total)
            if(n <= 0) { break }
            total += n
            // Stop once we have the full response (double CRLF + body).
            var resp = String{ .buffer = buf, .length = total }
            if(resp.contains($"tls-hello")) { break }
        }
        var resp = String{ .buffer = buf, .length = total }
        assert(resp.contains($"200"))
        assert(resp.contains($"tls-hello"))
    }
}

// Client negotiates h2 via ALPN with a raw TLS connection, performs the h2
// preface exchange, and completes a GET request.
// Exercises: ALPN h2 branch → HTTP2_OPEN over TLS
@test("tls_h2_raw_handshake")
func testTlsH2RawHandshake() {
    ensureTlsServer()

    // Wire-format: \x02h2
    var alpn = [3]u8 { 2_u8, 104_u8, 50_u8 }
    var ssl = tlsRawConnect(alpn as (*const u8), 3_u32)
    assert(ssl != null)
    var fd = SSL_get_fd(ssl)
    defer {
        SSL_shutdown(ssl)
        SSL_free(ssl)
        close(fd)
    }

    // h2 client preface
    const preface = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    assert(SSL_write(ssl, preface as (*const void), 24) == 24)

    // SETTINGS frame (empty)
    var settingsHdr: [9]char
    settingsHdr[3] = 0x04_i8
    assert(SSL_write(ssl, settingsHdr as (*const void), 9) == 9)

    // Read server SETTINGS + ACK (at least 18 bytes)
    var buf: [512]char
    var total = 0
    while(total < 18) {
        var n = SSL_read(ssl, (buf + total) as (*void), 512 - total)
        if(n <= 0) { break }
        total += n
    }
    assert(total >= 18)
    assert((buf[3] as (i32) & 0xFF) == 0x04)  // SETTINGS frame type

    // SETTINGS ACK
    var ackHdr: [9]char
    ackHdr[3] = 0x04_i8
    ackHdr[4] = 0x01_i8
    assert(SSL_write(ssl, ackHdr as (*const void), 9) == 9)

    // HEADERS frame: GET /hello (indexed: method=GET idx=2, scheme=http idx=6; literal path)
    var hpackBuf: [32]char
    var hpackLen = 0
    hpackBuf[hpackLen] = 0x82_i8; hpackLen += 1  // :method GET (idx 2)
    hpackBuf[hpackLen] = 0x84_i8; hpackLen += 1  // :path / (idx 4)... override below
    // Override with literal :path /hello
    hpackLen -= 1
    hpackBuf[hpackLen] = 0x04_i8; hpackLen += 1  // literal, name idx 4 (:path)
    hpackBuf[hpackLen] = 0x06_i8; hpackLen += 1  // length 6
    hpackBuf[hpackLen] = '/' as (i8); hpackLen += 1
    hpackBuf[hpackLen] = 'h' as (i8); hpackLen += 1
    hpackBuf[hpackLen] = 'e' as (i8); hpackLen += 1
    hpackBuf[hpackLen] = 'l' as (i8); hpackLen += 1
    hpackBuf[hpackLen] = 'l' as (i8); hpackLen += 1
    hpackBuf[hpackLen] = 'o' as (i8); hpackLen += 1
    hpackBuf[hpackLen] = 0x86_i8; hpackLen += 1  // :scheme https (idx 6)

    var frameHdr: [9]char
    frameHdr[0] = 0_i8
    frameHdr[1] = 0_i8
    frameHdr[2] = hpackLen as (i8)
    frameHdr[3] = 0x01_i8  // HEADERS
    frameHdr[4] = 0x05_i8  // END_HEADERS | END_STREAM
    frameHdr[5] = 0_i8; frameHdr[6] = 0_i8; frameHdr[7] = 0_i8; frameHdr[8] = 1_i8  // stream 1

    assert(SSL_write(ssl, frameHdr as (*const void), 9) == 9)
    assert(SSL_write(ssl, hpackBuf as (*const void), hpackLen) == hpackLen)

    // Read until we see a HEADERS response frame (type 0x01) with status 200
    total = 0
    var gotHeaders = false
    for(var tries = 0; tries < 20 && !gotHeaders; tries += 1) {
        var n = SSL_read(ssl, (buf + total) as (*void), 512 - total)
        if(n <= 0) { break }
        total += n
        // Scan for a HEADERS frame (type byte at offset 3 of each 9-byte header)
        var off = 0
        while(off + 9 <= total) {
            var ftype = buf[off + 3] as (i32) & 0xFF
            var flen  = ((buf[off + 0] as (i32) & 0xFF) << 16) |
                        ((buf[off + 1] as (i32) & 0xFF) << 8)  |
                         (buf[off + 2] as (i32) & 0xFF)
            if(ftype == 0x01) {  // HEADERS
                gotHeaders = true
                break
            }
            off += 9 + flen
        }
    }
    assert(gotHeaders)
}
