// Smoke tests for the std/http/http client against a local ringhttp h2c server.
//
// Uses HttpOptions{ .priorKnowledge = true } so curl speaks HTTP/2 cleartext
// (no TLS required), matching ringhttp's cleartext mode.
//
// Both "std/http/http" and "std/ringhttp" define HttpRequest/HttpResponse, so
// both are imported under aliases and referenced via :: syntax.

import "std/mem"
import "std/assert"
import "std/string"
import "std/string/builder"
import "std/map"
import "std/thread"
import "std/thread/barrier"
import "std/libc"

import "std/http/http" as stdhttp

import "std/ringhttp"

// ---------------------------------------------------------------------------
// Server on a dedicated port (separate from the raw-socket e2e tests)
// ---------------------------------------------------------------------------

const CLIENT_TEST_PORT: u16 = 9494_u16

func ClientHelloHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.addHeaderStr("content-type", "text/plain")
    ctx.response.body.append("hello from h2")
    return 1
}

func ClientEchoHandler(ctx: *RequestHandlerContext) : i32 {
    var req = ctx.request
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.body.appendStrn(req.body.buffer, req.body.length)
    return 1
}

func ClientJsonHandler(ctx: *RequestHandlerContext) : i32 {
    ctx.response.status = 200
    ctx.response.type   = ResponseType.BODY
    ctx.response.addHeaderStr("content-type", "application/json")
    ctx.response.body.append("{\"version\":\"h2\"}")
    return 1
}

struct ClientTestServer {
    config:  HttpConfig
    barrier: Barrier
}

var gClientServer: ClientTestServer
var gClientServerReady = false

func ClientServerThread(arg: *void) : i32 {
    var ts = arg as (*ClientTestServer)
    var server = HttpServer{}
    server.init(&ts.config)
    server.addHttpController(HttpMethod.GET,  "/hello", null,
        HttpController{.callback = ClientHelloHandler})
    server.addHttpController(HttpMethod.POST, "/echo",  null,
        HttpController{.callback = ClientEchoHandler})
    server.addHttpController(HttpMethod.GET,  "/json",  null,
        HttpController{.callback = ClientJsonHandler})
    ts.barrier.wait()
    server.start()
    defer server.close()
    return 0
}

func ensureClientServer() {
    if(gClientServerReady) { return; }

    gClientServer.config = HttpConfig{
        .allocator             = defaultAllocator,
        .port                  = CLIENT_TEST_PORT,
        .numThreads            = 2,
        .maxPoolSize           = 32,
        .keepAliveTimeoutInSec = 10,
        .isLogEnabled          = false,
    }
    gClientServer.barrier.init(2)

    var thread = Thread{}
    assert(thread.create(ClientServerThread, &gClientServer) == ThreadStatus.SUCCESS)
    gClientServer.barrier.wait()
    ThreadSleepMSec(200)
    gClientServerReady = true
}

// ---------------------------------------------------------------------------
// Helper: build a URL for the local test server
// ---------------------------------------------------------------------------

func localUrl(path: *const char, buf: *char, bufSize: i32) : *const char {
    snprintf(buf, bufSize as (usize), "http://127.0.0.1:%d%s",
        CLIENT_TEST_PORT as (i32), path)
    return buf
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

@test("http2_client_get")
func testHttp2ClientGet() {
    ensureClientServer()

    var opts = stdhttp::HttpOptions{ .priorKnowledge = true }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = localUrl("/hello", urlBuf, 128)
    assert(client.get(url, &resp))

    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"hello from h2"))
}

@test("http2_client_post")
func testHttp2ClientPost() {
    ensureClientServer()

    var opts = stdhttp::HttpOptions{ .priorKnowledge = true }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = localUrl("/echo", urlBuf, 128)
    assert(client.post(url, &resp, $"ping123"))

    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"ping123"))
}

@test("http2_client_not_found")
func testHttp2ClientNotFound() {
    ensureClientServer()

    var opts = stdhttp::HttpOptions{ .priorKnowledge = true }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(64, defaultAllocator)

    var urlBuf: [128]char
    var url = localUrl("/no-such-path", urlBuf, 128)
    assert(client.get(url, &resp))

    assert(resp.statusCode == 404)
}

@test("http2_client_with_headers")
func testHttp2ClientWithHeaders() {
    ensureClientServer()

    var opts = stdhttp::HttpOptions{ .priorKnowledge = true }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var headers = stdhttp::HeadersInit(4, defaultAllocator)
    headers.put($"content-type", $"application/json")
    headers.put($"x-request-id", $"test-42")

    var urlBuf: [128]char
    var url = localUrl("/echo", urlBuf, 128)
    assert(client.post(url, &resp, $"{\"key\":\"value\"}", &headers))

    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"{\"key\":\"value\"}"))
}

@test("http2_client_json")
func testHttp2ClientJson() {
    ensureClientServer()

    var opts = stdhttp::HttpOptions{ .priorKnowledge = true }
    var client: stdhttp::Http
    assert(client.init(&opts))
    defer client.free()

    var resp = stdhttp::HttpResponseInit(256, defaultAllocator)

    var urlBuf: [128]char
    var url = localUrl("/json", urlBuf, 128)
    assert(client.get(url, &resp))

    assert(resp.statusCode == 200)
    var body = String{.buffer = resp.body.buffer as (*const char), .length = resp.body.length}
    assert(body.equals($"{\"version\":\"h2\"}"))
}
