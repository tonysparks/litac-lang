// Unit tests for the HPACK encoder/decoder in http2_hpack.lita.

import "std/mem"
import "std/assert"
import "std/string"
import "std/string/builder"
import "std/array"
import "std/libc"

import "std/ringhttp/http_ring"
import "std/ringhttp/http2_hpack"

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

// Find the first occurrence of needle (lowercase ASCII) in a byte buffer.
// Returns the offset or -1 if not found.
func findBytes(haystack: *const char, haystackLen: i32, needle: *const char, needleLen: i32) : i32 {
    if(needleLen <= 0 || needleLen > haystackLen) { return -1 }
    for(var i = 0; i <= haystackLen - needleLen; i += 1) {
        if(memcmp(haystack + i, needle as (*const void), needleLen as (usize)) == 0) {
            return i
        }
    }
    return -1
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

// Encoder must lowercase header names and Huffman-encode strings.
// Encodes a response with a mixed-case custom header, then decodes the HPACK
// block and verifies the name arrives as lowercase (RFC 7540 §8.1.2).
@test("hpack_encode_lowercase_names")
func testHpackEncodeLowercaseNames() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    var response: HttpResponse
    response.init(defaultAllocator)
    response.status = 200
    response.addHeaderStr("X-My-Header", "SomeValue")

    var out = StringBuilderInit(256, defaultAllocator)
    hpack.encodeResponse(&response, &out)

    // The mixed-case literal bytes must NOT appear on the wire
    // (neither as raw text nor — since Huffman is used — as raw bytes).
    assert(findBytes(out.buffer, out.length, "X-My-Header", 11) < 0)

    // Decode the block back into an HttpRequest and verify lowercase name.
    var request: HttpRequest
    memset(&request, 0, sizeof(:HttpRequest))
    request.headers.init(16, defaultAllocator as (*Allocator))
    request.reset()
    var pe1 = false
    assert(hpack.decode(out.buffer as (*const u8), out.length,
        &request, defaultAllocator as (*Allocator), &pe1) == Status.OK)
    assert(request.headers.length >= 1)
    assert(request.headers.get(0).name.equals($"x-my-header"))
}

// Encoder uses Huffman when it produces fewer bytes.
// "content-type" encodes to 9 bytes Huffman vs 12 raw.
@test("hpack_huffman_shorter_than_raw")
func testHpackHuffmanShorterThanRaw() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    var response: HttpResponse
    response.init(defaultAllocator)
    response.status = 200
    // "content-type" has no static-table entry for its value — will be emitted
    // as literal name (indexed) + Huffman-encoded value "text/plain".
    response.addHeaderStr("content-type", "text/plain")

    var out = StringBuilderInit(256, defaultAllocator)
    hpack.encodeResponse(&response, &out)

    // Decode back; value must survive the round-trip intact.
    var request: HttpRequest
    memset(&request, 0, sizeof(:HttpRequest))
    request.headers.init(16, defaultAllocator as (*Allocator))
    request.reset()
    var pe2 = false
    assert(hpack.decode(out.buffer as (*const u8), out.length,
        &request, defaultAllocator as (*Allocator), &pe2) == Status.OK)
    assert(request.headers.length >= 1)
    assert(request.headers.get(0).values.equals($"text/plain"))
}

// Decoder must accept Huffman-encoded strings and correctly populate the request.
@test("hpack_decode_indexed_method_path")
func testHpackDecodeIndexedMethodPath() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Wire encoding of: :method GET (idx 2) + :path / (idx 4) + :scheme http (idx 6)
    // Each is an indexed header field: 0x80 | index
    var wire: [3]u8
    wire[0] = (0x80 | 2) as (u8)   // :method GET
    wire[1] = (0x80 | 4) as (u8)   // :path /
    wire[2] = (0x80 | 6) as (u8)   // :scheme http

    var request: HttpRequest
    memset(&request, 0, sizeof(:HttpRequest))
    request.reset()

    var pe3 = false
    assert(hpack.decode(wire as (*const u8), 3, &request, defaultAllocator as (*Allocator), &pe3) == Status.OK)
    assert(request.method == HttpMethod.GET)
    assert(request.path.equals($"/"))
}

// Encoder produces indexed representation for :status 200 (static entry 8).
@test("hpack_encode_status_200_indexed")
func testHpackEncodeStatus200Indexed() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    var response: HttpResponse
    response.init(defaultAllocator)
    response.status = 200

    var out = StringBuilderInit(64, defaultAllocator)
    hpack.encodeResponse(&response, &out)

    // First byte must be 0x80 | 8 = 0x88 (indexed :status 200)
    assert(out.length >= 1)
    assert((out.buffer[0] as (i32) & 0xFF) == 0x88)
}

// ---------------------------------------------------------------------------
// Helpers shared by the tests below
// ---------------------------------------------------------------------------

func hpackRequest() : HttpRequest {
    var r: HttpRequest
    memset(&r, 0, sizeof(:HttpRequest))
    r.headers.init(16, defaultAllocator as (*Allocator))
    r.reset()
    return r
}

func hpackDecodeOk(hpack: *Hpack, wire: *const u8, wireLen: i32, req: *HttpRequest, pe: *bool) {
    assert(hpack.decode(wire, wireLen, req, defaultAllocator as (*Allocator), pe) == Status.OK)
}

// ---------------------------------------------------------------------------
// :method variants
// ---------------------------------------------------------------------------

// Static table index 3 = :method POST.
@test("hpack_method_post_static_table")
func testHpackMethodPost() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    var wire: [1]u8
    wire[0] = (0x80 | 3) as (u8)   // indexed :method POST

    var req = hpackRequest()
    var pe = false
    hpackDecodeOk(&hpack, wire as (*const u8), 1, &req, &pe)
    assert(!pe)
    assert(req.method == HttpMethod.POST)
}

// DELETE is not in the static table; must arrive as a literal with name index 2 (:method).
@test("hpack_method_delete_literal")
func testHpackMethodDelete() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Literal without indexing: first byte = name index (4-bit prefix) = 2 (:method)
    // Value string "DELETE" (6 bytes, raw, H-bit clear)
    var wire: [8]u8
    wire[0] = 0x02_u8               // literal without indexing, name idx 2
    wire[1] = 0x06_u8               // string length 6, not Huffman
    wire[2] = 'D' as (u8)
    wire[3] = 'E' as (u8)
    wire[4] = 'L' as (u8)
    wire[5] = 'E' as (u8)
    wire[6] = 'T' as (u8)
    wire[7] = 'E' as (u8)

    var req = hpackRequest()
    var pe = false
    hpackDecodeOk(&hpack, wire as (*const u8), 8, &req, &pe)
    assert(!pe)
    assert(req.method == HttpMethod.DELETE)
}

// ---------------------------------------------------------------------------
// :path query-string splitting
// ---------------------------------------------------------------------------

// :path with a query string must be split at '?': path before, query after.
@test("hpack_path_query_string_split")
func testHpackPathQueryStringSplit() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Literal without indexing, name index 4 (:path), value "/foo?bar=1" (10 bytes)
    var wire: [12]u8
    wire[0]  = 0x04_u8               // name idx 4 (:path)
    wire[1]  = 0x0A_u8               // value length 10, raw
    wire[2]  = '/' as (u8)
    wire[3]  = 'f' as (u8)
    wire[4]  = 'o' as (u8)
    wire[5]  = 'o' as (u8)
    wire[6]  = '?' as (u8)
    wire[7]  = 'b' as (u8)
    wire[8]  = 'a' as (u8)
    wire[9]  = 'r' as (u8)
    wire[10] = '=' as (u8)
    wire[11] = '1' as (u8)

    var req = hpackRequest()
    var pe = false
    hpackDecodeOk(&hpack, wire as (*const u8), 12, &req, &pe)
    assert(!pe)
    assert(req.path.equals($"/foo"))
    assert(req.query.equals($"bar=1"))
}

// :path without '?' must be stored verbatim; query must remain empty.
@test("hpack_path_no_query_string")
func testHpackPathNoQuery() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Literal without indexing, name index 4 (:path), value "/api/users" (10 bytes)
    var wire: [12]u8
    wire[0]  = 0x04_u8
    wire[1]  = 0x0A_u8
    wire[2]  = '/' as (u8)
    wire[3]  = 'a' as (u8)
    wire[4]  = 'p' as (u8)
    wire[5]  = 'i' as (u8)
    wire[6]  = '/' as (u8)
    wire[7]  = 'u' as (u8)
    wire[8]  = 's' as (u8)
    wire[9]  = 'e' as (u8)
    wire[10] = 'r' as (u8)
    wire[11] = 's' as (u8)

    var req = hpackRequest()
    var pe = false
    hpackDecodeOk(&hpack, wire as (*const u8), 12, &req, &pe)
    assert(!pe)
    assert(req.path.equals($"/api/users"))
    assert(req.query.length == 0)
}

// ---------------------------------------------------------------------------
// :authority → host header mapping
// ---------------------------------------------------------------------------

// :authority must be mapped to a "host" regular header (RFC 7540 §8.1.2.3).
@test("hpack_authority_maps_to_host")
func testHpackAuthorityMapsToHost() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Literal without indexing, name index 1 (:authority), value "example.com" (11 bytes)
    var wire: [13]u8
    wire[0]  = 0x01_u8               // name idx 1 (:authority)
    wire[1]  = 0x0B_u8               // value length 11, raw
    wire[2]  = 'e' as (u8)
    wire[3]  = 'x' as (u8)
    wire[4]  = 'a' as (u8)
    wire[5]  = 'm' as (u8)
    wire[6]  = 'p' as (u8)
    wire[7]  = 'l' as (u8)
    wire[8]  = 'e' as (u8)
    wire[9]  = '.' as (u8)
    wire[10] = 'c' as (u8)
    wire[11] = 'o' as (u8)
    wire[12] = 'm' as (u8)

    var req = hpackRequest()
    var pe = false
    hpackDecodeOk(&hpack, wire as (*const u8), 13, &req, &pe)
    assert(!pe)
    assert(req.headers.length >= 1)
    assert(req.headers.get(0).name.equals($"host"))
    assert(req.headers.get(0).values.equals($"example.com"))
}

// ---------------------------------------------------------------------------
// Dynamic table — incremental indexing and cross-decode lookup
// ---------------------------------------------------------------------------

// A header encoded with literal-incremental-indexing must be added to the
// dynamic table and retrievable by index 62 in a subsequent decode.
@test("hpack_dynamic_table_incremental_lookup")
func testHpackLiteralIncrementalDynamicTableLookup() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Literal incremental indexing (0x40), new name "x-custom" (8 bytes), value "hello" (5 bytes)
    var wire1: [16]u8
    wire1[0]  = 0x40_u8   // literal incremental, name literal follows (6-bit prefix = 0)
    wire1[1]  = 0x08_u8   // name length 8, raw
    wire1[2]  = 'x' as (u8)
    wire1[3]  = '-' as (u8)
    wire1[4]  = 'c' as (u8)
    wire1[5]  = 'u' as (u8)
    wire1[6]  = 's' as (u8)
    wire1[7]  = 't' as (u8)
    wire1[8]  = 'o' as (u8)
    wire1[9]  = 'm' as (u8)
    wire1[10] = 0x05_u8   // value length 5, raw
    wire1[11] = 'h' as (u8)
    wire1[12] = 'e' as (u8)
    wire1[13] = 'l' as (u8)
    wire1[14] = 'l' as (u8)
    wire1[15] = 'o' as (u8)

    var req1 = hpackRequest()
    var pe1 = false
    hpackDecodeOk(&hpack, wire1 as (*const u8), 16, &req1, &pe1)
    assert(!pe1)

    // Now look up index 62 — must resolve to the just-added dynamic entry.
    var wire2: [1]u8
    wire2[0] = (0x80 | 62) as (u8)

    var req2 = hpackRequest()
    var pe2 = false
    hpackDecodeOk(&hpack, wire2 as (*const u8), 1, &req2, &pe2)
    assert(!pe2)
    assert(req2.headers.length >= 1)
    assert(req2.headers.get(0).name.equals($"x-custom"))
    assert(req2.headers.get(0).values.equals($"hello"))
}

// ---------------------------------------------------------------------------
// Dynamic table size update (§6.3)
// ---------------------------------------------------------------------------

// A dynamic table size update to 0 must evict all entries; subsequent indexed
// lookups into the (now-empty) dynamic table must not return stale data.
@test("hpack_dynamic_table_size_update_evicts")
func testHpackDynamicTableSizeUpdateEvicts() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Step 1: add "x-tag: v1" via literal incremental indexing.
    var wire1: [13]u8
    wire1[0] = 0x40_u8   // literal incremental, new name
    wire1[1] = 0x05_u8   // name length 5, raw
    wire1[2] = 'x' as (u8)
    wire1[3] = '-' as (u8)
    wire1[4] = 't' as (u8)
    wire1[5] = 'a' as (u8)
    wire1[6] = 'g' as (u8)
    wire1[7] = 0x02_u8   // value length 2, raw
    wire1[8] = 'v' as (u8)
    wire1[9] = '1' as (u8)
    // pad remaining bytes (not decoded)
    wire1[10] = 0x00_u8
    wire1[11] = 0x00_u8
    wire1[12] = 0x00_u8

    var req1 = hpackRequest()
    var pe1 = false
    hpackDecodeOk(&hpack, wire1 as (*const u8), 10, &req1, &pe1)
    assert(!pe1)

    // Step 2: size update to 0 (evicts all) then attempt index 62.
    // Wire: [0x20] = dynamic table size update, 5-bit prefix value 0.
    // Wire: [0x80|62] = indexed header field, index 62.
    var wire2: [2]u8
    wire2[0] = 0x20_u8           // dynamic table size update → 0
    wire2[1] = (0x80 | 62) as (u8)  // index 62 (now empty table)

    // After the table is cleared, index 62 is out of bounds — must be COMPRESSION_ERROR.
    var req2 = hpackRequest()
    var pe2 = false
    assert(hpack.decode(wire2 as (*const u8), 2, &req2, defaultAllocator as (*Allocator), &pe2) != Status.OK)
}

// ---------------------------------------------------------------------------
// Pseudo-header ordering violations (RFC 7540 §8.1.2.1)
// ---------------------------------------------------------------------------

// A pseudo-header that appears after a regular header must set pseudoError.
// Decoding must still complete (returns OK) to keep HPACK state consistent.
@test("hpack_pseudo_after_regular_sets_error")
func testHpackPseudoAfterRegular() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // "content-type: text/html" (literal without indexing, name idx 31)
    // Index 31 > 15 (4-bit prefix max), so two bytes for name index:
    //   byte 0: 0x0F (prefix saturated at 15)
    //   byte 1: 0x10 (16, so 15+16 = 31)
    // Value "text/html" (9 bytes, raw)
    // Then :method GET indexed (0x82) — pseudo after regular.
    var wire: [13]u8
    wire[0]  = 0x0F_u8              // literal without indexing, name idx part 1
    wire[1]  = 0x10_u8              // name idx part 2 → idx 31 = content-type
    wire[2]  = 0x09_u8              // value length 9, raw
    wire[3]  = 't' as (u8)
    wire[4]  = 'e' as (u8)
    wire[5]  = 'x' as (u8)
    wire[6]  = 't' as (u8)
    wire[7]  = '/' as (u8)
    wire[8]  = 'h' as (u8)
    wire[9]  = 't' as (u8)
    wire[10] = 'm' as (u8)
    wire[11] = 'l' as (u8)
    wire[12] = 0x82_u8              // indexed :method GET — pseudo after regular

    var req = hpackRequest()
    var pe = false
    assert(hpack.decode(wire as (*const u8), 13, &req, defaultAllocator as (*Allocator), &pe) == Status.OK)
    assert(pe)  // violation detected
}

// A pseudo-header field appearing more than once must set pseudoError.
@test("hpack_duplicate_pseudo_sets_error")
func testHpackDuplicatePseudo() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // :method GET (index 2) repeated twice.
    var wire: [2]u8
    wire[0] = 0x82_u8   // indexed :method GET
    wire[1] = 0x82_u8   // same, again

    var req = hpackRequest()
    var pe = false
    assert(hpack.decode(wire as (*const u8), 2, &req, defaultAllocator as (*Allocator), &pe) == Status.OK)
    assert(pe)
}

// ---------------------------------------------------------------------------
// Encoder — status codes
// ---------------------------------------------------------------------------

// Non-static status codes must be emitted as literal-without-indexing (§6.2.2)
// with name index 8 (:status) as first byte (0x08).
@test("hpack_encode_status_non_static_code")
func testHpackEncodeStatusNonStatic() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    var out = StringBuilderInit(16, defaultAllocator)
    hpack.encodeStatus(201, &out)

    assert(out.length >= 1)
    assert((out.buffer[0] as (i32) & 0xFF) == 0x08)   // literal, name idx 8
    assert(findBytes(out.buffer, out.length, "201", 3) >= 0)

    // Verify a second non-static code follows the same pattern.
    var out2 = StringBuilderInit(16, defaultAllocator)
    hpack.encodeStatus(301, &out2)
    assert((out2.buffer[0] as (i32) & 0xFF) == 0x08)
    assert(findBytes(out2.buffer, out2.length, "301", 3) >= 0)
}

// Static status codes 404 and 500 must emit their indexed one-byte form.
@test("hpack_encode_status_404_and_500_indexed")
func testHpackEncodeStatusStaticVariants() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    var out404 = StringBuilderInit(8, defaultAllocator)
    hpack.encodeStatus(404, &out404)
    assert(out404.length == 1)
    assert((out404.buffer[0] as (i32) & 0xFF) == (0x80 | 13))   // static entry 13

    var out500 = StringBuilderInit(8, defaultAllocator)
    hpack.encodeStatus(500, &out500)
    assert(out500.length == 1)
    assert((out500.buffer[0] as (i32) & 0xFF) == (0x80 | 14))   // static entry 14
}

// ---------------------------------------------------------------------------
// content-length header parsing
// ---------------------------------------------------------------------------

// The decoder must parse the content-length literal and set request.bodyLength.
// Name index 28 (> 4-bit max 15) requires a two-byte index encoding.
@test("hpack_content_length_sets_body_length")
func testHpackContentLengthParsed() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Literal without indexing, name idx 28 (content-length):
    //   byte 0: 0x0F (4-bit prefix saturated → 15)
    //   byte 1: 0x0D (13, so 15+13 = 28)
    // Value "1024" (4 bytes, raw)
    var wire: [7]u8
    wire[0] = 0x0F_u8
    wire[1] = 0x0D_u8
    wire[2] = 0x04_u8               // value length 4, raw
    wire[3] = '1' as (u8)
    wire[4] = '0' as (u8)
    wire[5] = '2' as (u8)
    wire[6] = '4' as (u8)

    var req = hpackRequest()
    var pe = false
    hpackDecodeOk(&hpack, wire as (*const u8), 7, &req, &pe)
    assert(!pe)
    assert(req.bodyLength == 1024)
    assert((req.flags & HttpFlags.CONTENT_LENGTH_PROVIDED) != 0)
}

// ---------------------------------------------------------------------------
// Error paths
// ---------------------------------------------------------------------------

// Index 0 is not a valid HPACK index; the decoder must return an error.
@test("hpack_invalid_index_zero_returns_error")
func testHpackInvalidIndexZero() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    var wire: [1]u8
    wire[0] = 0x80_u8   // indexed header field, index 0

    var req = hpackRequest()
    var pe = false
    assert(hpack.decode(wire as (*const u8), 1, &req, defaultAllocator as (*Allocator), &pe) == Status.ERROR_PARSING_HTTP_REQUEST)
}

// A string whose declared length extends past the end of the payload must
// cause the decoder to return an error (no out-of-bounds read).
@test("hpack_truncated_string_returns_error")
func testHpackTruncatedStringPayload() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Literal incremental (0x40), new name, claimed length 5 but only 3 bytes follow.
    var wire: [5]u8
    wire[0] = 0x40_u8   // literal incremental, new name
    wire[1] = 0x05_u8   // name string length 5 (raw)
    wire[2] = 'a' as (u8)
    wire[3] = 'b' as (u8)
    wire[4] = 'c' as (u8)  // only 3 bytes, but length says 5 → truncated

    var req = hpackRequest()
    var pe = false
    assert(hpack.decode(wire as (*const u8), 5, &req, defaultAllocator as (*Allocator), &pe) == Status.ERROR_PARSING_HTTP_REQUEST)
}

// ---------------------------------------------------------------------------
// Multi-byte integer encoding (RFC 7541 §5.1)
// ---------------------------------------------------------------------------

// Verify the decoder correctly handles a multi-byte integer in the indexed
// representation. Index 62 (first dynamic slot) requires the 7-bit prefix
// to stay in a single byte (62 < 127), but this test verifies that a
// two-decode sequence where the dynamic table entry was added in the prior
// call uses the right index arithmetic.
// (Separate from testHpackLiteralIncrementalDynamicTableLookup because here
//  we verify encode→decode of a large static-table-range value via encodeResponse.)
@test("hpack_encode_response_roundtrip_static_header_name")
func testHpackEncodeResponseStaticNameRoundtrip() {
    var hpack: Hpack
    hpack.init(defaultAllocator as (*Allocator))

    // Encode a response with "content-length: 42" — static name (index 28).
    var response: HttpResponse
    response.init(defaultAllocator)
    response.status = 200
    response.addHeaderStr("content-length", "42")

    var out = StringBuilderInit(64, defaultAllocator)
    hpack.encodeResponse(&response, &out)

    // Decode back and verify content-length survives the round-trip.
    var hpack2: Hpack
    hpack2.init(defaultAllocator as (*Allocator))
    var req = hpackRequest()
    var pe = false
    // encodeResponse emits :status (response-only pseudo-header), so pe will fire
    // when decoded through the request decoder — that's expected and harmless here.
    hpackDecodeOk(&hpack2, out.buffer as (*const u8), out.length, &req, &pe)
    assert(req.bodyLength == 42)
}
