    [1]=":authority",       [2]=":method",          [3]=":method",
    [4]=":path",            [5]=":path",             [6]=":scheme",
    [7]=":scheme",          [8]=":status",           [9]=":status",
    [10]=":status",         [11]=":status",          [12]=":status",
    [13]=":status",         [14]=":status",          [15]="accept-charset",
