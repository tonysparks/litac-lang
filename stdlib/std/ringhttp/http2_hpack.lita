// ---------------------------------------------------------------------------
// Huffman decoder trie — stored inside Hpack (no global mutable state)
// ---------------------------------------------------------------------------

const HUFF_NO_CHILD: i16 = -1_i16

struct HuffNode {
    children: [2]i16   // child indices; HUFF_NO_CHILD = none
    symbol:   i16      // -1 = internal, 0-255 = leaf symbol
}

const HPACK_TRIE_SIZE: i32 = 513

// ---------------------------------------------------------------------------
// Dynamic table
// ---------------------------------------------------------------------------

public const HPACK_MAX_DYN_ENTRIES: i32 = 128
const HPACK_ENTRY_OVERHEAD: i32 = 32
const HPACK_INITIAL_TABLE_SIZE: i32 = 4096

struct HpackEntry {
    name:  String
    value: String
    size:  i32
}

// ---------------------------------------------------------------------------
// Hpack context (per-connection)
// ---------------------------------------------------------------------------

public struct Hpack {
    // Huffman decoder trie (built on init)
    huffTrie:  [HPACK_TRIE_SIZE]HuffNode
    huffCount: i32

    // Dynamic table (circular buffer; dynStart = index of newest entry)
    dynEntries:   [HPACK_MAX_DYN_ENTRIES]HpackEntry
    dynStart:     i32
    dynCount:     i32
    dynTableSize: i32
    dynMaxSize:   i32
    maxAllowed:   i32   // SETTINGS_HEADER_TABLE_SIZE limit from our own SETTINGS

    allocator: *Allocator
}

// ---------------------------------------------------------------------------
// Trie build
// ---------------------------------------------------------------------------

func (this: *Hpack) buildTrie() {
    for(var i = 0; i < HPACK_TRIE_SIZE; i += 1) {
        this.huffTrie[i].children[0] = HUFF_NO_CHILD
        this.huffTrie[i].children[1] = HUFF_NO_CHILD
        this.huffTrie[i].symbol      = -1_i16
    }
    this.huffCount = 1  // root = node 0

    for(var sym = 0; sym < 256; sym += 1) {
        var code = H_CODE[sym]
        var bits = H_BITS[sym]
        var node: i32 = 0

        for(var bit = bits - 1; bit >= 0; bit -= 1) {
            var b = (code >> bit) & 1
            if(bit == 0) {
                var leaf = this.huffCount as (i16)
                this.huffTrie[this.huffCount].children[0] = HUFF_NO_CHILD
                this.huffTrie[this.huffCount].children[1] = HUFF_NO_CHILD
                this.huffTrie[this.huffCount].symbol      = sym as (i16)
                this.huffTrie[node].children[b]           = leaf
                this.huffCount += 1
            } else {
                if(this.huffTrie[node].children[b] == HUFF_NO_CHILD) {
                    var internalCount = this.huffCount as (i16)
                    this.huffTrie[this.huffCount].children[0] = HUFF_NO_CHILD
                    this.huffTrie[this.huffCount].children[1] = HUFF_NO_CHILD
                    this.huffTrie[this.huffCount].symbol      = -1_i16
                    this.huffTrie[node].children[b]           = internalCount
                    this.huffCount += 1
                }
                node = this.huffTrie[node].children[b] as (i32)
            }
        }
    }
}

public func (this: *Hpack) init(allocator: *Allocator) {
    memset(this, 0, sizeof(:Hpack))
    this.allocator    = allocator
    this.dynMaxSize   = HPACK_INITIAL_TABLE_SIZE
    this.maxAllowed   = HPACK_INITIAL_TABLE_SIZE
    this.buildTrie()
}

// ---------------------------------------------------------------------------
// Dynamic table helpers
// ---------------------------------------------------------------------------

func (this: *Hpack) dynGet(offset: i32) : *HpackEntry {
    if(offset < 0 || offset >= this.dynCount) {
        return null
    }
    var idx = (this.dynStart + offset) % HPACK_MAX_DYN_ENTRIES
    return &this.dynEntries[idx]
}

func (this: *Hpack) dynEvictOldest() {
    var oldest = (this.dynStart + this.dynCount - 1) % HPACK_MAX_DYN_ENTRIES
    this.dynTableSize -= this.dynEntries[oldest].size
    this.dynCount -= 1
}

func (this: *Hpack) dynAdd(name: String, value: String) {
    var entrySize = name.length + value.length + HPACK_ENTRY_OVERHEAD
    while(this.dynCount > 0 && this.dynTableSize + entrySize > this.dynMaxSize) {
        this.dynEvictOldest()
    }
    if(entrySize > this.dynMaxSize || this.dynCount >= HPACK_MAX_DYN_ENTRIES) {
        return;
    }
    this.dynStart = (this.dynStart - 1 + HPACK_MAX_DYN_ENTRIES) % HPACK_MAX_DYN_ENTRIES
    this.dynCount += 1

    var nameBuf  = this.allocator.alloc(name.length + 1) as (*char)
    var valueBuf = this.allocator.alloc(value.length + 1) as (*char)
    if(name.length > 0) {
        memcpy(nameBuf, name.buffer, name.length as (usize))
    }
    nameBuf[name.length] = '\0'
    if(value.length > 0) {
        memcpy(valueBuf, value.buffer, value.length as (usize))
    }
    valueBuf[value.length] = '\0'

    var e = &this.dynEntries[this.dynStart]
    e.name  = String{.buffer = nameBuf  as (*const char), .length = name.length}
    e.value = String{.buffer = valueBuf as (*const char), .length = value.length}
    e.size  = entrySize
    this.dynTableSize += entrySize
}

public func (this: *Hpack) updateMaxSize(newMax: i32) {
    this.dynMaxSize = newMax
    while(this.dynCount > 0 && this.dynTableSize > this.dynMaxSize) {
        this.dynEvictOldest()
    }
}

func (this: *Hpack) indexName(idx: i32) : String {
    if(idx >= 1 && idx <= 61) {
        return StringInit(ST_NAME[idx])
    }
    var dyn = this.dynGet(idx - 62)
    if(dyn != null) {
        return dyn.name
    }
    return String{}
}

func (this: *Hpack) indexValue(idx: i32) : String {
    if(idx >= 1 && idx <= 61) {
        return StringInit(ST_VALUE[idx])
    }
    var dyn = this.dynGet(idx - 62)
    if(dyn != null) {
        return dyn.value
    }
    return String{}
}

// ---------------------------------------------------------------------------
// Integer decode (RFC 7541 §5.1)
// Returns value; caller passes pos by value and receives newPos via out param.
// ---------------------------------------------------------------------------

struct IntResult {
    value:  i32
    newPos: i32
}

func decodeInt(
    payload:     *const u8,
    payloadLen:  i32,
    pos:         i32,
    prefixBits:  i32,
    firstMasked: i32
) : IntResult {
    var maxFirst = (1 << prefixBits) - 1
    var val = firstMasked & maxFirst
    if(val < maxFirst) {
        return IntResult{.value = val, .newPos = pos}
    }
    var M = 0
    var p = pos
    while(p < payloadLen) {
        var next = payload[p] as (i32)
        p += 1
        val += (next & 0x7f) << M
        M += 7
        if((next & 0x80) == 0) {
            break
        }
    }
    return IntResult{.value = val, .newPos = p}
}

// ---------------------------------------------------------------------------
// Huffman decode into a StringBuilder
// ---------------------------------------------------------------------------

func (this: *Hpack) huffDecode(
    input:    *const u8,
    inputLen: i32,
    out:      *StringBuilder
) : bool {
    var node: i32 = 0
    var bitsAfterLastSymbol: i32 = 0
    var sawZeroBit: bool = false
    for(var i = 0; i < inputLen; i += 1) {
        var byte = input[i] as (i32)
        for(var bit = 7; bit >= 0; bit -= 1) {
            var b   = (byte >> bit) & 1
            var nxt = this.huffTrie[node].children[b] as (i32)
            if(nxt < 0) {
                return false
            }
            bitsAfterLastSymbol += 1
            if(b == 0) { sawZeroBit = true }
            var sym = this.huffTrie[nxt].symbol as (i32)
            if(sym >= 0) {
                if(sym == 256) {
                    return true  // EOS
                }
                var ch = sym as (char)
                out.appendStrn(&ch, 1)
                node = 0
                bitsAfterLastSymbol = 0
                sawZeroBit = false
            } else {
                node = nxt
            }
        }
    }
    // RFC 7541 §5.2: padding bits MUST be ≤7 and MUST be the EOS prefix (all 1s).
    if(node != 0) {
        if(bitsAfterLastSymbol > 7) { return false }
        if(sawZeroBit) { return false }
    }
    return true
}

// ---------------------------------------------------------------------------
// String decode (RFC 7541 §5.2)
// ---------------------------------------------------------------------------

struct StringResult {
    value:  String
    newPos: i32
    ok:     bool
}

func (this: *Hpack) decodeString(
    payload:    *const u8,
    payloadLen: i32,
    pos:        i32,
    allocator:  *Allocator
) : StringResult {
    if(pos >= payloadLen) {
        return StringResult{.ok = false}
    }
    var first     = payload[pos] as (i32)
    var isHuffman = (first & 0x80) != 0
    var lenResult = decodeInt(payload, payloadLen, pos + 1, 7, first)
    var strLen    = lenResult.value
    var p         = lenResult.newPos

    if(p + strLen > payloadLen || strLen < 0) {
        return StringResult{.ok = false}
    }
    var data = payload + p
    p += strLen

    if(isHuffman) {
        var sb = StringBuilder{}
        sb.init(strLen + 4, allocator)
        if(!this.huffDecode(data, strLen, &sb)) {
            return StringResult{.ok = false}
        }
        return StringResult{.value = String{.buffer = sb.buffer as (*const char), .length = sb.length}, .newPos = p, .ok = true}
    }

    var buf = allocator.alloc(strLen + 1) as (*char)
    if(strLen > 0) {
        memcpy(buf, data, strLen as (usize))
    }
    buf[strLen] = '\0'
    return StringResult{
        .value  = String{.buffer = buf as (*const char), .length = strLen},
        .newPos = p,
        .ok     = true
    }
}

// ---------------------------------------------------------------------------
// Apply decoded name+value to an HttpRequest
// ---------------------------------------------------------------------------

func applyHeader(name: String, value: String, request: *HttpRequest) {
    if(name.length > 0 && name.buffer[0] == ':') {
        if(name.equals($":method")) {
            if(value.equals($"GET"))     { request.method = HttpMethod.GET;     return; }
            if(value.equals($"POST"))    { request.method = HttpMethod.POST;    return; }
            if(value.equals($"PUT"))     { request.method = HttpMethod.PUT;     return; }
            if(value.equals($"DELETE"))  { request.method = HttpMethod.DELETE;  return; }
            if(value.equals($"HEAD"))    { request.method = HttpMethod.HEAD;    return; }
            if(value.equals($"PATCH"))   { request.method = HttpMethod.PATCH;   return; }
            if(value.equals($"OPTIONS")) { request.method = HttpMethod.OPTIONS; return; }
            if(value.equals($"TRACE"))   { request.method = HttpMethod.TRACE;   return; }
            return;
        }
        if(name.equals($":path")) {
            var qpos = -1
            for(var i = 0; i < value.length; i += 1) {
                if(value.buffer[i] == '?') {
                    qpos = i
                    break
                }
            }
            if(qpos >= 0) {
                request.path  = value.substring(0, qpos)
                request.query = value.substring(qpos + 1)
            } else {
                request.path  = value
                request.query = String{}
            }
            return;
        }
        if(name.equals($":scheme")) {
            request.scheme = value
            return;
        }
        if(name.equals($":authority")) {
            var hdr = HttpHeader{.name = $"host", .values = value}
            request.headers.add(hdr)
            return;
        }
        return;
    }

    if(name.equalsIgnoreCase($"content-length")) {
        var n = 0
        for(var i = 0; i < value.length; i += 1) {
            var c = value.buffer[i] as (i32)
            if(c >= ('0' as (i32)) && c <= ('9' as (i32))) {
                n = n * 10 + (c - ('0' as (i32)))
            }
        }
        request.bodyLength = n
        request.flags |= HttpFlags.CONTENT_LENGTH_PROVIDED
    }

    var hdr = HttpHeader{.name = name, .values = value}
    request.headers.add(hdr)
}

// ---------------------------------------------------------------------------
// Decode a complete HPACK header block
// ---------------------------------------------------------------------------

// Bitmask values for pseudo-header seen tracking.
const PSEUDO_AUTHORITY: i32 = 0x01
const PSEUDO_METHOD:    i32 = 0x02
const PSEUDO_PATH:      i32 = 0x04
const PSEUDO_SCHEME:    i32 = 0x08
const PSEUDO_STATUS:    i32 = 0x10

func pseudoBit(name: String) : i32 {
    if(name.equals($":authority")) { return PSEUDO_AUTHORITY }
    if(name.equals($":method"))    { return PSEUDO_METHOD    }
    if(name.equals($":path"))      { return PSEUDO_PATH      }
    if(name.equals($":scheme"))    { return PSEUDO_SCHEME    }
    return 0
}

// Decode a complete HPACK header block.
//
// pseudoError is set to true (but decoding continues to keep HPACK state
// consistent) if:
//   • any pseudo-header field appears more than once, or
//   • a pseudo-header field appears after a regular header field.
// Both are stream-level PROTOCOL_ERRORs per RFC 7540 §8.1.2.1 / §8.1.2.6.
public func (this: *Hpack) decode(
    payload:     *const u8,
    payloadLen:  i32,
    request:     *HttpRequest,
    allocator:   *Allocator,
    pseudoError: *bool
) : Status {
    var pos         = 0
    var seenPseudo  = 0
    var seenRegular = false
    var seenHeader  = false  // any indexed/literal field seen (table size updates must precede)

    while(pos < payloadLen) {
        var first = payload[pos] as (i32)

        if((first & 0x80) != 0) {
            // §6.1 Indexed Header Field
            var r = decodeInt(payload, payloadLen, pos + 1, 7, first)
            pos = r.newPos
            if(r.value < 1) {
                return Status.ERROR_PARSING_HTTP_REQUEST
            }
            // RFC 7541 §2.3.3: index beyond static+dynamic table is a decoding error.
            if(r.value > 61 && (r.value - 62) >= this.dynCount) {
                return Status.ERROR_PARSING_HTTP_REQUEST
            }
            var name  = this.indexName(r.value)
            var value = this.indexValue(r.value)
            seenHeader = true
            var bit   = pseudoBit(name)
            if(bit != 0) {
                if(seenRegular || (seenPseudo & bit) != 0) { *pseudoError = true }
                seenPseudo |= bit
            } else if(name.length > 0 && name.buffer[0] == ':') {
                *pseudoError = true   // response-only or unknown pseudo-header
            } else {
                seenRegular = true
            }
            applyHeader(name, value, request)

        } else if((first & 0x40) != 0) {
            // §6.2.1 Literal + Incremental Indexing
            var ri = decodeInt(payload, payloadLen, pos + 1, 6, first)
            pos = ri.newPos
            var name: String
            if(ri.value > 0) {
                if(ri.value > 61 && (ri.value - 62) >= this.dynCount) {
                    return Status.ERROR_PARSING_HTTP_REQUEST
                }
                name = this.indexName(ri.value)
            } else {
                var rn = this.decodeString(payload, payloadLen, pos, allocator)
                if(!rn.ok) {
                    return Status.ERROR_PARSING_HTTP_REQUEST
                }
                name = rn.value
                pos  = rn.newPos
            }
            var rv = this.decodeString(payload, payloadLen, pos, allocator)
            if(!rv.ok) {
                return Status.ERROR_PARSING_HTTP_REQUEST
            }
            pos = rv.newPos
            this.dynAdd(name, rv.value)
            seenHeader = true
            var bit = pseudoBit(name)
            if(bit != 0) {
                if(seenRegular || (seenPseudo & bit) != 0) { *pseudoError = true }
                seenPseudo |= bit
            } else if(name.length > 0 && name.buffer[0] == ':') {
                *pseudoError = true
            } else {
                seenRegular = true
            }
            applyHeader(name, rv.value, request)

        } else if((first & 0xe0) == 0x20) {
            // §6.3 Dynamic Table Size Update
            var r = decodeInt(payload, payloadLen, pos + 1, 5, first)
            pos = r.newPos
            // RFC 7541 §4.2: size updates MUST appear before any header field.
            if(seenHeader) {
                return Status.ERROR_PARSING_HTTP_REQUEST
            }
            // RFC 7541 §6.3: new size MUST NOT exceed SETTINGS_HEADER_TABLE_SIZE.
            if(r.value > this.maxAllowed) {
                return Status.ERROR_PARSING_HTTP_REQUEST
            }
            this.updateMaxSize(r.value)

        } else {
            // §6.2.2 / §6.2.3 Literal without / never indexing
            var ri = decodeInt(payload, payloadLen, pos + 1, 4, first & 0x0f)
            pos = ri.newPos
            var name: String
            if(ri.value > 0) {
                if(ri.value > 61 && (ri.value - 62) >= this.dynCount) {
                    return Status.ERROR_PARSING_HTTP_REQUEST
                }
                name = this.indexName(ri.value)
            } else {
                var rn = this.decodeString(payload, payloadLen, pos, allocator)
                if(!rn.ok) {
                    return Status.ERROR_PARSING_HTTP_REQUEST
                }
                name = rn.value
                pos  = rn.newPos
            }
            var rv = this.decodeString(payload, payloadLen, pos, allocator)
            if(!rv.ok) {
                return Status.ERROR_PARSING_HTTP_REQUEST
            }
            pos = rv.newPos
            seenHeader = true
            var bit = pseudoBit(name)
            if(bit != 0) {
                if(seenRegular || (seenPseudo & bit) != 0) { *pseudoError = true }
                seenPseudo |= bit
            } else if(name.length > 0 && name.buffer[0] == ':') {
                *pseudoError = true
            } else {
                seenRegular = true
            }
            applyHeader(name, rv.value, request)
        }
    }

    return Status.OK
}

// ---------------------------------------------------------------------------
// Encoder — literal-without-indexing, no Huffman
// ---------------------------------------------------------------------------

func writeIntEnc(val: i32, prefixBits: i32, firstBytePrefix: i32, out: *StringBuilder) {
    var maxFirst = (1 << prefixBits) - 1
    if(val < maxFirst) {
        var b = (firstBytePrefix | val) as (char)
        out.appendStrn(&b, 1)
        return;
    }
    var b = (firstBytePrefix | maxFirst) as (char)
    out.appendStrn(&b, 1)
    val -= maxFirst
    while(val > 127) {
        var nb = ((val & 0x7f) | 0x80) as (char)
        out.appendStrn(&nb, 1)
        val >>= 7
    }
    var last = val as (char)
    out.appendStrn(&last, 1)
}

// ---------------------------------------------------------------------------
// Huffman encoder helpers
// ---------------------------------------------------------------------------

// Number of bytes needed to Huffman-encode dataLen bytes from data.
func huffEncodeLen(data: *const u8, dataLen: i32) : i32 {
    var bits = 0
    for(var i = 0; i < dataLen; i += 1) {
        bits += H_BITS[data[i] as (i32)]
    }
    return (bits + 7) / 8
}

// Append Huffman-encoded payload bytes (no length prefix) to out.
// Packs codes MSB-first; pads the final byte with 1-bits per RFC 7541 §5.2.
func huffEncodeBits(data: *const u8, dataLen: i32, out: *StringBuilder) {
    var curByte:  u32 = 0_u32
    var bitsLeft: i32 = 8
    for(var i = 0; i < dataLen; i += 1) {
        var sym   = data[i] as (i32)
        var code  = H_CODE[sym] as (u32)
        var bits  = H_BITS[sym]
        while(bits > 0) {
            if(bits >= bitsLeft) {
                curByte |= (code >> (bits - bitsLeft)) & ((1_u32 << bitsLeft) - 1_u32)
                bits -= bitsLeft
                var b = curByte as (char)
                out.appendStrn(&b, 1)
                curByte   = 0_u32
                bitsLeft  = 8
            } else {
                curByte |= (code & ((1_u32 << bits) - 1_u32)) << (bitsLeft - bits)
                bitsLeft -= bits
                bits = 0
            }
        }
    }
    if(bitsLeft < 8) {
        curByte |= (1_u32 << bitsLeft) - 1_u32   // pad with 1-bits
        var b = curByte as (char)
        out.appendStrn(&b, 1)
    }
}

// ---------------------------------------------------------------------------
// String literal writers — use Huffman when it produces fewer bytes.
// ---------------------------------------------------------------------------

func writeStringLit(s: String, out: *StringBuilder) {
    var huffLen = huffEncodeLen(s.buffer as (*const u8), s.length)
    if(huffLen < s.length) {
        writeIntEnc(huffLen, 7, 0x80, out)   // H bit set
        huffEncodeBits(s.buffer as (*const u8), s.length, out)
    } else {
        writeIntEnc(s.length, 7, 0, out)
        if(s.length > 0) { out.appendStrn(s.buffer, s.length) }
    }
}

// Like writeStringLit but lowercases ASCII letters before encoding (RFC 7540 §8.1.2).
// Uses a 256-byte stack buffer; names longer than that fall back to raw literal.
func writeStringLitLower(s: String, out: *StringBuilder) {
    var buf: [256]u8
    if(s.length > 255) {
        // Fallback: emit raw literal with per-byte lowercasing (no Huffman)
        writeIntEnc(s.length, 7, 0, out)
        for(var i = 0; i < s.length; i += 1) {
            var c = s.buffer[i] as (i32)
            if(c >= 0x41 && c <= 0x5A) { c |= 0x20 }
            var b = c as (char)
            out.appendStrn(&b, 1)
        }
        return;
    }
    for(var i = 0; i < s.length; i += 1) {
        var c = s.buffer[i] as (i32)
        if(c >= 0x41 && c <= 0x5A) { c |= 0x20 }
        buf[i] = c as (u8)
    }
    var huffLen = huffEncodeLen(buf as (*const u8), s.length)
    if(huffLen < s.length) {
        writeIntEnc(huffLen, 7, 0x80, out)
        huffEncodeBits(buf as (*const u8), s.length, out)
    } else {
        writeIntEnc(s.length, 7, 0, out)
        if(s.length > 0) { out.appendStrn(buf as (*const char), s.length) }
    }
}

public func (this: *Hpack) encodeStatus(statusCode: i32, out: *StringBuilder) {
    // Static entries 8-14: :status 200, 204, 206, 304, 400, 404, 500
    if(statusCode == 200) { var b = (0x80 | 8) as (char);  out.appendStrn(&b, 1); return; }
    if(statusCode == 204) { var b = (0x80 | 9) as (char);  out.appendStrn(&b, 1); return; }
    if(statusCode == 206) { var b = (0x80 | 10) as (char); out.appendStrn(&b, 1); return; }
    if(statusCode == 304) { var b = (0x80 | 11) as (char); out.appendStrn(&b, 1); return; }
    if(statusCode == 400) { var b = (0x80 | 12) as (char); out.appendStrn(&b, 1); return; }
    if(statusCode == 404) { var b = (0x80 | 13) as (char); out.appendStrn(&b, 1); return; }
    if(statusCode == 500) { var b = (0x80 | 14) as (char); out.appendStrn(&b, 1); return; }
    // Literal without indexing, name index 8 (:status)
    var prefix = 0x08 as (char)
    out.appendStrn(&prefix, 1)
    var statusStr: [8]char
    var statusLen = snprintf(statusStr, 8_usize, "%d", statusCode)
    writeIntEnc(statusLen, 7, 0, out)
    if(statusLen > 0) {
        out.appendStrn(statusStr, statusLen)
    }
}

func staticNameIdx(name: String) : i32 {
    for(var i = 1; i <= 61; i += 1) {
        if(name.equalsIgnoreCase(StringInit(ST_NAME[i]))) {
            return i
        }
    }
    return 0
}

public func (this: *Hpack) encodeResponse(response: *HttpResponse, out: *StringBuilder) {
    this.encodeStatus(response.status, out)
    for(var i = 0; i < response.numberOfHeaders as (i32); i += 1) {
        var h   = &response.headers[i]
        var idx = staticNameIdx(h.name)
        if(idx > 0) {
            writeIntEnc(idx, 4, 0, out)
        } else {
            var zero = 0x00 as (char)
            out.appendStrn(&zero, 1)
            writeStringLitLower(h.name, out)
        }
        writeStringLit(h.values, out)
    }
}

