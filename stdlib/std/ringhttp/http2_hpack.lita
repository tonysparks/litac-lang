// HPACK header compression (RFC 7541).
// Huffman table from RFC 7541 Appendix B; static table from Appendix A.
//
// Encoder: literal-without-indexing, no Huffman (RFC permits this).
// Decoder: full — static table, dynamic table, Huffman decode.
//
// The trie is stored inside the Hpack struct and built once on init().

import "std/string"
import "std/string/builder"
import "std/array"
import "std/libc"
import "std/mem"
import "std/log"

import "std/ringhttp/http_common"
import "std/ringhttp/http_request"
import "std/ringhttp/http_response"

// ---------------------------------------------------------------------------
// Huffman tables — RFC 7541 Appendix B (codes stored as i32; all fit)
// ---------------------------------------------------------------------------

